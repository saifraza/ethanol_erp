# biometric-bridge environment template.
# Copy this to `.env` (auto-created by install-windows.ps1 with a fresh key)
# and never commit the real .env.

# Shared secret with the cloud backend. Must match Railway's
# BIOMETRIC_BRIDGE_KEY env var. install-windows.ps1 generates a random one
# the first time it runs.
BIOMETRIC_BRIDGE_KEY=replace-me-with-random-48-char-value
