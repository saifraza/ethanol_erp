generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// FACTORY SERVER SCHEMA — Lightweight, local-first
// This is SEPARATE from the cloud ERP schema (61 models).
// Only stores what the factory floor needs locally.
// ============================================================

// --- USERS ---
model FactoryUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt hashed
  name      String
  role      String   @default("GATE_ENTRY") // ADMIN, GATE_ENTRY, WEIGHBRIDGE, FUEL_YARD, LAB
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// --- WEIGHMENTS ---
// Central weighment records — all PCs create/update via factory server API
model Weighment {
  id            String   @id @default(uuid())
  localId       String   @unique // UUID (used in QR codes)
  ticketNo      Int?     @unique // Auto-increment ticket number for slips
  pcId          String   // Which PC created gate entry
  pcName        String?
  vehicleNo     String
  direction     String   // INBOUND, OUTBOUND
  // Purchase info
  purchaseType  String?  // PO, SPOT, OUTBOUND
  poNumber      String?
  poId          String?  // Cloud PO UUID
  poLineId      String?  // Cloud PO line UUID
  supplierName  String?
  supplierId    String?
  materialName  String?
  materialId    String?
  materialCategory String?  // RAW_MATERIAL, FUEL, CHEMICAL, PACKING
  // Gate entry details
  gateEntryNo   String?
  transporter   String?
  vehicleType   String?  // Truck 14W, 10W, 6W, Tractor Trolley, Pickup
  driverName    String?
  driverPhone   String?
  operatorName  String?  // Who created gate entry
  shift         String?  // First Shift, Second Shift, Third Shift
  bags          Int?
  remarks       String?
  // Spot purchase fields
  sellerPhone   String?
  sellerVillage String?
  sellerAadhaar String?
  rate          Float?   // Per KG rate
  deductions    Float?
  deductionReason String?
  paymentMode   String?  // CASH, UPI, BANK_TRANSFER
  paymentRef    String?
  // Weights
  grossWeight   Float?
  tareWeight    Float?
  netWeight     Float?
  weightSource  String?  // SERIAL, MANUAL
  grossPcId     String?  // Which PC captured gross weight
  tarePcId      String?  // Which PC captured tare weight
  grossTime     DateTime?
  tareTime      DateTime?
  // Lab quality fields
  labStatus       String?  @default("PENDING") // PENDING, PASS, FAIL
  labMoisture     Float?
  labStarch       Float?
  labDamaged      Float?
  labForeignMatter Float?
  labRemarks      String?
  labTestedAt     DateTime?
  labTestedBy     String?
  // Ethanol outbound fields
  cloudGatePassId String?  // DispatchTruck UUID on cloud ERP (set at gate entry for ethanol)
  // DDGS outbound: cloud DDGSContract UUID picked at gate entry (operator selects from
  // contract dropdown). Persisted so the cloud handler binds the truck to the EXPLICIT
  // contract instead of re-resolving by buyer name at sync time. Without this, a
  // contract edit/delete between gate entry and sync silently relinks or nulls the
  // truck. (Codex audit 2026-04-08, finding #1.)
  cloudContractId String?
  quantityBL      Float?   // Volume in Bulk Litres (ethanol flow meter)
  strength        Float?   // Alcohol strength %
  sealNo          String?  // Seal number on tanker
  // Ethanol dispatch fields (captured at gross weighment for outbound)
  rstNo           String?
  driverLicense   String?
  pesoDate        String?
  // Ship-To (outbound only, snapshot at gate entry; when null Bill-To == Ship-To)
  shipToCustomerId String?
  shipToName       String?
  shipToGstin      String?
  shipToAddress    String?
  shipToState      String?
  shipToPincode    String?
  // Camera snapshots (comma-separated relative paths)
  grossPhotos   String?  // e.g. "{id}/gross_cam1.jpg,{id}/gross_cam2.jpg"
  tarePhotos    String?
  grossVideoPaths String? // video capture WIP (columns exist in DB from uncommitted work)
  tareVideoPaths  String?
  // Company (multi-tenant: which company this truck belongs to)
  companyId     String?  // Cloud Company UUID — set at gate entry
  companyCode   String?  // "MSPIL", "SC-A" — for display
  // Status
  status        String   @default("GATE_ENTRY") // GATE_ENTRY, FIRST_DONE, COMPLETE, CANCELLED
  // Timestamps
  gateEntryAt   DateTime?
  firstWeightAt DateTime?
  secondWeightAt DateTime?
  // Cloud sync (legacy push-based: push.ts handlers → GrainTruck/GoodsReceipt/etc.)
  cloudSynced   Boolean  @default(false)
  cloudSyncedAt DateTime?
  cloudError    String?
  syncAttempts  Int      @default(0)
  // Cloud RAW mirror sync (row-for-row copy to cloud "Weighment" table)
  // NULL = never pushed to mirror. Set to NOW() after each successful push.
  // Query: "mirrorPushedAt IS NULL OR mirrorPushedAt < updatedAt" picks up
  // new + edited rows without the in-memory cursor / 7-day lookback that
  // caused blind spots in the old approach.
  mirrorPushedAt DateTime?
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pcId])
  @@index([ticketNo])
  @@index([status])
  @@index([cloudSynced])
  @@index([mirrorPushedAt])
  @@index([vehicleNo])
  @@index([createdAt])
  @@index([labStatus])
}

// --- COUNTERS ---
// Auto-increment ticket numbers, shift counters, etc.
model Counter {
  id    String @id        // e.g. "ticket_no"
  value Int    @default(0)
}

// --- GATE ENTRIES ---
// Vehicle entry/exit tracking
model GateEntry {
  id           String   @id @default(uuid())
  vehicleNo    String
  direction    String   // INBOUND, OUTBOUND
  purpose      String?  // RAW_MATERIAL, FUEL, DDGS_DISPATCH, CHEMICAL, VISITOR, OTHER
  driverName   String?
  driverPhone  String?
  personCount  Int      @default(1)
  // Linked records
  weighmentId  String?
  poNumber     String?
  supplierName String?
  // Timing
  entryTime    DateTime @default(now())
  exitTime     DateTime?
  // Status
  status       String   @default("INSIDE") // INSIDE, EXITED
  // Cloud sync
  cloudSynced  Boolean  @default(false)
  cloudSyncedAt DateTime?
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vehicleNo])
  @@index([status])
  @@index([direction])
  @@index([createdAt])
  @@index([cloudSynced])
}

// --- PC HEARTBEATS ---
// Health monitoring for all factory PCs
model PcHeartbeat {
  id            String   @id @default(uuid())
  pcId          String
  pcName        String
  pcRole        String   @default("WEIGHBRIDGE") // WEIGHBRIDGE, GATE_ENTRY, FUEL_YARD, LAB, CAMERA
  tailscaleIp   String?
  lanIp         String?
  // Health
  cpuPercent    Float?
  memoryPercent Float?
  diskFreeGb    Float?
  uptime        String?
  // Service info
  serviceVersion String?
  serialProtocol String?
  dbSizeKb       Int?
  queueDepth     Int?
  lastSyncTime   DateTime?
  // Timestamps
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([pcId])
  @@index([lastSeen])
}

// --- CACHED MASTER DATA ---
// Pulled from cloud ERP, used by all PCs
model CachedSupplier {
  id        String   @id
  name      String
  gstin     String?
  phone     String?
  companyId String?  // Cloud Company UUID
  updatedAt DateTime @default(now())

  @@index([companyId])
}

model CachedMaterial {
  id        String   @id
  name      String
  unit      String?
  category  String?
  updatedAt DateTime @default(now())
}

model CachedPurchaseOrder {
  id             String   @id
  poNumber       String
  supplierName   String
  supplierId     String
  materialName   String
  materialId     String
  quantity       Float
  receivedQty    Float    @default(0)
  rate           Float    @default(0)
  unit           String
  status         String
  companyId      String?  // Cloud Company UUID
  companyCode    String?  // "MSPIL", "MAEL" — for display
  updatedAt      DateTime @default(now())

  @@index([status])
  @@index([supplierId])
  @@index([companyId])
}

model CachedCustomer {
  id        String   @id
  name      String
  gstin     String?
  updatedAt DateTime @default(now())
}

// --- SYNC QUEUE ---
// Dead letter queue for failed cloud syncs
model SyncQueue {
  id          String   @id @default(uuid())
  entityType  String   // WEIGHMENT, GATE_ENTRY
  entityId    String
  payload     String   // JSON payload
  attempts    Int      @default(0)
  lastError   String?
  status      String   @default("PENDING") // PENDING, FAILED, DEAD
  nextRetry   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([nextRetry])
  @@index([entityType])
}

// --- BUSINESS RULES ---
// Configurable rules enforced during weighbridge operations
// Managed via admin Settings UI on factory server
model BusinessRule {
  id          String   @id @default(uuid())
  key         String   @unique  // e.g. "MIN_WEIGHT_INTERVAL_MINUTES"
  label       String             // "Minimum time between two weights"
  description String?            // Help text for admin UI
  value       String             // Always stored as string, parsed by valueType
  valueType   String             // "number", "boolean", "string", "select"
  category    String   @default("WEIGHMENT")  // WEIGHMENT, GATE_ENTRY, GENERAL
  enabled     Boolean  @default(true)
  minValue    String?            // For number type: min allowed in UI
  maxValue    String?            // For number type: max allowed in UI
  options     String?            // For select type: JSON array of options
  updatedAt   DateTime @updatedAt
  updatedBy   String?            // Who last changed it

  @@index([category])
  @@index([enabled])
}

// --- WASH TOTALIZER ---
// Factory-side backup totalizer for wash flow (MG_140101).
// Accumulates PRV_HR readings independently of cloud OPC DB.
// Gap-proof: even if cloud OPC bridge is down, factory can compute wash delta.
model WashTotalizer {
  id              String   @id @default(uuid())
  hour            DateTime @unique // Hour bucket (truncated to hour)
  prvHrValue      Float    // PRV_HR reading for this hour (KL)
  accumulatedKL   Float    // Running total since first reading
  source          String   @default("OPC_BRIDGE") // OPC_BRIDGE, MANUAL
  createdAt       DateTime @default(now())

  @@index([hour])
}

// --- WEIGHMENT CORRECTION LOG ---
// Local mirror of cloud-initiated corrections. Cloud is the master for
// admin edits (see .claude/skills/weighment-corrections.md). Factory receives
// corrections via POST /api/weighbridge/correction and records each applied
// change here. Primary key is the cloud-assigned correctionId, so duplicate
// deliveries (cloud retries) are idempotent.
model WeighmentCorrectionLog {
  correctionId  String   @id // UUID from cloud WeighmentCorrection.id
  weighmentId   String   // local Weighment.id (resolved from factoryLocalId)
  ticketNo      Int?
  vehicleNo     String?
  fieldName     String   // "materialName" | "supplier" | "cancel" | ...
  oldValueJson  String?
  newValueJson  String?
  appliedAt     DateTime @default(now())

  @@index([weighmentId])
  @@index([appliedAt])
}

// --- RULE OVERRIDE LOG ---
// Audit trail when admin overrides a rule violation
model RuleOverrideLog {
  id           String   @id @default(uuid())
  ruleKey      String
  weighmentId  String
  action       String   // GROSS, TARE
  overriddenBy String   // Username or "admin"
  reason       String?  // Optional reason
  createdAt    DateTime @default(now())

  @@index([weighmentId])
  @@index([createdAt])
}

// --- WEIGHMENT AUDIT QUEUE ---
// Local-first audit log for safety-rule overrides + soft-confirms.
// syncWorker pushes rows to cloud WeighmentAuditEvent (cloud is master for
// reporting; factory keeps a copy so audit survives if cloud is unreachable).
// Idempotency key: id (UUID generated here) maps 1:1 to cloud factoryEventId.
model WeighmentAuditQueue {
  id              String   @id @default(uuid())
  eventType       String   // SCALE_NOT_ZERO_OVERRIDE | DELTA_CONFIRMED | INTERVAL_OVERRIDE | DUPLICATE_OVERRIDE
  ruleKey         String?
  weighmentId     String   // local Weighment.id
  weighmentLocalId String  // local Weighment.localId (cloud join key)
  ticketNo        Int?
  vehicleNo       String?
  pcId            String?
  action          String?  // GROSS | TARE | GATE_ENTRY
  newWeight       Float?
  prevWeight      Float?
  liveScaleWeight Float?
  thresholdKg     Float?
  message         String?
  confirmedBy     String   // factory user.name
  confirmReason   String?
  rawPayload      String?  // JSON string for forensics
  occurredAt      DateTime @default(now())
  syncedToCloud   Boolean  @default(false)
  syncedAt        DateTime?
  cloudError      String?

  @@index([syncedToCloud])
  @@index([occurredAt])
  @@index([weighmentId])
}

// ========================================================================
// BIOMETRIC — factory-led mode (added 2026-05-07)
// ------------------------------------------------------------------------
// Pattern mirrors weighbridge: pull punches from devices into the factory
// Postgres immediately, then sync to cloud in batches (every minute, but
// resilient to multi-hour outages — cloudSynced=false rows persist).
// Cloud is the source-of-truth for HR data (Employee, LaborWorker,
// BiometricDevice config). Factory-server caches it via masterDataCache.ts.
// ========================================================================

// Local mirror of cloud BiometricDevice rows that have factoryManaged=true.
// Refreshed from /api/biometric-factory/master-data every 30s. The factory
// scheduler iterates only this table — never touches the cloud directly.
model CachedBiometricDevice {
  id              String   @id // cloud BiometricDevice.id
  code            String   @unique
  name            String
  location        String?
  ip              String
  port            Int      @default(4370)
  password        Int      @default(0)
  autoPullMinutes Int      @default(0)
  autoPushMinutes Int      @default(0)
  companyId       String?
  // Local sync state — independent of the cloud's lastAutoPullAt etc.
  lastPullAt      DateTime?
  lastPushAt      DateTime?
  lastError       String?
  updatedAt       DateTime @default(now())

  @@index([code])
}

// Slim mirror of cloud Employee — just the fields needed to (a) resolve
// punch user_id → Employee, and (b) push the user list back to devices.
model CachedEmployee {
  id           String   @id // cloud Employee.id
  empCode      String?
  empNo        Int?
  firstName    String
  lastName     String?
  deviceUserId String?
  cardNumber   String?
  companyId    String?
  isActive     Boolean  @default(true)
  updatedAt    DateTime @default(now())

  @@index([deviceUserId])
  @@index([companyId])
}

// Same shape for labor.
model CachedLaborWorker {
  id           String   @id // cloud LaborWorker.id
  workerCode   String?
  workerNo     Int?
  firstName    String
  lastName     String?
  deviceUserId String?
  cardNumber   String?
  companyId    String?
  isActive     Boolean  @default(true)
  updatedAt    DateTime @default(now())

  @@index([deviceUserId])
  @@index([companyId])
}

// Each fingerprint hit on a device. cloudSynced=false means we still owe
// the cloud a copy. Identical pattern to Weighment.cloudSynced.
model AttendancePunch {
  id            String   @id @default(uuid())
  deviceCode    String   // cloud BiometricDevice.code
  deviceUserId  String   // value the device reports (string for type stability)
  punchAt       DateTime // device clock, converted UTC by the bridge
  direction     String   @default("AUTO") // IN | OUT | AUTO
  // Resolved at pull time so reports work offline
  employeeId    String?  // cloud Employee.id (cached via CachedEmployee)
  laborWorkerId String?  // cloud LaborWorker.id
  companyId     String?
  // Cloud sync
  cloudSynced   Boolean  @default(false)
  cloudSyncedAt DateTime?
  cloudError    String?
  syncAttempts  Int      @default(0)
  // Timestamps
  createdAt     DateTime @default(now())

  @@unique([deviceCode, deviceUserId, punchAt])
  @@index([cloudSynced])
  @@index([punchAt])
  @@index([deviceCode])
}

// --- PRINT QUEUE ---
// For managing printer jobs across PCs
model PrintJob {
  id         String   @id @default(uuid())
  pcId       String
  printerType String  // THERMAL, DOT_MATRIX
  template   String   // GATE_PASS, WEIGHT_SLIP, DISPATCH_SLIP
  data       String   // JSON data for template
  status     String   @default("PENDING") // PENDING, SENT, PRINTED, FAILED
  createdAt  DateTime @default(now())

  @@index([pcId, status])
  @@index([createdAt])
}
