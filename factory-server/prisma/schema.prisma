generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// FACTORY SERVER SCHEMA — Lightweight, local-first
// This is SEPARATE from the cloud ERP schema (61 models).
// Only stores what the factory floor needs locally.
// ============================================================

// --- USERS ---
model FactoryUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt hashed
  name      String
  role      String   @default("GATE_ENTRY") // ADMIN, GATE_ENTRY, WEIGHBRIDGE, FUEL_YARD, LAB
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// --- WEIGHMENTS ---
// Central weighment records — all PCs create/update via factory server API
model Weighment {
  id            String   @id @default(uuid())
  localId       String   @unique // UUID (used in QR codes)
  ticketNo      Int?     @unique // Auto-increment ticket number for slips
  pcId          String   // Which PC created gate entry
  pcName        String?
  vehicleNo     String
  direction     String   // INBOUND, OUTBOUND
  // Purchase info
  purchaseType  String?  // PO, SPOT, OUTBOUND
  poNumber      String?
  poId          String?  // Cloud PO UUID
  poLineId      String?  // Cloud PO line UUID
  supplierName  String?
  supplierId    String?
  materialName  String?
  materialId    String?
  materialCategory String?  // RAW_MATERIAL, FUEL, CHEMICAL, PACKING
  // Gate entry details
  gateEntryNo   String?
  transporter   String?
  vehicleType   String?  // Truck 14W, 10W, 6W, Tractor Trolley, Pickup
  driverName    String?
  driverPhone   String?
  operatorName  String?  // Who created gate entry
  shift         String?  // First Shift, Second Shift, Third Shift
  bags          Int?
  remarks       String?
  // Spot purchase fields
  sellerPhone   String?
  sellerVillage String?
  sellerAadhaar String?
  rate          Float?   // Per KG rate
  deductions    Float?
  deductionReason String?
  paymentMode   String?  // CASH, UPI, BANK_TRANSFER
  paymentRef    String?
  // Weights
  grossWeight   Float?
  tareWeight    Float?
  netWeight     Float?
  weightSource  String?  // SERIAL, MANUAL
  grossPcId     String?  // Which PC captured gross weight
  tarePcId      String?  // Which PC captured tare weight
  grossTime     DateTime?
  tareTime      DateTime?
  // Lab quality fields
  labStatus       String?  @default("PENDING") // PENDING, PASS, FAIL
  labMoisture     Float?
  labStarch       Float?
  labDamaged      Float?
  labForeignMatter Float?
  labRemarks      String?
  labTestedAt     DateTime?
  labTestedBy     String?
  // Ethanol outbound fields
  cloudGatePassId String?  // DispatchTruck UUID on cloud ERP (set at gate entry for ethanol)
  quantityBL      Float?   // Volume in Bulk Litres (ethanol flow meter)
  strength        Float?   // Alcohol strength %
  sealNo          String?  // Seal number on tanker
  // Camera snapshots (comma-separated relative paths)
  grossPhotos   String?  // e.g. "{id}/gross_cam1.jpg,{id}/gross_cam2.jpg"
  tarePhotos    String?
  // Status
  status        String   @default("GATE_ENTRY") // GATE_ENTRY, FIRST_DONE, COMPLETE, CANCELLED
  // Timestamps
  gateEntryAt   DateTime?
  firstWeightAt DateTime?
  secondWeightAt DateTime?
  // Cloud sync
  cloudSynced   Boolean  @default(false)
  cloudSyncedAt DateTime?
  cloudError    String?
  syncAttempts  Int      @default(0)
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pcId])
  @@index([ticketNo])
  @@index([status])
  @@index([cloudSynced])
  @@index([vehicleNo])
  @@index([createdAt])
  @@index([labStatus])
}

// --- COUNTERS ---
// Auto-increment ticket numbers, shift counters, etc.
model Counter {
  id    String @id        // e.g. "ticket_no"
  value Int    @default(0)
}

// --- GATE ENTRIES ---
// Vehicle entry/exit tracking
model GateEntry {
  id           String   @id @default(uuid())
  vehicleNo    String
  direction    String   // INBOUND, OUTBOUND
  purpose      String?  // RAW_MATERIAL, FUEL, DDGS_DISPATCH, CHEMICAL, VISITOR, OTHER
  driverName   String?
  driverPhone  String?
  personCount  Int      @default(1)
  // Linked records
  weighmentId  String?
  poNumber     String?
  supplierName String?
  // Timing
  entryTime    DateTime @default(now())
  exitTime     DateTime?
  // Status
  status       String   @default("INSIDE") // INSIDE, EXITED
  // Cloud sync
  cloudSynced  Boolean  @default(false)
  cloudSyncedAt DateTime?
  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([vehicleNo])
  @@index([status])
  @@index([direction])
  @@index([createdAt])
  @@index([cloudSynced])
}

// --- PC HEARTBEATS ---
// Health monitoring for all factory PCs
model PcHeartbeat {
  id            String   @id @default(uuid())
  pcId          String
  pcName        String
  pcRole        String   @default("WEIGHBRIDGE") // WEIGHBRIDGE, GATE_ENTRY, FUEL_YARD, LAB, CAMERA
  tailscaleIp   String?
  lanIp         String?
  // Health
  cpuPercent    Float?
  memoryPercent Float?
  diskFreeGb    Float?
  uptime        String?
  // Service info
  serviceVersion String?
  serialProtocol String?
  dbSizeKb       Int?
  queueDepth     Int?
  lastSyncTime   DateTime?
  // Timestamps
  lastSeen      DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([pcId])
  @@index([lastSeen])
}

// --- CACHED MASTER DATA ---
// Pulled from cloud ERP, used by all PCs
model CachedSupplier {
  id        String   @id
  name      String
  gstin     String?
  phone     String?
  updatedAt DateTime @default(now())
}

model CachedMaterial {
  id        String   @id
  name      String
  unit      String?
  category  String?
  updatedAt DateTime @default(now())
}

model CachedPurchaseOrder {
  id             String   @id
  poNumber       String
  supplierName   String
  supplierId     String
  materialName   String
  materialId     String
  quantity       Float
  receivedQty    Float    @default(0)
  rate           Float    @default(0)
  unit           String
  status         String
  updatedAt      DateTime @default(now())

  @@index([status])
  @@index([supplierId])
}

model CachedCustomer {
  id        String   @id
  name      String
  gstin     String?
  updatedAt DateTime @default(now())
}

// --- SYNC QUEUE ---
// Dead letter queue for failed cloud syncs
model SyncQueue {
  id          String   @id @default(uuid())
  entityType  String   // WEIGHMENT, GATE_ENTRY
  entityId    String
  payload     String   // JSON payload
  attempts    Int      @default(0)
  lastError   String?
  status      String   @default("PENDING") // PENDING, FAILED, DEAD
  nextRetry   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([nextRetry])
  @@index([entityType])
}

// --- PRINT QUEUE ---
// For managing printer jobs across PCs
model PrintJob {
  id         String   @id @default(uuid())
  pcId       String
  printerType String  // THERMAL, DOT_MATRIX
  template   String   // GATE_PASS, WEIGHT_SLIP, DISPATCH_SLIP
  data       String   // JSON data for template
  status     String   @default("PENDING") // PENDING, SENT, PRINTED, FAILED
  createdAt  DateTime @default(now())

  @@index([pcId, status])
  @@index([createdAt])
}
