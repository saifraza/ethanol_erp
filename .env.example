DATABASE_URL="postgresql://user:password@localhost:5432/distillery_erp"
JWT_SECRET="change-me-in-production"
PORT=5000

# E-Way Bill & E-Invoice Configuration (Saral GSP)
EWAY_BILL_MODE=sandbox
EWAY_SARAL_URL=https://saralgsp.com
EWAY_NIC_CLIENT_ID=your_client_id
EWAY_NIC_CLIENT_SECRET=your_client_secret
EWAY_GSTIN=your_gstin_here

# E-Way Bill credentials (standalone e-way bill)
EWAY_EWB_USERNAME=your_ewb_username
EWAY_EWB_PASSWORD=your_ewb_password

# E-Invoice credentials (IRN generation)
EWAY_EINV_USERNAME=your_einv_username
EWAY_EINV_PASSWORD=your_einv_password

# Legacy NIC Direct Mode (if needed)
EWAY_NIC_USERNAME=your_nic_username
EWAY_NIC_PASSWORD=your_nic_password
EWAY_NIC_URL=https://gsp.adaequare.com
EWAY_NIC_PUBLIC_KEY=base64_encoded_RSA_public_key
