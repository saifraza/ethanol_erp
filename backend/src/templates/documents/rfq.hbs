<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Request for Quotation</title>{{> base-styles}}</head>
<body>
<div class="page">
  {{> letterhead}}
  <div class="doc-title">REQUEST FOR QUOTATION (RFQ)</div>

  <div class="details-grid">
    <div class="detail-row"><span class="detail-label">RFQ No</span><span class="detail-value bold">RFQ-{{reqNo}}-{{refSuffix}}</span></div>
    <div class="detail-row"><span class="detail-label">Date</span><span class="detail-value">{{formatDate createdAt}}</span></div>
    <div class="detail-row"><span class="detail-label">Valid Until</span><span class="detail-value">{{formatDate validUntil}}</span></div>
    {{#if department}}<div class="detail-row"><span class="detail-label">Department</span><span class="detail-value">{{department}}</span></div>{{/if}}
  </div>

  {{#if vendor}}
  <div class="box" style="margin-top: 8px;">
    <div class="box-header">To</div>
    <div class="box-body">
      <div style="font-weight: 700; font-size: 11px;">{{vendor.name}}</div>
      {{#if vendor.address}}<div style="font-size: 9px; color: #444;">{{vendor.address}}</div>{{/if}}
      <div style="font-size: 9px; color: #444; margin-top: 2px;">
        {{#if vendor.contactPerson}}Kind Attn: {{vendor.contactPerson}}{{#if vendor.email}} · {{/if}}{{/if}}
        {{#if vendor.email}}{{vendor.email}}{{/if}}
        {{#if vendor.phone}} · {{vendor.phone}}{{/if}}
        {{#if vendor.gstin}} · GSTIN: {{vendor.gstin}}{{/if}}
      </div>
    </div>
  </div>
  {{/if}}

  <div class="box" style="margin-top: 8px;">
    <div class="box-header">Items Requested</div>
    <div class="box-body" style="padding: 0;">
      <table class="items-table" style="table-layout: fixed;">
        <colgroup>
          <col style="width: 30px;">
          <col>
          <col style="width: 70px;">
          <col style="width: 55px;">
          <col style="width: 180px;">
        </colgroup>
        <thead>
          <tr>
            <th style="text-align: center;">#</th>
            <th style="text-align: left;">Item / Specification</th>
            <th style="text-align: right;">Qty</th>
            <th style="text-align: center;">Unit</th>
            <th style="text-align: left;">Remarks</th>
          </tr>
        </thead>
        <tbody>
          {{#each lines}}
          <tr>
            <td style="text-align: center; padding: 4px 5px;">{{lineNo}}</td>
            <td style="padding: 4px 6px;"><b>{{itemName}}</b></td>
            <td style="text-align: right; padding: 4px 5px; font-family: 'Courier New', monospace;">{{formatNum quantity}}</td>
            <td style="text-align: center; padding: 4px 5px;">{{unit}}</td>
            <td style="padding: 4px 6px; color: #555;">{{remarks}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  </div>

  {{#if justification}}<div class="remarks-section"><div class="label">Purpose:</div><div class="text">{{justification}}</div></div>{{/if}}

  {{#if specialRemarks}}
  <div class="box" style="margin-top: 8px; background: #fffbea; border-color: #fde68a;">
    <div class="box-header" style="background: #fde68a; color: #78350f;">Additional Notes from MSPIL</div>
    <div class="box-body">
      <div style="font-size: 9px; color: #78350f; line-height: 1.5; white-space: pre-wrap;">{{specialRemarks}}</div>
    </div>
  </div>
  {{/if}}

  <div class="box" style="margin-top: 10px;">
    <div class="box-header">Please Include in Your Quote</div>
    <div class="box-body">
      <div style="font-size: 8px; color: #444; line-height: 1.8;">
        &bull; Unit rate (in INR, exclusive of GST) for each item<br>
        &bull; Applicable GST % and HSN code per item<br>
        &bull; Delivery time in days from receipt of PO<br>
        &bull; Packing / freight terms (free delivery, ex-works, FOR, etc.)<br>
        &bull; Payment terms (advance / credit days)<br>
        &bull; Quote validity period<br>
        &bull; Any brand / make / origin details
      </div>
    </div>
  </div>

  <div class="box" style="margin-top: 8px; background: #fff7ed; border-color: #fed7aa;">
    <div class="box-body" style="padding: 6px 10px;">
      <div style="font-size: 9px; color: #9a3412; line-height: 1.5;">
        <b>IMPORTANT:</b> Please <b>REPLY ON THIS SAME EMAIL</b> so our system can automatically match your quote to this RFQ and extract the rates. Do not start a new email thread.
      </div>
    </div>
  </div>

  {{> terms-footer}}
  {{> signatures sigCount=2 sigLabels=(list "For MSPIL" "Supplier") sigNames=(list preparedBy "")}}

  <div class="footer-area">
    {{#if qrDataUrl}}<div class="qr-block"><img src="{{qrDataUrl}}" alt="QR"><div class="qr-text">Scan to verify this RFQ</div></div>{{/if}}
    <div class="footer-text">{{footer}}</div>
  </div>
</div>
</body>
</html>
