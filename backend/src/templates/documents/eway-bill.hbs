<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>e-Way Bill</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family: Arial, Helvetica, sans-serif; font-size:9px; color:#222; }
  .page { width:210mm; min-height:297mm; padding:14px 18px; }
  h1 { font-size:22px; font-weight:700; margin-bottom:12px; }
  h3 { font-size:10px; font-weight:700; margin:10px 0 4px; border-bottom:1px solid #333; padding-bottom:2px; }
  .tbl { width:100%; border-collapse:collapse; font-size:8.5px; margin-bottom:2px; }
  .tbl td, .tbl th { border:1px solid #555; padding:4px 6px; vertical-align:top; }
  .tbl th { background:#eee; font-weight:600; text-align:center; font-size:8px; }
  .lbl { color:#555; font-size:7.5px; }
  .val { font-weight:600; font-size:9px; }
  .mono { font-family: monospace; }
  .right { text-align:right; }
  .center { text-align:center; }
  .addr-box { border:1px solid #555; padding:6px 8px; font-size:8.5px; line-height:1.5; min-height:80px; }
  .addr-box .name { font-weight:700; font-size:9.5px; }
  .addr-box .gstin { font-weight:600; }
  .addr-box .dispatch { font-size:7.5px; color:#555; font-style:italic; margin-top:4px; }
  .barcode { text-align:center; margin-top:12px; font-family:monospace; font-size:14px; letter-spacing:3px; font-weight:700; }
  .qr-top { position:absolute; top:14px; right:18px; }
  .qr-top img { width:70px; height:70px; }
</style>
</head>
<body>
<div class="page" style="position:relative;">

  <h1>e-Way Bill</h1>

  <!-- 1. E-WAY BILL Details -->
  <h3>1. E-WAY BILL Details</h3>
  <table class="tbl">
    <tr>
      <td style="width:33%;"><span class="lbl">eWay Bill No:</span><br><span class="val mono">{{ewbNo}}</span></td>
      <td style="width:34%;"><span class="lbl">Generated Date:</span><br><span class="val">{{formatDate ewbDate}}</span></td>
      <td style="width:33%;"><span class="lbl">Generated By:</span><br><span class="val mono">{{sellerGstin}}</span><br><span class="lbl">Valid Upto:</span> <span class="val">{{formatDate ewbValidTill}}</span></td>
    </tr>
    <tr>
      <td><span class="lbl">Mode:</span> <span class="val">Road</span></td>
      <td><span class="lbl">Approx Distance:</span> <span class="val">{{distanceKm}}km</span></td>
      <td></td>
    </tr>
    <tr>
      <td><span class="lbl">Type:</span> <span class="val">Outward - Supply</span></td>
      <td><span class="lbl">Document Details:</span> <span class="val">Tax Invoice - INV-{{invoiceNo}} - {{formatDate invoiceDate}}</span></td>
      <td><span class="lbl">Transaction type:</span> <span class="val">Regular</span></td>
    </tr>
  </table>

  <!-- 2. Address Details -->
  <h3>2. Address Details</h3>
  <div style="display:flex; gap:8px;">
    <div style="flex:1;">
      <div style="font-size:8px; font-weight:600; margin-bottom:3px;">From</div>
      <div class="addr-box">
        <div class="gstin">GSTIN : {{sellerGstin}}</div>
        <div class="name">{{sellerName}}</div>
        <div>{{sellerState}}</div>
        <div class="dispatch">:: Dispatch From ::</div>
        <div>{{sellerAddress}}</div>
      </div>
    </div>
    <div style="flex:1;">
      <div style="font-size:8px; font-weight:600; margin-bottom:3px;">To</div>
      <div class="addr-box">
        <div class="gstin">GSTIN : {{buyerGstin}}</div>
        <div class="name">{{buyerName}}</div>
        <div>{{buyerState}}</div>
        <div class="dispatch">:: Ship To ::</div>
        <div>{{buyerAddress}}</div>
        {{#if buyerPincode}}<div>{{buyerState}}-{{buyerPincode}}</div>{{/if}}
      </div>
    </div>
  </div>

  <!-- 3. Goods Details -->
  <h3>3. Goods Details</h3>
  <table class="tbl">
    <thead>
      <tr>
        <th style="width:60px;">HSN<br>Code</th>
        <th>Product Name &amp; Desc.</th>
        <th style="width:70px;">Quantity</th>
        <th style="width:80px;">Taxable<br>Amount Rs.</th>
        <th style="width:120px;">Tax Rate (C+S+I+Cess+Cess<br>Non.Advol)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="center mono">{{hsnCode}}</td>
        <td>{{productName}}</td>
        <td class="right mono">{{formatNum quantity}}<br>{{unit}}</td>
        <td class="right mono">{{formatNum amount}}</td>
        <td class="center mono">
          {{#if (eq supplyType 'INTRA_STATE')}}{{cgstPercent}}+{{sgstPercent}}+NE+0.000+0.00{{else}}NE+NE+{{igstPercent}}.000+0.000+0.00{{/if}}
        </td>
      </tr>
    </tbody>
  </table>

  <table class="tbl" style="margin-top:-1px;">
    <tr>
      <td><span class="lbl">Tot. Tax'ble Amt</span><br><span class="mono">{{formatNum amount}}</span></td>
      <td><span class="lbl">CGST Amt</span><br><span class="mono">{{formatNum cgstAmount}}</span></td>
      <td><span class="lbl">SGST Amt</span><br><span class="mono">{{formatNum sgstAmount}}</span></td>
      <td><span class="lbl">IGST Amt</span><br><span class="mono">{{formatNum igstAmount}}</span></td>
      <td><span class="lbl">CESS Amt</span><br><span class="mono">0.00</span></td>
      <td><span class="lbl">CESS Non.Advol Amt</span><br><span class="mono">0.00</span></td>
      <td><span class="lbl">Other Amt</span><br><span class="mono">0.00</span></td>
      <td><span class="lbl">Total Inv.Amt</span><br><span class="mono val">{{formatNum totalAmount}}</span></td>
    </tr>
  </table>

  <!-- 4. Transportation Details -->
  <h3>4. Transportation Details</h3>
  <table class="tbl">
    <tr>
      <td><span class="lbl">Transporter ID &amp; Name :</span> <span class="val">{{#if transporterName}}{{transporterName}}{{else}}OWN TRANSPORT{{/if}}</span></td>
      <td><span class="lbl">Transporter Doc. No &amp; Date :</span> <span class="val">&amp; {{formatDate invoiceDate}}</span></td>
    </tr>
  </table>

  <!-- 5. Vehicle Details -->
  <h3>5. Vehicle Details</h3>
  <table class="tbl">
    <thead>
      <tr>
        <th>Mode</th>
        <th>Vehicle / Trans<br>Doc No &amp; Dt.</th>
        <th>From</th>
        <th>Entered Date</th>
        <th>Entered By</th>
        <th>CEWB No.<br>(If any)</th>
        <th>Multi Veh.Info<br>(If any)</th>
        <th>Portal</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Road</td>
        <td class="val">{{vehicleNo}}</td>
        <td>{{#if destination}}{{destination}}{{else}}Narsinghpur{{/if}}</td>
        <td>{{formatDate ewbDate}}</td>
        <td class="mono" style="font-size:7px;">{{sellerGstin}}</td>
        <td class="center">-</td>
        <td class="center">-</td>
        <td class="center">1</td>
      </tr>
    </tbody>
  </table>

  <!-- Barcode -->
  <div class="barcode">{{ewbNo}}</div>

</div>
</body>
</html>
