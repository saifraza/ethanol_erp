<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>e-Way Bill</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  @page { size: A4; margin: 10mm; }
  body { font-family: Arial, Helvetica, sans-serif; font-size: 9px; color: #222; line-height: 1.4; }
  .page { width: 210mm; padding: 16px 20px; }

  /* Section headers — matches government portal style */
  .sec-hdr { background: #e8e8e8; border: 1px solid #333; padding: 4px 8px; font-size: 10px; font-weight: 700; margin-top: 10px; }
  .sec-hdr:first-of-type { margin-top: 0; }

  /* Tables */
  .t { width: 100%; border-collapse: collapse; }
  .t td, .t th { border: 1px solid #333; padding: 4px 7px; vertical-align: top; font-size: 8.5px; }
  .t th { background: #f0f0f0; font-weight: 600; text-align: center; font-size: 8px; text-transform: uppercase; }
  .t .lbl { display: block; font-size: 7px; color: #666; text-transform: uppercase; letter-spacing: 0.3px; margin-bottom: 1px; }
  .t .val { font-weight: 700; font-size: 9px; }
  .t .mono { font-family: 'Courier New', monospace; }
  .t .r { text-align: right; }
  .t .c { text-align: center; }

  /* Address blocks */
  .addr-grid { display: flex; gap: 0; }
  .addr-grid .addr-col { flex: 1; border: 1px solid #333; padding: 8px 10px; font-size: 8.5px; line-height: 1.5; }
  .addr-grid .addr-col + .addr-col { border-left: none; }
  .addr-col .addr-type { font-size: 7px; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
  .addr-col .gstin-line { font-weight: 700; font-size: 9px; margin-bottom: 2px; }
  .addr-col .name-line { font-weight: 700; font-size: 10px; margin-bottom: 2px; }
  .addr-col .dispatch-line { font-size: 7.5px; color: #555; font-style: italic; margin-top: 6px; padding-top: 4px; border-top: 1px dashed #ccc; }

  /* Title bar */
  .title-bar { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
  .title-bar h1 { font-size: 20px; font-weight: 700; }
  .title-bar .qr-box { text-align: center; }
  .title-bar .qr-box img { width: 85px; height: 85px; }

  /* Bottom barcode area */
  .barcode-area { text-align: center; margin-top: 14px; padding: 10px; border: 1px solid #333; }
  .barcode-area .ewb-num { font-family: 'Courier New', monospace; font-size: 16px; font-weight: 700; letter-spacing: 4px; }
  .barcode-area .ewb-label { font-size: 7px; color: #666; text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }
</style>
</head>
<body>
<div class="page">

  <!-- Title + QR -->
  <div class="title-bar">
    <div>
      <h1>e-Way Bill</h1>
      <div style="font-size: 8px; color: #666; margin-top: 2px;">Generated from MSPIL ERP</div>
    </div>
    {{#if ewbQrDataUrl}}
    <div class="qr-box">
      <img src="{{ewbQrDataUrl}}" alt="EWB QR">
      <div style="font-size: 6.5px; color: #888;">Scan to verify</div>
    </div>
    {{/if}}
  </div>

  <!-- 1. E-WAY BILL Details -->
  <div class="sec-hdr">1. e-Way Bill Details</div>
  <table class="t">
    <tr>
      <td style="width:35%;">
        <span class="lbl">e-Way Bill No</span>
        <span class="val mono" style="font-size:12px;">{{ewbNo}}</span>
      </td>
      <td style="width:30%;">
        <span class="lbl">Generated Date</span>
        <span class="val">{{formatDate ewbDate}}</span>
      </td>
      <td style="width:35%;">
        <span class="lbl">Valid Upto</span>
        <span class="val">{{formatDate ewbValidTill}}</span>
      </td>
    </tr>
    <tr>
      <td>
        <span class="lbl">Generated By</span>
        <span class="val mono">{{sellerGstin}}</span>
      </td>
      <td>
        <span class="lbl">Mode</span>
        <span class="val">Road</span>
      </td>
      <td>
        <span class="lbl">Approx Distance</span>
        <span class="val">{{distanceKm}} Km</span>
      </td>
    </tr>
    <tr>
      <td>
        <span class="lbl">Type</span>
        <span class="val">Outward - Supply</span>
      </td>
      <td>
        <span class="lbl">Document Details</span>
        <span class="val">Tax Invoice</span><br>
        <span class="mono">{{invoiceNo}}</span> dt. <span>{{formatDate invoiceDate}}</span>
        {{#if challanNo}}<br><span class="lbl" style="margin-top:3px;">Challan No</span><span class="mono">{{challanNo}}</span>{{/if}}
      </td>
      <td>
        <span class="lbl">Transaction Type</span>
        <span class="val">Regular</span>
      </td>
    </tr>
  </table>

  <!-- 2. Address Details -->
  <div class="sec-hdr">2. Address Details</div>
  <div class="addr-grid">
    <div class="addr-col">
      <div class="addr-type">From</div>
      <div class="gstin-line">GSTIN: {{sellerGstin}}</div>
      <div class="name-line">{{sellerName}}</div>
      <div>{{sellerAddress}}</div>
      <div>{{sellerState}}</div>
      <div class="dispatch-line">Dispatch From: {{sellerAddress}}</div>
    </div>
    <div class="addr-col">
      <div class="addr-type">To</div>
      <div class="gstin-line">GSTIN: {{buyerGstin}}</div>
      <div class="name-line">{{buyerName}}</div>
      <div>{{buyerAddress}}</div>
      <div>{{buyerState}}{{#if buyerPincode}} - {{buyerPincode}}{{/if}}</div>
      <div class="dispatch-line">Ship To: {{buyerAddress}}, {{buyerState}}</div>
    </div>
  </div>

  <!-- 3. Goods Details -->
  <div class="sec-hdr">3. Goods Details</div>
  <table class="t">
    <thead>
      <tr>
        <th style="width:65px;">HSN Code</th>
        <th>Product Name &amp; Description</th>
        <th style="width:70px;">Quantity</th>
        <th style="width:85px;">Taxable Amount (Rs)</th>
        <th style="width:130px;">Tax Rate<br>(CGST+SGST+IGST+Cess)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="c mono">{{hsnCode}}</td>
        <td><span class="val">{{productName}}</span></td>
        <td class="r mono">{{formatNum quantity}} {{unit}}</td>
        <td class="r mono">{{formatNum amount}}</td>
        <td class="c mono" style="font-size:8px;">
          {{#if (eq supplyType 'INTRA_STATE')}}{{cgstPercent}}% + {{sgstPercent}}% + 0 + 0{{else}}0 + 0 + {{igstPercent}}% + 0{{/if}}
        </td>
      </tr>
    </tbody>
  </table>

  <!-- Tax Summary -->
  <table class="t" style="margin-top:-1px;">
    <tr>
      <td style="width:12.5%;">
        <span class="lbl">Taxable Amt</span>
        <span class="mono val">{{formatNum amount}}</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">CGST Amt</span>
        <span class="mono">{{formatNum cgstAmount}}</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">SGST Amt</span>
        <span class="mono">{{formatNum sgstAmount}}</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">IGST Amt</span>
        <span class="mono">{{formatNum igstAmount}}</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">Cess Amt</span>
        <span class="mono">0.00</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">Cess Non-Advol</span>
        <span class="mono">0.00</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">Other Amt</span>
        <span class="mono">0.00</span>
      </td>
      <td style="width:12.5%;">
        <span class="lbl">Total Inv Amt</span>
        <span class="mono val" style="font-size:10px;">{{formatNum totalAmount}}</span>
      </td>
    </tr>
  </table>

  <!-- 4. Transportation Details -->
  <div class="sec-hdr">4. Transportation Details</div>
  <table class="t">
    <tr>
      <td style="width:50%;">
        <span class="lbl">Transporter ID &amp; Name</span>
        <span class="val">{{transporterName}}</span>
      </td>
      <td style="width:50%;">
        <span class="lbl">Transporter Doc No. &amp; Date</span>
        <span class="val">INV-{{invoiceNo}}</span> &nbsp; {{formatDate invoiceDate}}
      </td>
    </tr>
  </table>

  <!-- 5. Vehicle Details -->
  <div class="sec-hdr">5. Vehicle Details</div>
  <table class="t">
    <thead>
      <tr>
        <th>Mode</th>
        <th>Vehicle / Trans Doc No &amp; Dt.</th>
        <th>From</th>
        <th>Entered Date</th>
        <th>Entered By</th>
        <th>CEWB No.</th>
        <th>Multi Veh. Info</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="c">Road</td>
        <td class="val c">{{vehicleNo}}</td>
        <td class="c">{{#if destination}}{{destination}}{{else}}Narsinghpur{{/if}}</td>
        <td class="c">{{formatDate ewbDate}}</td>
        <td class="c mono" style="font-size:7px;">{{sellerGstin}}</td>
        <td class="c">-</td>
        <td class="c">-</td>
      </tr>
    </tbody>
  </table>

  <!-- Barcode / EWB Number -->
  <div class="barcode-area">
    {{#if ewbQrDataUrl}}<img src="{{ewbQrDataUrl}}" alt="QR" style="width:90px; height:90px; margin-bottom:4px;"><br>{{/if}}
    <div class="ewb-num">{{ewbNo}}</div>
    <div class="ewb-label">e-Way Bill Number</div>
  </div>

</div>
</body>
</html>
