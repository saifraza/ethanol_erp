<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Purchase Order</title>{{> base-styles}}</head>
<body>
<div class="page">
  {{> letterhead}}
  <div class="doc-title">PURCHASE ORDER</div>

  <div class="details-grid">
    <div class="detail-row"><span class="detail-label">PO Number</span><span class="detail-value bold">{{padPO poNo}}</span></div>
    <div class="detail-row"><span class="detail-label">PO Date</span><span class="detail-value">{{formatDate poDate}}</span></div>
    <div class="detail-row"><span class="detail-label">Delivery Date</span><span class="detail-value">{{formatDate deliveryDate}}</span></div>
    <div class="detail-row"><span class="detail-label">Supply Type</span><span class="detail-value">{{#if (eq supplyType 'INTER_STATE')}}Inter State{{else}}Intra State{{/if}}</span></div>
    {{#if placeOfSupply}}<div class="detail-row"><span class="detail-label">Place of Supply</span><span class="detail-value">{{placeOfSupply}}</span></div>{{/if}}
    {{#if creditDays}}<div class="detail-row"><span class="detail-label">Credit Days</span><span class="detail-value">{{creditDays}}</span></div>{{/if}}
  </div>

  <div class="boxes">
    <div class="box">
      <div class="box-header">Vendor / Supplier</div>
      <div class="box-body">
        <div class="name">{{vendor.name}}</div>
        {{#if vendor.tradeName}}<div class="trade">{{vendor.tradeName}}</div>{{/if}}
        {{#if vendor.address}}<div class="line">{{vendor.address}}</div>{{/if}}
        <div class="line">{{join (list vendor.city vendor.state vendor.pincode) ", "}}</div>
        {{#if vendor.gstin}}<div class="gstin">GSTIN: {{vendor.gstin}}</div>{{/if}}
      </div>
    </div>
    <div class="box">
      <div class="box-header">Delivery To</div>
      <div class="box-body">
        <div class="line">{{default deliveryAddress "Village Bachai, Tehsil Gadarwara, District Narsinghpur, Madhya Pradesh - 487551"}}</div>
        {{#if paymentTerms}}<div class="meta-row mt-4"><span class="meta-label">Payment:</span><span class="meta-val">{{paymentTerms}}</span></div>{{/if}}
        {{#if transportMode}}<div class="meta-row"><span class="meta-label">Transport:</span><span class="meta-val">{{transportMode}}</span></div>{{/if}}
      </div>
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th style="width:25px">#</th>
        <th class="left">Description</th>
        <th style="width:50px">HSN</th>
        <th style="width:40px">Qty</th>
        <th style="width:35px">Unit</th>
        <th class="right" style="width:65px">Rate (Rs.)</th>
        <th style="width:35px">GST%</th>
        <th class="right" style="width:80px">Taxable (Rs.)</th>
        <th class="right" style="width:80px">Total (Rs.)</th>
      </tr>
    </thead>
    <tbody>
      {{#each lines}}
      <tr>
        <td class="center">{{inc @index}}</td>
        <td>{{description}}</td>
        <td class="center">{{hsnCode}}</td>
        <td class="center">{{formatNum quantity}}</td>
        <td class="center">{{unit}}</td>
        <td class="right">{{formatNum rate}}</td>
        <td class="center">{{gstPercent}}%</td>
        <td class="right">{{formatNum taxableAmount}}</td>
        <td class="right">{{formatNum lineTotal}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="totals-section">
    <div class="totals-box">
      <div class="total-row"><span class="label">Subtotal</span><span class="value">{{formatINR subtotal}}</span></div>
      <div class="total-row"><span class="label">GST</span><span class="value">{{formatINR totalGst}}</span></div>
      {{#if freightCharge}}<div class="total-row"><span class="label">Freight</span><span class="value">{{formatINR freightCharge}}</span></div>{{/if}}
      {{#if otherCharges}}<div class="total-row"><span class="label">Other Charges</span><span class="value">{{formatINR otherCharges}}</span></div>{{/if}}
      {{#if roundOff}}<div class="total-row"><span class="label">Round Off</span><span class="value">{{formatINR roundOff}}</span></div>{{/if}}
      <div class="total-row grand"><span class="label">GRAND TOTAL</span><span class="value">{{formatINR grandTotal}}</span></div>
    </div>
  </div>

  <div class="amount-words">
    <div class="label">Amount in Words:</div>
    <div class="text">{{numberToWords grandTotal}}</div>
  </div>

  {{#if remarks}}
  <div class="remarks-section"><div class="label">Remarks:</div><div class="text">{{remarks}}</div></div>
  {{/if}}

  {{> terms-footer}}
  {{> signatures sigCount=3 sigLabels=(list "Prepared By" "Approved By" "Authorized Signatory") sigNames=(list preparedBy approvedBy authorizedSignatory)}}

  <div class="footer-area">
    {{#if qrDataUrl}}<div class="qr-block"><img src="{{qrDataUrl}}" alt="QR"><div class="qr-text">Scan to verify this document</div></div>{{/if}}
    <div class="footer-text">{{footer}}</div>
  </div>
</div>
</body>
</html>
