<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Payslip — {{employeeName}}</title>{{> base-styles}}
<style>
  .ps-page { padding: 20px 24px; font-family: Arial, sans-serif; font-size: 9px; color: #333; }
  .ps-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 2px solid #1a56db; padding-bottom: 10px; margin-bottom: 12px; }
  .ps-company { font-size: 12px; font-weight: 700; color: #1a56db; }
  .ps-company-sub { font-size: 8px; color: #666; margin-top: 2px; }
  .ps-title { font-size: 11px; font-weight: 700; text-align: right; color: #1a56db; }
  .ps-period { font-size: 9px; color: #666; text-align: right; }
  .ps-info { display: flex; gap: 20px; margin-bottom: 14px; }
  .ps-info-block { flex: 1; }
  .ps-info-row { display: flex; margin-bottom: 3px; }
  .ps-info-label { width: 110px; font-size: 8px; color: #888; }
  .ps-info-val { font-weight: 600; font-size: 8.5px; }
  .ps-table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
  .ps-table th { background: #f0f4ff; font-size: 8px; font-weight: 700; text-align: left; padding: 5px 8px; border-bottom: 1px solid #ccc; }
  .ps-table td { padding: 4px 8px; font-size: 8.5px; border-bottom: 1px solid #eee; }
  .ps-table .right { text-align: right; font-family: monospace; }
  .ps-table .section-header { background: #f8fafc; font-weight: 600; font-size: 8px; color: #555; text-transform: uppercase; letter-spacing: 0.5px; }
  .ps-summary { display: flex; justify-content: space-between; margin-top: 14px; border-top: 2px solid #1a56db; padding-top: 10px; }
  .ps-net { font-size: 14px; font-weight: 700; color: #1a56db; }
  .ps-net-words { font-size: 8.5px; color: #666; font-style: italic; margin-top: 3px; }
  .ps-footer { margin-top: 30px; display: flex; justify-content: space-between; font-size: 8px; color: #888; border-top: 1px solid #ddd; padding-top: 8px; }
  .ps-employer-section { margin-top: 12px; }
  .ps-confidential { font-size: 7px; color: #bbb; text-align: center; margin-top: 20px; }
</style>
</head>
<body>
<div class="ps-page">

  <!-- Header -->
  <div class="ps-header">
    <div>
      <div class="ps-company">MAHAKAUSHAL SUGAR & POWER INDUSTRIES LTD</div>
      <div class="ps-company-sub">Village Sarai, Narsinghpur, Madhya Pradesh 487001</div>
      <div class="ps-company-sub">CIN: L15421MP2001PLC014641 | PAN: AADCM4898F</div>
    </div>
    <div>
      <div class="ps-title">PAYSLIP</div>
      <div class="ps-period">{{monthName}} {{year}}</div>
    </div>
  </div>

  <!-- Employee Info -->
  <div class="ps-info">
    <div class="ps-info-block">
      <div class="ps-info-row"><span class="ps-info-label">Employee Code</span><span class="ps-info-val">{{empCode}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">Employee Name</span><span class="ps-info-val">{{employeeName}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">Department</span><span class="ps-info-val">{{department}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">Designation</span><span class="ps-info-val">{{designation}}</span></div>
    </div>
    <div class="ps-info-block">
      <div class="ps-info-row"><span class="ps-info-label">Date of Joining</span><span class="ps-info-val">{{dateOfJoining}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">UAN</span><span class="ps-info-val">{{uan}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">PAN</span><span class="ps-info-val">{{pan}}</span></div>
      <div class="ps-info-row"><span class="ps-info-label">Bank A/c</span><span class="ps-info-val">{{bankAccount}} ({{bankIfsc}})</span></div>
    </div>
  </div>

  <!-- Earnings & Deductions -->
  <table class="ps-table">
    <thead>
      <tr>
        <th style="width:50%">Earnings</th>
        <th class="right" style="width:15%">Amount (Rs)</th>
        <th style="width:20%">Deductions</th>
        <th class="right" style="width:15%">Amount (Rs)</th>
      </tr>
    </thead>
    <tbody>
      {{#each pairedRows}}
      <tr>
        <td>{{this.earningName}}</td>
        <td class="right">{{this.earningAmount}}</td>
        <td>{{this.deductionName}}</td>
        <td class="right">{{this.deductionAmount}}</td>
      </tr>
      {{/each}}
      <tr style="font-weight:700; border-top:1px solid #999;">
        <td>Total Earnings</td>
        <td class="right">{{totalEarnings}}</td>
        <td>Total Deductions</td>
        <td class="right">{{totalDeductions}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Employer Contributions (CTC Transparency) -->
  <div class="ps-employer-section">
    <table class="ps-table">
      <thead>
        <tr><th colspan="2">Employer Contributions (Not deducted from salary)</th></tr>
      </thead>
      <tbody>
        {{#each employerContributions}}
        <tr>
          <td>{{this.name}}</td>
          <td class="right">{{this.amount}}</td>
        </tr>
        {{/each}}
        <tr style="font-weight:700; border-top:1px solid #999;">
          <td>Total Employer Contribution</td>
          <td class="right">{{totalEmployerContribution}}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Net Pay -->
  <div class="ps-summary">
    <div>
      <div class="ps-net">Net Pay: Rs {{netPay}}</div>
      <div class="ps-net-words">{{netPayWords}}</div>
    </div>
    <div style="text-align:right;">
      <div style="font-size:8px; color:#888;">Total CTC (Monthly): Rs {{monthlyCTC}}</div>
    </div>
  </div>

  <!-- Footer -->
  <div class="ps-footer">
    <div>This is a system-generated payslip and does not require a signature.</div>
    <div>Generated on {{generatedDate}}</div>
  </div>

  <div class="ps-confidential">CONFIDENTIAL — For the addressee only</div>

</div>
</body>
</html>
