<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Tax Invoice</title>{{> base-styles}}
<style>
  .inv-table { width:100%; border-collapse:collapse; font-size:8.5px; }
  .inv-table td, .inv-table th { border:1px solid #333; padding:3px 6px; vertical-align:top; }
  .inv-table th { background:#f5f5f5; font-weight:600; text-align:center; }
  .inv-hdr { font-weight:700; font-size:9px; }
  .inv-label { font-size:7.5px; color:#555; }
  .inv-val { font-weight:600; font-size:8.5px; }
  .inv-right { text-align:right; }
  .inv-center { text-align:center; }
  .inv-mono { font-family:monospace; }
  .irn-bar { border:1px solid #999; padding:5px 8px; margin-bottom:4px; font-size:8px; display:flex; justify-content:space-between; align-items:flex-start; background:#fafafa; }
  .irn-bar .irn-text { flex:1; }
  .irn-bar .qr-img { flex-shrink:0; margin-left:8px; }
  .irn-bar .qr-img img { width:75px; height:75px; }
  .tax-summary { width:100%; border-collapse:collapse; font-size:8px; margin-top:2px; }
  .tax-summary td, .tax-summary th { border:1px solid #333; padding:2px 6px; }
  .tax-summary th { background:#f5f5f5; font-weight:600; text-align:center; font-size:7.5px; }
  .grand-total { font-size:11px; font-weight:700; }
  .company-block { font-size:8px; line-height:1.4; }
  .company-block .name { font-weight:700; font-size:9.5px; }
  .company-block .gstin { font-weight:600; margin-top:2px; }
</style>
</head>
<body>
<div class="page" style="padding:12px 16px;">

  <!-- Header row: Title + e-Invoice label -->
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
    <div style="font-size:14px; font-weight:700;">Tax Invoice</div>
    {{#if irn}}<div style="font-size:11px; font-weight:600; border:1px solid #333; padding:2px 10px;">e-Invoice</div>{{/if}}
  </div>

  <!-- IRN Bar -->
  {{#if irn}}
  <div class="irn-bar">
    <div class="irn-text">
      <div><span style="font-weight:600;">IRN</span> : <span style="font-family:monospace; font-size:7px; word-break:break-all;">{{irn}}</span></div>
      {{#if ackNo}}<div><span style="font-weight:600;">Ack No.</span> : <span class="inv-mono">{{ackNo}}</span></div>{{/if}}
      {{#if irnDate}}<div><span style="font-weight:600;">Ack Date</span> : {{formatDate irnDate}}</div>{{/if}}
    </div>
    {{#if signedQRCode}}<div class="qr-img"><img src="data:image/png;base64,{{signedQRCode}}" alt="QR"></div>{{else}}{{#if irnQrDataUrl}}<div class="qr-img"><img src="{{irnQrDataUrl}}" alt="QR"></div>{{/if}}{{/if}}
  </div>
  {{/if}}

  <!-- Main bordered grid -->
  <table class="inv-table">
    <!-- Row 1: Seller + Invoice details -->
    <tr>
      <td rowspan="4" style="width:50%;">
        <div class="company-block">
          <div class="name">Mahakaushal Sugar And Power Ind (Ethanol Div)</div>
          <div>Village Agariya, Bachai, District Narsinghpur</div>
          <div>Madhya Pradesh - 487 001</div>
          <div class="gstin">GST NO - 23AAECM3666P1Z1</div>
          <div class="gstin">GSTIN/UIN: 23AAECM3666P1Z1</div>
          <div>State Name : Madhya Pradesh, Code : 23</div>
        </div>
      </td>
      <td class="inv-label">Invoice No.</td>
      <td class="inv-label">Dated</td>
    </tr>
    <tr>
      <td class="inv-val">{{#if customInvoiceNo}}{{customInvoiceNo}}{{else}}MSPIL/ETH/{{padNum "" invoiceNo 3}}{{/if}}</td>
      <td class="inv-val">{{formatDate invoiceDate}}</td>
    </tr>
    <tr>
      <td class="inv-label">Delivery Note</td>
      <td class="inv-label">Mode/Terms of Payment</td>
    </tr>
    <tr>
      <td class="inv-val">{{#if ewbNo}}{{ewbNo}}{{else}}{{#if challanNo}}{{challanNo}}{{else}}-{{/if}}{{/if}}</td>
      <td class="inv-val">{{#if paymentMode}}{{paymentMode}}{{else}}-{{/if}}</td>
    </tr>

    <!-- Row 2: Consignee (Ship To) + Reference/Dispatch -->
    <tr>
      <td rowspan="4">
        <div style="font-size:7.5px; color:#555;">Consignee (Ship to)</div>
        <div class="company-block">
          {{#if consignee}}
          <div class="name">{{consignee.name}}</div>
          {{#if consignee.address}}<div>{{consignee.address}}</div>{{/if}}
          {{#if consignee.gstin}}<div class="gstin">GSTIN/UIN : {{consignee.gstin}}</div>{{/if}}
          {{#if consignee.state}}<div>State Name : {{consignee.state}}{{#if consignee.stateCode}}, Code : {{consignee.stateCode}}{{/if}}</div>{{/if}}
          {{else}}
          <div class="name">{{customer.name}}</div>
          {{#if customer.address}}<div>{{customer.address}}</div>{{/if}}
          {{#if customer.city}}<div>{{customer.city}}{{#if customer.pincode}} - {{customer.pincode}}{{/if}}</div>{{/if}}
          {{#if customer.gstin}}<div class="gstin">GSTIN/UIN : {{customer.gstin}}</div>{{/if}}
          {{#if customer.state}}<div>State Name : {{customer.state}}{{#if customer.stateCode}}, Code : {{customer.stateCode}}{{/if}}</div>{{/if}}
          {{/if}}
        </div>
      </td>
      <td class="inv-label">Dispatch Doc No.</td>
      <td class="inv-label">Delivery Note Date</td>
    </tr>
    <tr>
      <td class="inv-val">{{#if rstNo}}RST NO {{rstNo}}{{else}}{{#if challanNo}}{{challanNo}}{{else}}SELF{{/if}}{{/if}}</td>
      <td class="inv-val">{{formatDate invoiceDate}}</td>
    </tr>
    <tr>
      <td class="inv-label">Dispatched through</td>
      <td class="inv-label">Destination</td>
    </tr>
    <tr>
      <td class="inv-val">{{#if dispatchMode}}{{dispatchMode}}{{else}}TANKER{{/if}}</td>
      <td class="inv-val">{{#if destination}}{{destination}}{{else}}{{#if customer.state}}{{customer.state}}{{else}}-{{/if}}{{/if}}</td>
    </tr>

    <!-- Row 3: Buyer (Bill To) + Vehicle/Transport -->
    <tr>
      <td rowspan="4">
        <div style="font-size:7.5px; color:#555;">Buyer (Bill to)</div>
        <div class="company-block">
          <div class="name">{{customer.name}}</div>
          {{#if customer.address}}<div>{{customer.address}}</div>{{/if}}
          {{#if customer.city}}<div>{{customer.city}}{{#if customer.pincode}} - {{customer.pincode}}{{/if}}</div>{{/if}}
          {{#if customer.gstin}}<div class="gstin">GSTIN/UIN : {{customer.gstin}}</div>{{/if}}
          {{#if customer.state}}<div>State Name : {{customer.state}}{{#if customer.stateCode}}, Code : {{customer.stateCode}}{{/if}}</div>{{/if}}
        </div>
      </td>
      <td class="inv-label">Bill of Lading/LR-RR No.</td>
      <td class="inv-label">Motor Vehicle No.</td>
    </tr>
    <tr>
      <td class="inv-val">-</td>
      <td class="inv-val">{{#if vehicleNo}}{{vehicleNo}}{{else}}-{{/if}}</td>
    </tr>
    <tr>
      <td class="inv-label">Transporter</td>
      <td class="inv-label">Terms of Delivery</td>
    </tr>
    <tr>
      <td class="inv-val">{{#if transporterName}}{{transporterName}}{{else}}-{{/if}}</td>
      <td class="inv-val">-</td>
    </tr>
  </table>

  <!-- Items Table -->
  <table class="inv-table" style="margin-top:-1px;">
    <thead>
      <tr>
        <th style="width:20px;">Sl<br>No.</th>
        <th style="text-align:left;">Description of Services</th>
        <th style="width:60px;">HSN/SAC</th>
        <th style="width:55px;">Quantity</th>
        <th style="width:35px;">Unit</th>
        <th style="width:60px;">Rate</th>
        <th style="width:10px;">per</th>
        <th class="inv-right" style="width:85px;">Amount</th>
      </tr>
    </thead>
    <tbody>
      <tr style="height:40px;">
        <td class="inv-center">1</td>
        <td style="font-weight:600; font-style:italic;">{{productName}}<br><span style="font-weight:400; font-size:7.5px;">{{formatNum quantity}}{{unit}} @ RS {{formatNum rate}}/{{unit}}</span></td>
        <td class="inv-center inv-mono">{{hsnCode}}</td>
        <td class="inv-right inv-mono">{{formatNum quantity}}</td>
        <td class="inv-center">{{unit}}</td>
        <td class="inv-right inv-mono">{{formatNum rate}}</td>
        <td class="inv-center">{{unit}}</td>
        <td class="inv-right inv-mono">{{formatNum amount}}</td>
      </tr>
      {{#if (eq supplyType 'INTRA_STATE')}}
      <tr>
        <td></td>
        <td style="text-align:right; font-weight:600; font-style:italic;">CGST {{cgstPercent}}%</td>
        <td></td><td></td><td></td><td></td><td></td>
        <td class="inv-right inv-mono">{{formatNum cgstAmount}}</td>
      </tr>
      <tr>
        <td></td>
        <td style="text-align:right; font-weight:600; font-style:italic;">SGST {{sgstPercent}}%</td>
        <td></td><td></td><td></td><td></td><td></td>
        <td class="inv-right inv-mono">{{formatNum sgstAmount}}</td>
      </tr>
      {{else}}
      <tr>
        <td></td>
        <td style="text-align:right; font-weight:600; font-style:italic;">IGST {{igstPercent}} %</td>
        <td></td><td></td><td></td><td></td><td></td>
        <td class="inv-right inv-mono">{{formatNum igstAmount}}</td>
      </tr>
      {{/if}}
      {{#if roundOff}}
      <tr>
        <td></td>
        <td style="text-align:right; font-weight:600; font-style:italic;">Less : <span style="font-weight:700;">BALANCE ROUND OFF A/C</span></td>
        <td></td><td></td><td></td><td></td><td></td>
        <td class="inv-right inv-mono">({{#if (gt roundOff 0)}}+{{else}}-{{/if}}){{formatNum (abs roundOff)}}</td>
      </tr>
      {{/if}}
      <!-- Spacer row -->
      <tr style="height:20px;"><td colspan="8"></td></tr>
      <!-- Total -->
      <tr style="border-top:2px solid #333;">
        <td></td>
        <td style="text-align:right; font-weight:700;">Total</td>
        <td></td><td></td><td></td><td></td><td></td>
        <td class="inv-right grand-total">&#x20B9; {{formatNum (default roundedTotalAmount totalAmount)}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Amount in words -->
  <div style="font-size:8.5px; padding:4px 6px; border:1px solid #333; border-top:none; margin-top:-1px;">
    <span style="font-size:7.5px; color:#555;">Amount Chargeable (in words)</span><br>
    <span style="font-weight:700;">{{numberToWords (default roundedTotalAmount totalAmount)}}</span>
    <span style="float:right; font-style:italic; font-size:7px;">E. &amp; O.E</span>
  </div>

  <!-- HSN/SAC Tax Summary -->
  <table class="tax-summary" style="margin-top:6px;">
    <thead>
      <tr>
        <th rowspan="2">HSN/SAC</th>
        <th rowspan="2">Taxable Value</th>
        {{#if (eq supplyType 'INTRA_STATE')}}
        <th colspan="2">Central Tax</th>
        <th colspan="2">State Tax</th>
        {{else}}
        <th colspan="2">IGST</th>
        {{/if}}
        <th rowspan="2">Total<br>Tax Amount</th>
      </tr>
      <tr>
        {{#if (eq supplyType 'INTRA_STATE')}}
        <th>Rate</th><th>Amount</th>
        <th>Rate</th><th>Amount</th>
        {{else}}
        <th>Rate</th><th>Amount</th>
        {{/if}}
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="inv-center inv-mono">{{hsnCode}}</td>
        <td class="inv-right inv-mono">{{formatNum amount}}</td>
        {{#if (eq supplyType 'INTRA_STATE')}}
        <td class="inv-center">{{cgstPercent}}%</td>
        <td class="inv-right inv-mono">{{formatNum cgstAmount}}</td>
        <td class="inv-center">{{sgstPercent}}%</td>
        <td class="inv-right inv-mono">{{formatNum sgstAmount}}</td>
        {{else}}
        <td class="inv-center">{{igstPercent}}%</td>
        <td class="inv-right inv-mono">{{formatNum igstAmount}}</td>
        {{/if}}
        <td class="inv-right inv-mono">{{formatNum gstAmount}}</td>
      </tr>
      <tr style="font-weight:700;">
        <td class="inv-right">Total</td>
        <td class="inv-right inv-mono">{{formatNum amount}}</td>
        {{#if (eq supplyType 'INTRA_STATE')}}
        <td></td><td class="inv-right inv-mono">{{formatNum cgstAmount}}</td>
        <td></td><td class="inv-right inv-mono">{{formatNum sgstAmount}}</td>
        {{else}}
        <td></td><td class="inv-right inv-mono">{{formatNum igstAmount}}</td>
        {{/if}}
        <td class="inv-right inv-mono">{{formatNum gstAmount}}</td>
      </tr>
    </tbody>
  </table>

  <!-- Tax amount in words -->
  <div style="font-size:8px; padding:3px 6px; border:1px solid #333; border-top:none; margin-top:-1px;">
    <span style="font-size:7px; color:#555;">Tax Amount (in words) :</span>
    <span style="font-weight:600;">{{numberToWords gstAmount}}</span>
  </div>

  {{#if remarks}}
  <div style="font-size:8px; padding:3px 6px; border:1px solid #333; border-top:none; margin-top:-1px;">
    <span style="font-style:italic; font-size:7.5px; color:#555;">Remarks:</span><br>
    {{remarks}}
  </div>
  {{/if}}

  <!-- E-Way Bill info -->
  {{#if ewbNo}}
  <div style="font-size:8px; padding:3px 6px; border:1px solid #333; border-top:none; margin-top:-1px;">
    <span style="font-weight:600;">E-Way Bill No:</span> {{ewbNo}} &nbsp;|&nbsp;
    {{#if ewbDate}}<span style="font-weight:600;">Date:</span> {{formatDate ewbDate}} &nbsp;|&nbsp;{{/if}}
    {{#if ewbValidTill}}<span style="font-weight:600;">Valid Till:</span> {{formatDate ewbValidTill}}{{/if}}
  </div>
  {{/if}}

  <!-- Declaration + Signature -->
  <table class="inv-table" style="margin-top:6px;">
    <tr>
      <td style="width:50%; font-size:7.5px; line-height:1.4;">
        <div style="font-weight:600; font-style:italic;">Declaration</div>
        <div>We declare that this invoice shows the actual price of the goods described and that all particulars are true and correct.</div>
      </td>
      <td style="text-align:right; vertical-align:bottom; padding-bottom:30px;">
        <div style="font-weight:600; font-size:8.5px;">for Mahakaushal Sugar And Power Ind (Ethanol Div)</div>
        <br><br><br>
        <div style="font-size:8px;">Authorised Signatory</div>
      </td>
    </tr>
  </table>

  <div style="text-align:center; font-size:7px; color:#777; margin-top:6px;">This is a Computer Generated Invoice</div>
</div>
</body>
</html>
