<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Tax Invoice</title>{{> base-styles}}</head>
<body>
<div class="page">
  {{> letterhead}}

  {{#if irn}}
  <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:6px; border:1px solid #ccc; padding:6px 10px; font-size:8.5px; background:#fafafa;">
    <div>
      <div style="font-weight:bold; font-size:10px; margin-bottom:3px;">e-Invoice</div>
      <div><span style="font-weight:600;">IRN:</span> <span style="font-family:monospace; font-size:7.5px; word-break:break-all;">{{irn}}</span></div>
      {{#if ackNo}}<div><span style="font-weight:600;">Ack No:</span> {{ackNo}}</div>{{/if}}
      {{#if irnDate}}<div><span style="font-weight:600;">Ack Date:</span> {{formatDate irnDate}}</div>{{/if}}
      {{#if ewbNo}}<div style="margin-top:2px;"><span style="font-weight:600;">E-Way Bill:</span> {{ewbNo}}{{#if ewbDate}} ({{formatDate ewbDate}}){{/if}}{{#if ewbValidTill}} — Valid till {{formatDate ewbValidTill}}{{/if}}</div>{{/if}}
    </div>
    {{#if signedQRCode}}<div style="flex-shrink:0; margin-left:10px;"><img src="data:image/png;base64,{{signedQRCode}}" alt="QR" style="width:80px; height:80px;"></div>{{/if}}
  </div>
  {{/if}}

  <div class="doc-title">TAX INVOICE</div>

  <div class="details-grid">
    <div class="detail-row"><span class="detail-label">Invoice No</span><span class="detail-value bold">{{invoiceNo}}</span></div>
    <div class="detail-row"><span class="detail-label">Invoice Date</span><span class="detail-value">{{formatDate invoiceDate}}</span></div>
    {{#if dueDate}}<div class="detail-row"><span class="detail-label">Due Date</span><span class="detail-value">{{formatDate dueDate}}</span></div>{{/if}}
    {{#if challanNo}}<div class="detail-row"><span class="detail-label">Challan No</span><span class="detail-value">{{challanNo}}</span></div>{{/if}}
    {{#if ewayBill}}<div class="detail-row"><span class="detail-label">E-Way Bill</span><span class="detail-value">{{ewayBill}}</span></div>{{/if}}
  </div>

  <div class="boxes">
    <div class="box">
      <div class="box-header">Bill To</div>
      <div class="box-body">
        <div class="name">{{customer.name}}</div>
        {{#if customer.address}}<div class="line">{{customer.address}}</div>{{/if}}
        <div class="line">{{join (list customer.city customer.state customer.pincode) ", "}}</div>
        {{#if customer.gstin}}<div class="gstin">GSTIN: {{customer.gstin}}</div>{{/if}}
      </div>
    </div>
    <div class="box">
      <div class="box-header">Ship From</div>
      <div class="box-body">
        <div class="name">MSPIL Distillery</div>
        <div class="line">Village Bachai, Tehsil Gadarwara, District Narsinghpur, Madhya Pradesh - 487551</div>
        <div class="gstin">GSTIN: 23AAECM3666P1Z1</div>
      </div>
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th style="width:25px">#</th>
        <th class="left">Description</th>
        <th style="width:45px">Qty</th>
        <th style="width:35px">Unit</th>
        <th class="right" style="width:70px">Rate (Rs.)</th>
        <th class="right" style="width:85px">Amount (Rs.)</th>
        <th style="width:40px">GST%</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="center">1</td>
        <td>{{productName}}</td>
        <td class="center">{{formatNum quantity}}</td>
        <td class="center">{{unit}}</td>
        <td class="right">{{formatNum rate}}</td>
        <td class="right">{{formatNum amount}}</td>
        <td class="center">{{gstPercent}}%</td>
      </tr>
    </tbody>
  </table>

  <div class="totals-section">
    <div class="totals-box">
      <div class="total-row"><span class="label">Taxable Amount</span><span class="value">{{formatINR amount}}</span></div>
      {{#if (eq supplyType 'INTRA_STATE')}}
      <div class="total-row"><span class="label">CGST</span><span class="value">{{formatINR halfGst}}</span></div>
      <div class="total-row"><span class="label">SGST</span><span class="value">{{formatINR halfGst}}</span></div>
      {{else}}
      <div class="total-row"><span class="label">IGST</span><span class="value">{{formatINR gstAmount}}</span></div>
      {{/if}}
      {{#if freightCharge}}<div class="total-row"><span class="label">Freight</span><span class="value">{{formatINR freightCharge}}</span></div>{{/if}}
      <div class="total-row grand"><span class="label">TOTAL</span><span class="value">{{formatINR totalAmount}}</span></div>
    </div>
  </div>

  <div class="amount-words">
    <div class="label">Amount in Words:</div>
    <div class="text">{{numberToWords totalAmount}}</div>
  </div>

  {{#if remarks}}
  <div class="remarks-section"><div class="label">Remarks:</div><div class="text">{{remarks}}</div></div>
  {{/if}}

  {{> terms-footer}}
  {{> signatures sigCount=2 sigLabels=(list "For MSPIL" "Authorized Signatory") sigNames=(list preparedBy authorizedSignatory)}}

  <div class="footer-area">
    {{#if qrDataUrl}}<div class="qr-block"><img src="{{qrDataUrl}}" alt="QR"><div class="qr-text">Scan to verify this document</div></div>{{/if}}
    <div class="footer-text">{{footer}}</div>
  </div>
</div>
</body>
</html>
