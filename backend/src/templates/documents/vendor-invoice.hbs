<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Vendor Invoice</title>{{> base-styles}}</head>
<body>
<div class="page">
  {{> letterhead}}
  <div class="doc-title">VENDOR INVOICE</div>

  <div class="details-grid">
    <div class="detail-row"><span class="detail-label">Invoice No</span><span class="detail-value bold">{{invoiceNo}}</span></div>
    <div class="detail-row"><span class="detail-label">Invoice Date</span><span class="detail-value">{{formatDate invoiceDate}}</span></div>
    {{#if vendorInvNo}}<div class="detail-row"><span class="detail-label">Vendor Inv No</span><span class="detail-value">{{vendorInvNo}}</span></div>{{/if}}
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value bold">{{status}}</span></div>
  </div>

  <div class="boxes">
    <div class="box">
      <div class="box-header">Vendor</div>
      <div class="box-body">
        <div class="name">{{vendor.name}}</div>
        {{#if vendor.gstin}}<div class="gstin">GSTIN: {{vendor.gstin}}</div>{{/if}}
      </div>
    </div>
    <div class="box">
      <div class="box-header">Billed To</div>
      <div class="box-body">
        <div class="name">Mahakaushal Sugar &amp; Power Industries Ltd</div>
        <div class="line">Village Bachai, Dist. Narsinghpur (M.P.) - 487001</div>
        <div class="gstin">GSTIN: 23AAECM3666P1Z1</div>
      </div>
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th style="width:25px">#</th>
        <th class="left">Product</th>
        <th style="width:55px">Qty</th>
        <th style="width:35px">Unit</th>
        <th class="right" style="width:75px">Rate (Rs.)</th>
        <th style="width:45px">GST%</th>
        <th class="right" style="width:90px">Amount (Rs.)</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="center">1</td>
        <td>{{productName}}</td>
        <td class="center">{{formatNum quantity}}</td>
        <td class="center">{{unit}}</td>
        <td class="right">{{formatNum rate}}</td>
        <td class="center">{{gstPercent}}%</td>
        <td class="right">{{formatNum subtotal}}</td>
      </tr>
    </tbody>
  </table>

  <div class="totals-section">
    <div class="totals-box">
      <div class="total-row"><span class="label">Subtotal</span><span class="value">{{formatINR subtotal}}</span></div>
      <div class="total-row"><span class="label">GST ({{gstPercent}}%)</span><span class="value">{{formatINR totalGst}}</span></div>
      <div class="total-row grand"><span class="label">NET PAYABLE</span><span class="value">{{formatINR netPayable}}</span></div>
    </div>
  </div>

  <div class="amount-words">
    <div class="label">Amount in Words:</div>
    <div class="text">{{numberToWords netPayable}}</div>
  </div>

  {{> signatures sigCount=2 sigLabels=(list "Verified By" "Authorized Signatory") sigNames=(list preparedBy authorizedSignatory)}}

  <div class="footer-area">
    {{#if qrDataUrl}}<div class="qr-block"><img src="{{qrDataUrl}}" alt="QR"><div class="qr-text">Scan to verify this document</div></div>{{/if}}
    <div class="footer-text">This is a computer-generated document.</div>
  </div>
</div>
</body>
</html>
