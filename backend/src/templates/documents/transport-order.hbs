<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Transport Work Order</title>{{> base-styles}}
<style>
  body { font-size: 13px; }
  .doc-title { font-size: 20px; padding: 10px 0 8px; letter-spacing: 1.5px; }
  .details-grid { padding: 10px 0; }
  .detail-label { font-size: 11px; width: 140px; padding: 4px 0; }
  .detail-value { font-size: 12.5px; padding: 4px 0; }
  .box-header { font-size: 11px; padding: 6px 10px; letter-spacing: 0.6px; }
  .box-body { padding: 8px 10px; }
  .box-body .name { font-size: 13.5px; margin-bottom: 4px; }
  .box-body .line, .box-body .gstin { font-size: 11.5px; line-height: 1.55; }
  .items-table thead th { font-size: 11px; padding: 7px 6px; }
  .items-table tbody td { font-size: 11.5px; padding: 6px 6px; }
  .totals-box { width: 320px; }
  .total-row { font-size: 12.5px; padding: 5px 8px; }
  .total-row.grand { font-size: 15px; padding: 8px 8px; }
</style>
</head>
<body>
<div class="page">
  {{> letterhead}}
  <div class="doc-title">TRANSPORT WORK ORDER</div>

  <div class="details-grid">
    <div class="detail-row"><span class="detail-label">WO Number</span><span class="detail-value bold">TWO-{{twoNo}}</span></div>
    <div class="detail-row"><span class="detail-label">Date</span><span class="detail-value">{{formatDate createdAt}}</span></div>
    <div class="detail-row"><span class="detail-label">Product</span><span class="detail-value">{{productType}}</span></div>
    {{#if contractNo}}<div class="detail-row"><span class="detail-label">Against Contract</span><span class="detail-value">{{contractNo}}{{#if customerName}} — {{customerName}}{{/if}}</span></div>{{/if}}
    <div class="detail-row"><span class="detail-label">Destination / Depot</span><span class="detail-value bold">{{depot}}</span></div>
    {{#if estimatedDelivery}}<div class="detail-row"><span class="detail-label">Est. Delivery</span><span class="detail-value">{{formatDate estimatedDelivery}}</span></div>{{/if}}
    <div class="detail-row"><span class="detail-label">Freight Rate</span><span class="detail-value">{{formatINR rate}} {{rateBasisLabel}}</span></div>
    {{#if trucksOrdered}}<div class="detail-row"><span class="detail-label">Trucks</span><span class="detail-value">{{truckCount}} used of {{trucksOrdered}} ordered</span></div>{{/if}}
    <div class="detail-row"><span class="detail-label">Supply Type</span><span class="detail-value">{{#if (eq supplyType 'INTER_STATE')}}Inter State{{else}}Intra State{{/if}}</span></div>
    <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value bold">{{status}}</span></div>
  </div>

  <div class="boxes">
    <div class="box">
      <div class="box-header">Transporter</div>
      <div class="box-body">
        <div class="name">{{transporter.name}}</div>
        {{#if transporter.gstin}}<div class="gstin">GSTIN: {{transporter.gstin}}</div>{{/if}}
        {{#if transporter.phone}}<div class="line">Ph: {{transporter.phone}}</div>{{/if}}
      </div>
    </div>
    <div class="box">
      <div class="box-header">Route &amp; Terms</div>
      <div class="box-body">
        <div class="line">To: {{depot}}</div>
        {{#if distanceKm}}<div class="line">Distance: {{distanceKm}} km</div>{{/if}}
        <div class="line">Freight billed on trucks actually used.</div>
      </div>
    </div>
  </div>

  <table class="items-table">
    <thead>
      <tr>
        <th style="width:22px">#</th>
        <th class="left">Vehicle / Description</th>
        <th style="width:90px">Date</th>
        <th class="right" style="width:90px">Qty</th>
        <th style="width:50px">Unit</th>
        <th class="right" style="width:90px">Freight (Rs.)</th>
      </tr>
    </thead>
    <tbody>
      {{#each lines}}
      <tr>
        <td class="center">{{inc @index}}</td>
        <td>{{vehicleNo}}</td>
        <td class="center">{{#if dispatchDate}}{{formatDate dispatchDate}}{{else}}—{{/if}}</td>
        <td class="right">{{formatNum quantity}}</td>
        <td class="center">{{unit}}</td>
        <td class="right">{{formatNum amount}}</td>
      </tr>
      {{/each}}
    </tbody>
  </table>

  <div class="totals-section">
    <div class="totals-box">
      <div class="total-row"><span class="label">Subtotal (freight)</span><span class="value">{{formatINR subtotal}}</span></div>
      {{#if gstAmount}}
      {{#if (eq supplyType 'INTER_STATE')}}
      <div class="total-row"><span class="label">IGST</span><span class="value">{{formatINR igstAmount}}</span></div>
      {{else}}
      <div class="total-row"><span class="label">CGST</span><span class="value">{{formatINR cgstAmount}}</span></div>
      <div class="total-row"><span class="label">SGST</span><span class="value">{{formatINR sgstAmount}}</span></div>
      {{/if}}
      {{/if}}
      <div class="total-row grand"><span class="label">TOTAL</span><span class="value">{{formatINR totalAmount}}</span></div>
      {{#if tdsAmount}}<div class="total-row"><span class="label">TDS u/s 194C ({{tdsPercent}}%)</span><span class="value">- {{formatINR tdsAmount}}</span></div>{{/if}}
      <div class="total-row"><span class="label">Net Payable</span><span class="value bold">{{formatINR netPayable}}</span></div>
    </div>
  </div>

  <div class="amount-words">
    <div class="label">Net Payable in Words:</div>
    <div class="text">{{numberToWords netPayable}}</div>
  </div>

  {{#if remarks}}
  <div class="remarks-section"><div class="label">Remarks:</div><div class="text">{{remarks}}</div></div>
  {{/if}}

  {{> terms-footer}}
  {{> signatures sigCount=3 sigLabels=(list "Prepared By" "Approved By" "Authorized Signatory") sigNames=(list preparedBy "" "")}}

  <div class="footer-area">
    {{#if qrDataUrl}}<div class="qr-block"><img src="{{qrDataUrl}}" alt="QR"><div class="qr-text">Scan to verify this document</div></div>{{/if}}
    <div class="footer-text">{{footer}}</div>
  </div>
</div>
</body>
</html>
