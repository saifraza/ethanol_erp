<style>
  @page { size: A4; margin: 12mm 10mm; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 9px; color: #222; }
  @media screen { body { background: #e0e0e0; } .page { width: 210mm; min-height: 297mm; margin: 8mm auto; background: #fff; padding: 8mm 10mm; box-shadow: 0 2px 20px rgba(0,0,0,0.15); } }
  @media print { .page { margin: 0; padding: 0; box-shadow: none; } }

  /* Letterhead */
  .letterhead { background: #c5d49e; padding: 8px 12px; display: flex; align-items: center; gap: 14px; }
  .letterhead .logo { width: 52px; height: 52px; object-fit: contain; }
  .letterhead-text { flex: 1; text-align: center; }
  .letterhead-text h1 { font-size: 15px; font-weight: 800; color: #1a3b0a; margin-bottom: 2px; letter-spacing: 0.3px; }
  .letterhead-text .cin { font-size: 7px; font-weight: 700; color: #2d4a2d; margin-bottom: 1px; }
  .letterhead-text .addr { font-size: 7px; color: #3a5a3a; line-height: 1.5; }
  .border-lines { height: 4px; border-top: 2px solid #4a7d28; border-bottom: 1px solid #7a9a10; margin-top: 1px; }

  /* Document Title */
  .doc-title { text-align: center; font-size: 14px; font-weight: 800; color: #4a7d28; padding: 6px 0 5px; border-bottom: 1px solid #999; letter-spacing: 1px; }
  .doc-subtitle { text-align: center; font-size: 8px; color: #666; margin-top: 2px; }

  /* Details Grid */
  .details-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; padding: 6px 0; border-bottom: 1px solid #ddd; }
  .detail-row { display: flex; padding: 2px 0; }
  .detail-label { font-size: 7.5px; font-weight: 700; color: #666; width: 95px; text-transform: uppercase; }
  .detail-value { font-size: 8.5px; color: #000; }
  .detail-value.bold { font-weight: 700; }

  /* Boxes (Vendor/Delivery, Bill To/Ship To) */
  .boxes { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 8px 0; }
  .box { border: 1px solid #ccc; background: #f7f7f7; overflow: hidden; }
  .box-header { background: #e8e8e8; padding: 3px 8px; font-size: 7px; font-weight: 700; color: #666; text-transform: uppercase; letter-spacing: 0.5px; }
  .box-body { padding: 6px 8px; }
  .box-body .name { font-size: 9px; font-weight: 700; color: #000; margin-bottom: 3px; }
  .box-body .trade { font-size: 7.5px; color: #666; margin-bottom: 2px; }
  .box-body .line { font-size: 7.5px; color: #333; line-height: 1.5; }
  .box-body .gstin { font-size: 7.5px; font-weight: 700; color: #333; margin-top: 3px; }
  .box-body .meta-row { display: flex; gap: 4px; margin-top: 3px; }
  .box-body .meta-label { font-size: 7px; font-weight: 700; color: #666; }
  .box-body .meta-val { font-size: 8px; color: #333; }

  /* Tables */
  .items-table { width: 100%; border-collapse: collapse; border: 1px solid #999; }
  .items-table thead th { background: #4a7d28; color: #fff; font-size: 7.5px; font-weight: 700; padding: 4px 5px; text-transform: uppercase; letter-spacing: 0.3px; border-right: 1px solid #2d5a14; text-align: center; }
  .items-table thead th:last-child { border-right: none; }
  .items-table thead th.left { text-align: left; }
  .items-table thead th.right { text-align: right; }
  .items-table tbody td { padding: 4px 5px; font-size: 8px; border-bottom: 1px solid #ddd; border-right: 1px solid #e8e8e8; vertical-align: middle; }
  .items-table tbody td:last-child { border-right: none; }
  .items-table tbody tr:nth-child(even) { background: #f5f5f5; }
  .items-table tbody td.center { text-align: center; }
  .items-table tbody td.right { text-align: right; font-variant-numeric: tabular-nums; }
  .items-table tbody td.left { text-align: left; }

  /* Totals */
  .totals-section { display: flex; justify-content: flex-end; margin-top: 6px; }
  .totals-box { width: 230px; }
  .total-row { display: flex; justify-content: space-between; padding: 3px 6px; font-size: 8.5px; border-bottom: 1px solid #eee; }
  .total-row .label { color: #333; text-align: right; }
  .total-row .value { font-variant-numeric: tabular-nums; min-width: 90px; text-align: right; }
  .total-row.grand { background: #e8f0e0; border-top: 2px solid #4a7d28; border-bottom: none; font-size: 10px; font-weight: 800; padding: 5px 6px; }
  .total-row.grand .label, .total-row.grand .value { color: #4a7d28; }

  /* Amount in Words */
  .amount-words { margin-top: 10px; }
  .amount-words .label { font-size: 7.5px; font-weight: 700; color: #666; }
  .amount-words .text { font-size: 8.5px; font-weight: 700; color: #000; margin-top: 2px; }

  /* Remarks */
  .remarks-section { margin-top: 8px; padding-top: 6px; border-top: 1px solid #ddd; }
  .remarks-section .label { font-size: 7.5px; font-weight: 700; color: #666; }
  .remarks-section .text { font-size: 8px; color: #333; margin-top: 2px; }

  /* Terms */
  .terms-section { margin-top: 10px; padding-top: 6px; border-top: 1px solid #ddd; }
  .terms-section h3 { font-size: 8.5px; font-weight: 700; color: #333; margin-bottom: 5px; }
  .terms-section ol { padding-left: 14px; }
  .terms-section li { font-size: 7.5px; color: #666; line-height: 1.6; }

  /* Bank Details */
  .bank-section { margin-top: 8px; padding-top: 6px; border-top: 1px solid #ddd; }
  .bank-section h3 { font-size: 8px; font-weight: 700; color: #333; margin-bottom: 3px; }
  .bank-section .bank-text { font-size: 7.5px; color: #444; }

  /* Signatures */
  .signatures { display: grid; gap: 20px; margin-top: 28px; }
  .sig-block { text-align: center; }
  .sig-name { font-size: 8px; font-weight: 600; color: #333; min-height: 12px; margin-bottom: 4px; }
  .sig-line { border-top: 1px solid #ccc; margin: 0 15px 4px; }
  .sig-label { font-size: 8px; font-weight: 700; color: #666; }

  /* QR + Footer */
  .footer-area { display: flex; align-items: flex-end; justify-content: space-between; margin-top: 12px; padding-top: 6px; border-top: 1px solid #ddd; }
  .qr-block { display: flex; align-items: center; gap: 6px; }
  .qr-block img { width: 70px; height: 70px; }
  .qr-block .qr-text { font-size: 6px; color: #999; max-width: 100px; }
  .footer-text { font-size: 6.5px; color: #aaa; text-align: right; }

  /* Weight Summary Box */
  .weight-box { border: 1px solid #ccc; margin-top: 8px; }
  .weight-box .wb-header { background: #e8e8e8; padding: 3px 8px; font-size: 7px; font-weight: 700; color: #666; text-transform: uppercase; }
  .weight-box .wb-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; }
  .weight-box .wb-item { padding: 4px 8px; border-right: 1px solid #eee; }
  .weight-box .wb-item:last-child { border-right: none; }
  .weight-box .wb-label { font-size: 6.5px; font-weight: 700; color: #666; text-transform: uppercase; }
  .weight-box .wb-val { font-size: 9px; font-weight: 700; color: #000; margin-top: 1px; font-variant-numeric: tabular-nums; }

  /* Returnable Badge */
  .badge-returnable { display: inline-block; background: #fee2e2; color: #dc2626; font-size: 8px; font-weight: 800; padding: 2px 8px; border: 1px solid #dc2626; text-transform: uppercase; letter-spacing: 0.5px; }
  .badge-nonreturnable { display: inline-block; background: #f0fdf4; color: #16a34a; font-size: 8px; font-weight: 800; padding: 2px 8px; border: 1px solid #16a34a; text-transform: uppercase; letter-spacing: 0.5px; }

  /* Utility */
  .text-right { text-align: right; }
  .text-center { text-align: center; }
  .font-mono { font-variant-numeric: tabular-nums; }
  .mt-2 { margin-top: 4px; }
  .mt-4 { margin-top: 8px; }
</style>
