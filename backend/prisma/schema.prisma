generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Company (Multi-Tenant) ──
// MSPIL + sister concern companies. Each company gets its own vendors, POs, GRNs, accounts.
model Company {
  id            String   @id @default(uuid())
  code          String   @unique // "MSPIL", "SC-A", "SC-B"
  name          String // full legal name
  shortName     String? // display name
  gstin         String?
  pan           String?
  gstState      String? // 2-digit state code
  address       String?
  city          String?
  state         String?
  pincode       String?
  contactPerson String?
  phone         String?
  email         String?
  bankName      String?
  bankBranch    String?
  bankAccount   String?
  bankIfsc      String?
  isDefault     Boolean  @default(false) // true = MSPIL (primary company)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users User[]
}

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  password       String
  name           String
  role           String       @default("OPERATOR")
  paymentRole    String? // MAKER, CHECKER, RELEASER — null = no bank payment access
  allowedModules String? // comma-separated module keys, null = all access
  phone          String?      // for mobile app PIN login
  mobilePin      String?      // hashed PIN for mobile app
  pushToken      String?      // Expo push notification token
  companyId      String? // FK → Company (null = MSPIL default for backwards compat)
  company        Company?     @relation(fields: [companyId], references: [id])
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  grainEntries   GrainEntry[]

  @@index([phone])
  @@index([companyId])
}

model DailyEntry {
  id                     String   @id @default(cuid())
  date                   DateTime
  yearStart              Int
  syrup1Flow             Float    @default(0)
  syrup2Flow             Float    @default(0)
  syrup3Flow             Float    @default(0)
  fltFlow                Float    @default(0)
  washFlow               Float    @default(0)
  fermenter1Level        Float    @default(0)
  fermenter2Level        Float    @default(0)
  fermenter3Level        Float    @default(0)
  fermenter4Level        Float    @default(0)
  beerWellLevel          Float    @default(0)
  pfLevel                Float    @default(0)
  grainOpeningStock      Float    @default(0)
  grainUnloadedToday     Float    @default(0)
  grainConsumed          Float    @default(0)
  grainDistilled         Float    @default(0)
  grainClosingStock      Float    @default(0)
  grainInFermenters      Float    @default(0)
  steamTotal             Float    @default(0)
  steamAvgTph            Float    @default(0)
  steamPerTon            Float    @default(0)
  distillationEfficiency Float    @default(0)
  recoveryPercentage     Float    @default(0)
  status                 String   @default("DRAFT")
  notes                  String   @default("")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([date, yearStart])
}

model TankDip {
  id         String   @id @default(cuid())
  date       DateTime
  yearStart  Int
  rsLevel    Float    @default(0)
  hfoLevel   Float    @default(0)
  lfoLevel   Float    @default(0)
  production Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, yearStart])
}

model Settings {
  id                     String   @id @default(cuid())
  grainPercent           Float    @default(31)
  fermenter1Cap          Float    @default(2300)
  fermenter2Cap          Float    @default(2300)
  fermenter3Cap          Float    @default(2300)
  fermenter4Cap          Float    @default(2300)
  beerWellCap            Float    @default(430)
  pfCap                  Float    @default(430)
  pfGrainPercent         Float    @default(15)
  iltCap                 Float    @default(190)
  fltCap                 Float    @default(440)
  millingLossPercent     Float    @default(2.5)
  pfGravityTarget        Float    @default(1.024) // PF ready-to-transfer gravity
  fermRetentionHours     Float    @default(8) // hours before transfer
  rsCap                  Float    @default(15000)
  hfoCap                 Float    @default(15000)
  lfoCap                 Float    @default(15000)
  ddgsBaseProduction     Float    @default(3160) // historical DDGS production before ERP (Ton)
  ddgsBaseStock          Float    @default(1956.01) // DDGS stock at ERP start (Ton)
  autoCollectConfig      String? // JSON config for auto-collection schedules
  // Telegram Bot API
  telegramBotToken       String? // Bot token from @BotFather
  telegramEnabled        Boolean  @default(false)
  telegramGroupChatId    String? // Primary group chat ID
  telegramGroupName      String? // Group name (display only)
  telegramGroup2ChatId   String? // Secondary group chat ID
  telegramGroup2Name     String? // Group 2 name (display only)
  telegramPrivateChatIds String? // Comma-separated private chat IDs
  telegramModuleRouting  String? // JSON: { "module": "group1"|"group2"|"private" }
  // WhatsApp (outbound push via Baileys worker)
  whatsappEnabled        Boolean  @default(false)
  whatsappWorkerUrl      String?  // e.g. https://mspil-whatsapp-production.up.railway.app
  whatsappWorkerApiKey   String?  // shared secret for x-api-key header
  whatsappGroupJid       String?  // Primary group JID (120363xxx@g.us)
  whatsappGroupName      String?
  whatsappGroup2Jid      String?  // Secondary group JID
  whatsappGroup2Name     String?
  whatsappPrivatePhones  String?  // Comma-separated: 91xxxxxxxxxx,91yyyyyyyyyy
  whatsappModuleRouting  String?  // JSON: { "module": "group1"|"group2"|"private" }
  opcAlarmsEnabled       Boolean  @default(true) // OPC alarm toggle (persists across deploys)
  opcWatchdogState       String? // JSON state for opcHealthWatchdog (survives Railway restarts) — added 2026-04-08
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Generic key-value config (AI providers, integrations, etc.)
model AppConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Document templates for auto-generated PDFs (challan, PO, invoice, rate request, etc.)
model DocumentTemplate {
  id          String   @id @default(cuid())
  docType     String   @unique // CHALLAN, PURCHASE_ORDER, INVOICE, RATE_REQUEST, SALE_ORDER
  title       String? // e.g. "DELIVERY CHALLAN"
  terms       String? // JSON array of term strings
  footer      String? // Footer text
  bankDetails String? // Bank details text
  companyInfo String? // JSON with company overrides
  remarks     String? // Default remarks
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GrainEntry {
  id                   String    @id @default(uuid())
  date                 DateTime
  yearStart            Int
  grainUnloaded        Float     @default(0)
  washConsumed         Float     @default(0)
  washConsumedAt       DateTime?
  fermentationVolume   Float     @default(0)
  fermentationVolumeAt DateTime?
  f1Level              Float?
  f2Level              Float?
  f3Level              Float?
  f4Level              Float?
  beerWellLevel        Float?
  pf1Level             Float?
  pf2Level             Float?
  iltLevel             Float?
  fltLevel             Float?
  grainConsumed        Float     @default(0)
  grainInProcess       Float     @default(0)
  siloOpeningStock     Float     @default(0)
  siloClosingStock     Float     @default(0)
  quarantineStock      Float     @default(0)
  flourSilo1Level      Float     @default(0)
  flourSilo2Level      Float     @default(0)
  totalGrainAtPlant    Float     @default(0)
  cumulativeUnloaded   Float     @default(0)
  cumulativeConsumed   Float     @default(0)
  moisture             Float?
  starchPercent        Float?
  damagedPercent       Float?
  foreignMatter        Float?
  trucks               Int?
  avgTruckWeight       Float?
  supplier             String?
  remarks              String?
  userId               String
  user                 User      @relation(fields: [userId], references: [id])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([date])
  @@index([yearStart, date])
}

model SiloSnapshot {
  id                 String   @id @default(uuid())
  date               DateTime @unique
  source             String   @default("AUTO") // AUTO | BASELINE | OVERRIDE

  // OPC tank levels at snapshot (KL, converted from %)
  f1Level            Float    @default(0)
  f2Level            Float    @default(0)
  f3Level            Float    @default(0)
  f4Level            Float    @default(0)
  beerWellLevel      Float    @default(0)
  pf1Level           Float    @default(0)
  pf2Level           Float    @default(0)
  iltLevel           Float    @default(0)
  fltLevel           Float    @default(0)
  totalVolumeKL      Float    @default(0)

  // Flour silos (manual input — no OPC sensor)
  flourSilo1Level    Float    @default(0) // MT
  flourSilo2Level    Float    @default(0) // MT
  flourTotal         Float    @default(0) // MT

  // Wash from flow meter (KL, 24h)
  washDistilledKL    Float    @default(0)

  // Grain math
  grainPctUsed       Float    @default(0.31)
  grainInSystem      Float    @default(0)
  deltaGrainInSystem Float    @default(0)
  grainDistilled     Float    @default(0)
  grainConsumed      Float    @default(0)

  // Grain IN from trucks
  grainReceivedMT    Float    @default(0)
  truckCount         Int      @default(0)

  // Silo stock
  siloOpening        Float    @default(0)
  siloClosing        Float    @default(0)

  // Cumulatives (year)
  cumReceived        Float    @default(0)
  cumConsumed        Float    @default(0)

  // Data quality
  opcDataAge         Int?
  remarks            String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([date])
}

model MillingEntry {
  id           String   @id @default(uuid())
  date         DateTime
  yearStart    Int
  analysisTime String   @default("")
  sieve_1mm    Float    @default(0)
  sieve_850    Float    @default(0)
  sieve_600    Float    @default(0)
  sieve_300    Float    @default(0)
  totalFine    Float    @default(0)
  millA_rpm    Float    @default(0)
  millA_load   Float    @default(0)
  millB_rpm    Float    @default(0)
  millB_load   Float    @default(0)
  millC_rpm    Float    @default(0)
  millC_load   Float    @default(0)
  remarks      String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

// ═══════════════════════════════════════════════
// RAW MATERIAL ANALYSIS
// ═══════════════════════════════════════════════
model RawMaterialEntry {
  id           String   @id @default(uuid())
  date         DateTime
  vehicleCode  String   @default("")
  vehicleNo    String   @default("")
  moisture     Float    @default(0)
  starch       Float    @default(0)
  fungus       Float    @default(0)
  immature     Float    @default(0)
  damaged      Float    @default(0)
  waterDamaged Float    @default(0)
  tfm          Float    @default(0)
  material     String   @default("Corn")
  remark       String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

// ═══════════════════════════════════════════════
// LIQUEFACTION
// ═══════════════════════════════════════════════
model LiquefactionEntry {
  id                      String   @id @default(uuid())
  date                    DateTime
  analysisTime            String   @default("")
  jetCookerTemp           Float?
  jetCookerFlow           Float?
  iltTemp                 Float?
  iltSpGravity            Float?
  iltPh                   Float?
  iltRs                   Float?
  fltTemp                 Float?
  fltSpGravity            Float?
  fltPh                   Float?
  fltRs                   Float?
  fltRst                  Float?
  // Extra test fields
  iltDs                   Float? // Dissolved Solids ILT
  iltTs                   Float? // Total Solids ILT
  fltDs                   Float? // Dissolved Solids FLT
  fltTs                   Float? // Total Solids FLT
  iltBrix                 Float? // Brix ILT
  fltBrix                 Float? // Brix FLT
  iltViscosity            Float? // Viscosity ILT
  fltViscosity            Float? // Viscosity FLT
  iltAcidity              Float? // Acidity ILT
  fltAcidity              Float? // Acidity FLT
  iltLevel                Float? // ILT Tank Level
  fltLevel                Float? // FLT Tank Level
  fltFlowRate             Float? // FLT Flow Rate
  flourRate               Float? // Flour Rate
  hotWaterFlowRate        Float? // Hot Water Flow Rate
  thinSlopRecycleFlowRate Float? // Thin Slop Recycle Flow Rate
  slurryFlow              Float? // ILT to Jet Cooker Slurry Flow
  steamFlow               Float? // Liquefaction Steam Flow
  iltSteam                Float? // Steam in ILT
  flowToFermenter         Float? // Flow to Fermenter M³/hr
  fltIodineTest           String? // POSITIVE or NEGATIVE
  fltIodinePhotoUrl       String? // photo of iodine test
  remark                  String?
  userId                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([date])
}

// ═══════════════════════════════════════════════
// PRE-FERMENTATION
// ═══════════════════════════════════════════════

// Chemical master list (persists across batches)
model PFChemical {
  id        String   @id @default(uuid())
  name      String   @unique
  rate      Float? // Rs per unit
  unit      String   @default("kg") // kg, ltr, gm
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// PF Batch — one cycle of pre-fermentation
model PFBatch {
  id             String         @id @default(uuid())
  batchNo        Int
  fermenterNo    Int            @default(1)
  phase          String         @default("SETUP") // SETUP, DOSING, LAB, TRANSFER, CIP, DONE
  setupTime      DateTime?
  dosingEndTime  DateTime?
  slurryVolume   Float? // litres from liquefaction
  slurryGravity  Float?
  slurryTemp     Float?
  transferTime   DateTime?
  transferVolume Float?
  cipStartTime   DateTime?
  cipEndTime     DateTime?
  remarks        String?
  userId         String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  dosings        PFDosing[]
  labReadings    PFLabReading[]

  @@index([phase])
  @@index([createdAt])
}

// Dosing per batch — which chemicals added
model PFDosing {
  id           String   @id @default(uuid())
  batchId      String
  batch        PFBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chemicalName String // denormalized for easy display
  quantity     Float // amount in unit
  unit         String   @default("kg")
  rate         Float? // Rs per unit at time of dosing
  addedAt      DateTime @default(now())
}

// Lab readings during PF (replaces old PreFermentationEntry)
model PFLabReading {
  id           String   @id @default(uuid())
  batchId      String
  batch        PFBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  analysisTime String   @default("")
  spGravity    Float?
  ph           Float?
  rs           Float?
  rst          Float?
  alcohol      Float?
  ds           Float?
  vfaPpa       Float?
  temp         Float?
  remarks      String?
  userId       String
  createdAt    DateTime @default(now())
}

// Keep old model for backward compat
model PreFermentationEntry {
  id           String   @id @default(uuid())
  date         DateTime
  analysisTime String   @default("")
  batchNo      Int      @default(0)
  fermenterNo  Int      @default(1)
  spGravity    Float?
  ph           Float?
  rs           Float?
  rst          Float?
  alcohol      Float?
  ds           Float?
  vfaPpa       Float?
  temp         Float?
  remarks      String?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// FERMENTATION — the big one
// Each row = one reading for one fermenter in one batch
// ═══════════════════════════════════════════════
model FermentationEntry {
  id                String   @id @default(uuid())
  date              DateTime
  analysisTime      String   @default("")
  batchNo           Int      @default(0)
  fermenterNo       Int      @default(1)
  level             Float? // fermenter level % at time of reading
  spGravity         Float?
  ph                Float?
  rs                Float?
  rst               Float?
  alcohol           Float?
  ds                Float?
  vfaPpa            Float?
  temp              Float?
  spentLoss         Float?
  spentLossPhotoUrl String?
  status            String   @default("U/F")
  remarks           String?
  userId            String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([batchNo, fermenterNo])
  @@index([date])
  @@index([createdAt])
  @@index([fermenterNo])
}

// Fermentation batch metadata
model FermentationBatch {
  id                 String       @id @default(uuid())
  batchNo            Int
  fermenterNo        Int          @default(1)
  phase              String       @default("PF_TRANSFER") // PF_TRANSFER, FILLING, REACTION, RETENTION, TRANSFER, CIP, DONE
  pfTransferTime     DateTime?
  fillingStartTime   DateTime?
  fillingEndTime     DateTime?
  setupEndTime       DateTime?
  reactionStartTime  DateTime?
  retentionStartTime DateTime?
  fermentationEndTime DateTime?    // auto-set when gravity ≤ 1.0
  transferTime       DateTime?
  cipStartTime       DateTime?
  cipEndTime         DateTime?
  setupTime          String?
  setupDate          DateTime?
  setupGravity       Float?
  setupRs            Float?
  setupRst           Float?
  fermLevel          Float? // level % of 2300 M³
  volume             Float? // calculated litres
  transferVolume     Float?
  beerWellNo         Int?
  finalDate          DateTime?
  finalRsGravity     Float?
  totalHours         Float?
  yeast              String?
  enzyme             String?
  formolin           String?
  booster            String?
  urea               String?
  finalAlcohol       Float?
  remarks            String?
  userId             String
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  dosings            FermDosing[]

  @@unique([batchNo, fermenterNo])
  @@index([phase])
  @@index([createdAt])
}

// Fermentation chemicals (reusable list)
model FermChemical {
  id        String   @id @default(uuid())
  name      String   @unique
  unit      String   @default("kg")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Dosing per fermentation batch
model FermDosing {
  id           String            @id @default(uuid())
  batchId      String
  batch        FermentationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  chemicalName String
  quantity     Float
  unit         String            @default("kg")
  level        Float? // fermenter level % at time of dosing
  addedAt      DateTime          @default(now())
}

// Beer Well readings
model BeerWellReading {
  id        String   @id @default(uuid())
  wellNo    Int      @default(1)
  level     Float? // level %
  spGravity Float?
  ph        Float?
  alcohol   Float?
  temp      Float?
  remarks   String?
  batchNo   Int? // which batch was transferred here
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// DOSING RECIPES (fixed patterns)
// ═══════════════════════════════════════════════
model DosingRecipe {
  id           String   @id @default(uuid())
  category     String // PF, FERMENTER, LIQUEFACTION
  chemicalName String
  quantity     Float
  unit         String   @default("kg")
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// DISTILLATION
// ═══════════════════════════════════════════════
model DistillationEntry {
  id                   String   @id @default(uuid())
  date                 DateTime
  analysisTime         String   @default("")
  spentWashLoss        Float?
  rcLessLoss           Float?
  ethanolStrength      Float?
  rcReflexStrength     Float?
  regenerationStrength Float?
  evaporationSpgr      Float?
  // New fields
  rcStrength           Float?
  actStrength          Float?
  spentLossLevel       String? // NIL, SLIGHT, HIGH
  spentWashPhotoUrl    String?
  rcLessPhotoUrl       String?
  remark               String?
  userId               String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([date])
}

// ═══════════════════════════════════════════════
// EVAPORATION
// ═══════════════════════════════════════════════
model EvaporationEntry {
  id                 String   @id @default(uuid())
  date               DateTime
  analysisTime       String   @default("")
  // FF1-FF5 specific gravity & temp
  ff1SpGravity       Float?
  ff1Temp            Float?
  ff2SpGravity       Float?
  ff2Temp            Float?
  ff3SpGravity       Float?
  ff3Temp            Float?
  ff4SpGravity       Float?
  ff4Temp            Float?
  ff5SpGravity       Float?
  ff5Temp            Float?
  // FC1, FC2 specific gravity & temp
  fc1SpGravity       Float?
  fc1Temp            Float?
  fc2SpGravity       Float?
  fc2Temp            Float?
  // Concentration of each FFE (%) — legacy, kept for old data
  ff1Concentration   Float?
  ff2Concentration   Float?
  ff3Concentration   Float?
  ff4Concentration   Float?
  ff5Concentration   Float?
  // Syrup
  syrupConcentration Float?
  // Vacuum & flow
  vacuum             Float?
  thinSlopFlowRate   Float?
  // Last syrup gravity
  lastSyrupGravity   Float?
  // Reboiler of Analyzer Column (A, B, C)
  reboilerATemp      Float?
  reboilerBTemp      Float?
  reboilerCTemp      Float?
  // Thin Slop
  thinSlopGravity    Float?
  thinSlopSolids     Float?
  // Spent Wash
  spentWashGravity   Float?
  spentWashSolids    Float?
  remark             String?
  userId             String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([date])
}

// ═══════════════════════════════════════════════
// DDGS PRODUCTION
// ═══════════════════════════════════════════════
model DDGSProductionEntry {
  id              String   @id @default(uuid())
  date            DateTime
  shiftDate       String   @default("") // YYYY-MM-DD of 9am-9am shift day
  entryTime       String   @default("")
  timeFrom        String   @default("") // e.g. "08:00"
  timeTo          String   @default("") // e.g. "09:00"
  operatorName    String   @default("")
  bags            Float?
  weightPerBag    Float?
  totalProduction Float?
  // Dryer params
  dryerInletTemp  Float?
  dryerOutletTemp Float?
  ddgsMoisture    Float?
  ddgsProtein     Float?
  remark          String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([shiftDate])
}

// ═══════════════════════════════════════════════
// DDGS STOCK (daily stock tracking)
// ═══════════════════════════════════════════════
model DDGSStockEntry {
  id              String   @id @default(uuid())
  date            DateTime
  yearStart       Int
  openingStock    Float    @default(0) // auto from prev closing
  productionToday Float    @default(0) // bags * weightPerBag from DDGS production
  dispatchToday   Float    @default(0) // sum of dispatch trucks
  closingStock    Float    @default(0) // opening + production - dispatch
  bags            Int      @default(0)
  weightPerBag    Float    @default(50) // kg per bag default 50
  remarks         String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([date, yearStart])
}

// ═══════════════════════════════════════════════
// DDGS DISPATCH TRUCKS (per-truck outgoing)
// ═══════════════════════════════════════════════
model DDGSDispatchTruck {
  id                   String                @id @default(uuid())
  date                 DateTime              @default(now())
  status               String                @default("GATE_IN") // GATE_IN → TARE_WEIGHED → LOADING → GROSS_WEIGHED → BILLED → RELEASED
  rstNo                Int?
  vehicleNo            String                @default("")
  partyName            String                @default("")
  partyAddress         String?
  partyGstin           String?
  destination          String                @default("")
  driverName           String?
  driverMobile         String?
  transporterName      String?
  bags                 Int                   @default(0)
  weightPerBag         Float                 @default(50)
  weightGross          Float                 @default(0)
  weightTare           Float                 @default(0)
  weightNet            Float                 @default(0)
  rate                 Float? // ₹ per MT
  invoiceNo            String?
  invoiceAmount        Float?
  gatePassNo           String?
  ewayBillNo           String?
  hsnCode              String                @default("2303") // DDGS HSN
  gateInTime           DateTime?
  tareTime             DateTime?
  grossTime            DateTime?
  releaseTime          DateTime?
  remarks              String?
  sourceWbId           String?               @unique // Factory weighment ID for dedup (CRITICAL for idempotency)
  customerId           String?
  customer             Customer?             @relation("DDGSDispatchBillTo", fields: [customerId], references: [id])
  contractId           String?
  contract             DDGSContract?         @relation(fields: [contractId], references: [id])
  // Ship-To (may differ from Bill-To for job work; snapshot at gate entry)
  shipToCustomerId     String?
  shipToCustomer       Customer?             @relation("DDGSDispatchShipTo", fields: [shipToCustomerId], references: [id])
  shipToName           String?
  shipToGstin          String?
  shipToAddress        String?
  shipToState          String?
  shipToPincode        String?
  userId               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @default(now()) @updatedAt
  ddgsContractDispatch DDGSContractDispatch?

  division String? @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON

  @@index([date])
  @@index([customerId])
  @@index([contractId])
  @@index([shipToCustomerId])
  @@index([division])
}

// ═══════════════════════════════════════════════
// DRYER (3 dryers — moisture, steam, syrup, load)
