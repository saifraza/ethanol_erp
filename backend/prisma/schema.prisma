  d2Feed       Float?
  d2WetCake    Float?
  d2ThinSlopGr Float?
  d3Feed       Float?
  d3WetCake    Float?
  d3ThinSlopGr Float?
  d4Feed       Float?
  d4WetCake    Float?
  d4ThinSlopGr Float?
  d5Feed       Float?
  d5WetCake    Float?
  d5ThinSlopGr Float?
  d6Feed       Float?
  d6WetCake    Float?
  d6ThinSlopGr Float?
  d7Feed       Float?
  d7WetCake    Float?
  d7ThinSlopGr Float?
  d8Feed       Float?
  d8WetCake    Float?
  d8ThinSlopGr Float?
  remark       String?
  userId       String
  createdAt    DateTime @default(now())
