  companyId      String? // FK → Company (null = MSPIL default)
  company        Company?                @relation(fields: [companyId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([companyId])
  @@index([startDate])
  @@index([endDate])
}

model SugarContractDispatch {
  id              String        @id @default(uuid())
  contractId      String
  contract        SugarContract @relation(fields: [contractId], references: [id])
  dispatchDate    DateTime
  vehicleNo       String
  driverName      String?
  driverPhone     String?
  transporterName String?
  destination     String?
  bags            Int           @default(0)
  weightPerBag    Float         @default(50)
  weightGrossMT   Float         @default(0)
  weightTareMT    Float         @default(0)
  weightNetMT     Float         @default(0)
  rate            Float         @default(0)
  amount          Float         @default(0)
  distanceKm      Float?
  challanNo       String?
  gatePassNo      String?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  sugarDispatchTruckId String?             @unique
  sugarDispatchTruck   SugarDispatchTruck? @relation(fields: [sugarDispatchTruckId], references: [id])

  status    String   @default("DISPATCHED")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([dispatchDate])
}

// ═══════════════════════════════════════════════
// COMPLIANCE & TAX — PHASE 1 (Master Data)
// See .claude/skills/compliance-tax-system.md
// ═══════════════════════════════════════════════

// Company-level tax identity + LUT + regime
model ComplianceConfig {
  id                  String    @id @default(cuid())
  legalName           String
  pan                 String    @unique
  tan                 String    @unique
  gstin               String    @unique
  cin                 String?
  udyamNo             String?
  registeredState     String // 2-digit GST state code (e.g., "23" for MP)
  registeredStateName String? // "Madhya Pradesh"
  taxRegime           String    @default("NORMAL") // "115BAB" | "115BAA" | "NORMAL"
  fyStartMonth        Int       @default(4) // April
  eInvoiceEnabled     Boolean   @default(true)
  eInvoiceThresholdCr Float     @default(5)
  eWayBillMinAmount   Float     @default(50000)
  lutNumber           String?
  lutValidFrom        DateTime?
  lutValidTill        DateTime?
  updatedBy           String?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())
}

// Fiscal Year + period lock
model FiscalYear {
  id        String          @id @default(cuid())
  code      String          @unique // "2026-27"
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean         @default(false)
  isClosed  Boolean         @default(false)
  closedAt  DateTime?
  closedBy  String?
  series    InvoiceSeries[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  companyId String? // FK → Company (null = MSPIL default)
  company   Company?        @relation(fields: [companyId], references: [id])

  @@index([isCurrent])
  @@index([companyId])
}

// Per-FY per-docType invoice number series with atomic next-number
model InvoiceSeries {
  id         String     @id @default(cuid())
  fyId       String
  fy         FiscalYear @relation(fields: [fyId], references: [id], onDelete: Cascade)
  docType    String // TAX_INVOICE | CREDIT_NOTE | DEBIT_NOTE | DELIVERY_CHALLAN | EXPORT_INVOICE | RCM_INVOICE | JOBWORK_INVOICE
  prefix     String // "ETH/26-27/"
  nextNumber Int        @default(1)
  width      Int        @default(5)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@unique([fyId, docType])
  @@index([fyId])
  @@index([companyId])
}

// HSN / SAC code master
model HsnCode {
  id             String          @id @default(cuid())
  code           String          @unique // "2207 20"
  description    String
  uqc            String // "KLR" | "KGS" | "NOS" | "MTS"
  category       String // FINISHED_GOOD | RAW_MATERIAL | BYPRODUCT | SERVICE
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  rates          GstRate[]
  materials      Material[]
  inventoryItems InventoryItem[]
  poLines        POLine[]

  @@index([code])
  @@index([category])
}

// Effective-dated GST rate per HSN
model GstRate {
  id            String    @id @default(cuid())
  hsnId         String
  hsn           HsnCode   @relation(fields: [hsnId], references: [id], onDelete: Cascade)
  cgst          Float     @default(0)
  sgst          Float     @default(0)
  igst          Float     @default(0)
  cess          Float     @default(0)
  isExempt      Boolean   @default(false)
  isOutsideGst  Boolean   @default(false) // e.g., ENA, alcohol for human consumption
  conditionNote String? // "EBP only" | "Industrial use"
  effectiveFrom DateTime
  effectiveTill DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([hsnId, effectiveFrom])
}

// TDS Section master (new Income-tax Act 2025 codes + old legacy)
model TdsSection {
  id                 String          @id @default(cuid())
  code               String          @unique // "393_CONTRACTOR"
  newSection         String // "393"
  oldSection         String? // "194C"
  nature             String // "Contractor"
  rateIndividual     Float // 1
  rateOthers         Float // 2
  thresholdSingle    Float           @default(0)
  thresholdAggregate Float           @default(0)
  panMissingRate     Float           @default(20)
  nonFilerRate       Float           @default(5)
  effectiveFrom      DateTime
  effectiveTill      DateTime?
  isActive           Boolean         @default(true)
  defaultLedgerId    String? // FK → Account (TDS Payable ledger for this section)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  vendors            Vendor[]
  poOverrides        PurchaseOrder[] @relation("PoOverrideTds")

  @@index([newSection])
  @@index([effectiveFrom])
  @@index([defaultLedgerId])
}

// TCS Section master
model TcsSection {
  id            String    @id @default(cuid())
  code          String    @unique // "206C_1H"
  nature        String
  rate          Float
  threshold     Float     @default(0)
  effectiveFrom DateTime
  effectiveTill DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Audit trail for every compliance field change
model ComplianceAudit {
  id         String   @id @default(cuid())
  entityType String // "Vendor" | "Customer" | "ComplianceConfig" | "GstRate" | "TdsSection" | ...
  entityId   String
  field      String
  oldValue   String?
  newValue   String?
  changedBy  String
  changedAt  DateTime @default(now())
  reason     String?

  @@index([entityType, entityId])
  @@index([changedAt])
}

// Plain-English explanations used by the Tax Rules Reference page
model TaxRuleExplanation {
  id           String   @id @default(cuid())
  ruleKey      String   @unique // "tds.393.contractor"
  title        String
  plainEnglish String   @db.Text
  whatErpDoes  String   @db.Text
  whatUserDoes String   @db.Text
  sourceLink   String?
  category     String // DIRECT_TAX | GST | PAYROLL | ROC | DISTILLERY | OTHER
  sortOrder    Int      @default(0)
  updatedBy    String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([category, sortOrder])
}

/// Cloud mirror of factory Weighment. Passive — does not drive any
/// business logic. Populated by POST /api/weighment/sync from factory
/// syncWorker (Phase 2) and by a Tailscale backfill script (Phase 3).
/// See .claude/memory or commit history for the architectural context.
model Weighment {
  id               String    @id @default(uuid())
  localId          String    @unique
  ticketNo         Int?      @unique // unique index added 2026-04-16 — DB-level dedup safety net
  vehicleNo        String
  direction        String
  supplierName     String?
  customerName     String?
  shipToName       String?
  materialName     String?
  materialCategory String?
  purchaseType     String?
  poId             String?
  poLineId         String?
  supplierId       String?
  customerId       String?
  grossWeight      Float?
  tareWeight       Float?
  netWeight        Float?
  grossTime        DateTime?
  tareTime         DateTime?
  gateEntryAt      DateTime?
  firstWeightAt    DateTime?
  secondWeightAt   DateTime?
  releaseAt        DateTime?
  status           String
  labStatus        String?
  labMoisture      Float?
  labStarch        Float?
  labDamaged       Float?
  labForeignMatter Float?
  labRemarks       String?
  driverName       String?
  driverPhone      String?
  driverLicense    String?
  transporterName  String?
  transporterGstin String?
  vehicleType      String?
  bags             Int?
  rate             Float?
  strength         Float?
  quantityBL       Float?
  sealNo           String?
  rstNo            String?
  remarks          String?
  cancelled        Boolean   @default(false)
  cancelledReason  String?
  cancelledAt      DateTime?
  factoryCreatedAt DateTime?
  factoryUpdatedAt DateTime?
  rawPayload       Json?
  syncedAt         DateTime  @default(now()) @updatedAt
  syncedFromIp     String?
  mirrorVersion    Int       @default(1)

  @@index([direction, gateEntryAt])
  @@index([materialCategory])
  @@index([status])
  @@index([vehicleNo])
  // ticketNo: unique index lives on the field itself (@unique on line 4118)
  @@index([poId])
  @@index([factoryCreatedAt])
  @@index([direction, materialCategory, secondWeightAt])
  @@index([syncedAt])
  @@index([purchaseType])
  @@index([supplierId])
  @@index([customerId])
}

// ══════════════════════════════════════════════════════════════
// HR MODULE — Employee Master, Payroll, Statutory Compliance
// ══════════════════════════════════════════════════════════════

model Designation {
  id        String   @id @default(cuid())
  title     String   @unique
  grade     String? // E1, E2, M1, S1
  band      String? // Senior Management, Middle Management, Staff
  level     Int      @default(0) // hierarchy level for org chart (0=top)
  minSalary Float?
  maxSalary Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  companyId String? // FK → Company (null = MSPIL default)
  company   Company?   @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Employee {
  id      String @id @default(cuid())
  empCode String @unique // MSPIL-001
  empNo   Int    @unique @default(autoincrement())

  // Personal
  firstName     String
  lastName      String
  fatherName    String?
  dateOfBirth   DateTime?
  gender        String? // MALE, FEMALE, OTHER
  bloodGroup    String?
  maritalStatus String?
  photo         String?

  // Contact
  phone            String?
  email            String?
  addressCurrent   String?
  addressPermanent String?
  emergencyContact String?
  emergencyPhone   String?

  // Identity
  aadhaar    String?
  pan        String?
  passportNo String?

  // RFID card number — pushed to biometric devices alongside fingerprint
  // for employees who authenticate via card. Stored as string to allow
  // leading zeros and printed-card-format compatibility; converted to int
  // when relayed to the device (which expects a 32-bit unsigned).
  cardNumber String?

  // EPF / PF
  uan                   String? // 12-digit Universal Account Number
  pfMemberNo            String? // Establishment-specific: AA/BBB/CCCCCCC
  pfJoiningDate         DateTime?
  previousPfNo          String? // For Form 13 transfer
  isInternationalWorker Boolean   @default(false)
  higherPensionOpt      Boolean   @default(false) // Section 11(3) opt-in

  // ESI
  esicNo String?

  // PF Nomination (Form 2)
  pfNomineeName     String?
  pfNomineeRelation String?
  pfNomineeDob      DateTime?
  pfNomineeShare    Float? // percentage (100 if single nominee)

  // Bank
  bankName    String?
  bankBranch  String?
  bankAccount String?
  bankIfsc    String?

  // Employment
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id])
  reportingToId String?
  reportingTo   Employee?    @relation("Reporting", fields: [reportingToId], references: [id])
  reportees     Employee[]   @relation("Reporting")

  // Labor Contractor (for contract workers)
  contractorId      String?
  contractor        Contractor? @relation(fields: [contractorId], references: [id])
  contractStartDate DateTime?
  contractEndDate   DateTime?
  contractRefNo     String?
  dailyWageRate     Float?

  dateOfJoining    DateTime
  confirmationDate DateTime?
  dateOfLeaving    DateTime?
  employmentType   String    @default("PERMANENT") // PERMANENT, CONTRACT, FIXED_TERM, TRAINEE, APPRENTICE, DAILY_WAGE
  skillCategory    String? // UNSKILLED, SEMI_SKILLED, SKILLED, HIGHLY_SKILLED
  shiftPattern     String? // DAY, ROTATING_3SHIFT, GENERAL
  workLocation     String    @default("FACTORY") // FACTORY, OFFICE
  division         String    @default("ETHANOL") // SUGAR | POWER | ETHANOL | HQ | COMMON

  // Salary Config
  ctcAnnual        Float   @default(0)
  cashPayPercent   Float   @default(0) // % of netPay paid in cash (e.g. 30); rest goes to bank
  basicMonthly     Float   @default(0)
  epfApplicable    Boolean @default(true)
  epfOnActualBasic Boolean @default(false) // true = PF on full basic, false = capped at 15000
  esiApplicable    Boolean @default(true)
  ptApplicable     Boolean @default(true)
  taxRegime        String  @default("NEW") // NEW, OLD

  // Tax declarations (old regime)
  declared80C     Float @default(0)
  declared80D     Float @default(0)
  declaredHRA     Float @default(0)
  declaredOther   Float @default(0)
  rentPaidMonthly Float @default(0)

  // Salary sheet category (matches MSPIL Excel structure: SENIOR/PF/NPF/DIRECTOR/etc.)
  payCategory    String? // SENIOR | PF | NPF | DIRECTOR | SEASONAL | CONTRACT
  defaultPayMode String  @default("BANK") // CASH | BANK — main payout channel

  // Seasonal employment status (sugar industry — crushing-season vs year-round)
  seasonalStatus String? // SEASONAL | OFF_SEASONAL

  // Reference to original Excel section/department string (for migration trace)
  excelSection    String?
  excelSourceFile String?

  // Status
  status   String  @default("ACTIVE") // ACTIVE, ON_NOTICE, RELIEVED, ABSCONDING, TERMINATED
  isActive Boolean @default(true)
  remarks  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  salaryComponents  EmployeeSalaryComponent[]
  payrollLines      PayrollLine[]
  attendancePunches AttendancePunch[]
  attendanceDays    AttendanceDay[]
  leaveApplications LeaveApplication[]
  defaultShiftId    String?
  defaultShift      Shift?                    @relation(fields: [defaultShiftId], references: [id])
  // Biometric device user_id — same value across all configured devices.
  // For new employees, defaults to empNo at creation time. For legacy
  // enrollments, set via the HR > Biometric Devices mapping UI.
  deviceUserId      String?
  companyId         String? // FK → Company (null = MSPIL default)
  company           Company?                  @relation(fields: [companyId], references: [id])

  @@index([departmentId])
  @@index([designationId])
  @@index([status])
  @@index([reportingToId])
  @@index([contractorId])
  @@index([companyId])
  @@index([division])
  @@index([employmentType])
  @@index([isActive])
  @@index([defaultShiftId])
  @@index([deviceUserId])
}

model SalaryComponent {
  id              String   @id @default(cuid())
  code            String   @unique // BASIC, HRA, EPF_EE, EPF_ER_EPF, EPF_ER_EPS, etc.
  name            String
  type            String // EARNING, DEDUCTION, EMPLOYER_CONTRIBUTION
  isStatutory     Boolean  @default(false)
  isTaxable       Boolean  @default(true)
  isPfWage        Boolean  @default(false) // included in PF wage calculation
  calculationType String   @default("FIXED") // FIXED, PERCENTAGE_OF_BASIC, PERCENTAGE_OF_GROSS, FORMULA
  defaultPct      Float?
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employeeComponents EmployeeSalaryComponent[]
  payrollComponents  PayrollLineComponent[]
}

model EmployeeSalaryComponent {
  id            String          @id @default(cuid())
  employeeId    String
  employee      Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  componentId   String
  component     SalaryComponent @relation(fields: [componentId], references: [id])
  monthlyAmount Float           @default(0)
  annualAmount  Float           @default(0)
  effectiveFrom DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@unique([employeeId, componentId])
  @@index([employeeId])
}

model PayrollRun {
  id               String    @id @default(cuid())
  runNo            Int       @unique @default(autoincrement())
  month            Int
  year             Int
  runDate          DateTime  @default(now())
  status           String    @default("DRAFT") // DRAFT, PROCESSING, COMPUTED, APPROVED, PAID, CANCELLED
  totalGross       Float     @default(0)
  totalDeductions  Float     @default(0)
  totalNet         Float     @default(0)
  totalEpfEmployee Float     @default(0)
  totalEpfEmployer Float     @default(0)
  totalEsiEmployee Float     @default(0)
  totalEsiEmployer Float     @default(0)
  totalPt          Float     @default(0)
  totalTds         Float     @default(0)
  employeeCount    Int       @default(0)
  approvedBy       String?
  approvedAt       DateTime?
  paidDate         DateTime?
  remarks          String?
  userId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lines     PayrollLine[]
  companyId String? // FK → Company (null = MSPIL default)
  company   Company?      @relation(fields: [companyId], references: [id])

  @@unique([month, year])
  @@index([status])
  @@index([companyId])
}

model PayrollLine {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id])

  grossEarnings   Float @default(0)
  totalDeductions Float @default(0)
  netPay          Float @default(0)

  // Cash vs Bank split (snapshot from Employee.cashPayPercent at compute time)
  cashAmount Float     @default(0) // portion of netPay to be paid in cash
  bankAmount Float     @default(0) // portion of netPay to be paid via bank transfer
  paidStatus String    @default("UNPAID") // UNPAID, CASH_PAID, BANK_PAID, FULLY_PAID
  cashPaidAt DateTime?
  bankPaidAt DateTime?

  // EPF breakdown
  pfWages        Float @default(0) // Basic + DA
  epfEmployee    Float @default(0) // 12% of PF wages
  epfEmployerEpf Float @default(0) // 3.67% of PF wages
  epfEmployerEps Float @default(0) // 8.33% of min(pfWages, 15000)
  edliEmployer   Float @default(0) // 0.50% of min(pfWages, 15000)
  epfAdminCharge Float @default(0) // 0.50% of min(pfWages, 15000)

  // ESI
  esiEmployee Float @default(0)
  esiEmployer Float @default(0)

  // Other statutory
  professionalTax Float @default(0)
  tds             Float @default(0)

  // ECR fields
  grossWages Float @default(0)
  epfWages   Float @default(0)
  epsWages   Float @default(0) // min(pfWages, 15000)
  edliWages  Float @default(0) // min(pfWages, 15000)
  ncpDays    Int   @default(0)

  // Day-level tracking (matches MSPIL salary sheet format)
  workingDays   Int   @default(0)
  presentDays   Int   @default(0)
  holidayDays   Int   @default(0)
  holidayAmount Float @default(0) // EWA = (basic+conv+med)/working * holiday
  ewDays        Int   @default(0) // Extra Work days
  ewAmount      Float @default(0)

  // Detailed deductions (separated from `totalDeductions`)
  advanceDeduction Float @default(0)
  otherDeduction   Float @default(0)

  // Extra pays — one-off / reimbursement (in addition to regular salary)
  additionalAmount Float   @default(0) // From "Additional" sheet (senior staff)
  additionalNote   String?
  petrolAmount     Float   @default(0) // Cane Petrol reimbursement
  mobileAllowance  Float   @default(0) // Cane Mobile reimbursement

  // Source / category for filtering & reports
  category String @default("REGULAR") // REGULAR | SENIOR | PF | NPF | DIRECTOR | SEASONAL | CONTRACT

  status    String   @default("COMPUTED") // COMPUTED, APPROVED, PAID, HOLD
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components PayrollLineComponent[]

  @@unique([payrollRunId, employeeId])
  @@index([payrollRunId])
  @@index([employeeId])
  @@index([category])
}

model PayrollLineComponent {
  id            String          @id @default(cuid())
  payrollLineId String
  payrollLine   PayrollLine     @relation(fields: [payrollLineId], references: [id], onDelete: Cascade)
  componentId   String
  component     SalaryComponent @relation(fields: [componentId], references: [id])
  amount        Float           @default(0)
  createdAt     DateTime        @default(now())

  @@unique([payrollLineId, componentId])
  @@index([payrollLineId])
}

// ── TDS Challan (Section 192 — Salary TDS deposit to govt) ────
// Each row = one ITNS-281 challan deposit covering payroll TDS for a month/quarter.
// Forms the link between monthly TDS deducted and quarterly Form 24Q filing.
model TdsChallan {
  id             String    @id @default(cuid())
  fyCode         String // "2026-27"
  quarter        Int // 1=Apr-Jun, 2=Jul-Sep, 3=Oct-Dec, 4=Jan-Mar
  month          Int // 1-12 calendar month for which TDS was deducted
  year           Int
  section        String    @default("192") // 192 (salary), 192A, 194, etc.
  challanNo      String // BSR receipt no (CIN)
  bsrCode        String // 7-digit BSR code of bank branch
  depositDate    DateTime
  amount         Float // tax + interest + others
  taxAmount      Float     @default(0)
  surcharge      Float     @default(0)
  cess           Float     @default(0)
  interest       Float     @default(0)
  penalty        Float     @default(0)
  others         Float     @default(0)
  paymentMode    String    @default("ONLINE") // ONLINE | OTC_CHEQUE | OTC_CASH
  bankName       String?
  remarks        String?
  filedInForm24Q Boolean   @default(false)
  filedQuarter   Int? // which Form 24Q quarter this challan was reported in
  filedFy        String?
  filedAt        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  userId         String?
  companyId      String? // FK → Company (null = MSPIL default)
  company        Company?  @relation(fields: [companyId], references: [id])

  @@unique([challanNo, bsrCode, depositDate])
  @@index([fyCode, quarter])
  @@index([month, year])
  @@index([companyId])
}

// ── GST Reconciliation (2A / 2B) ────────────────────────────
model GstReconRun {
  id           String          @id @default(cuid())
  returnType   String // "2A" | "2B"
  filingPeriod String // "042026" (MMYYYY from portal)
  periodMonth  Int // 4
  periodYear   Int // 2026
  buyerGstin   String
  uploadedAt   DateTime        @default(now())
  uploadedBy   String
  status       String          @default("UPLOADED") // UPLOADED | MATCHED | FINALIZED
  totalPortal  Int             @default(0)
  totalBooks   Int             @default(0)
  matched      Int             @default(0)
  onlyInPortal Int             @default(0)
  onlyInBooks  Int             @default(0)
  mismatch     Int             @default(0)
  itcMatched   Float           @default(0)
  itcAtRisk    Float           @default(0)
  rawJson      String?         @db.Text
  entries      GstReconEntry[]

  @@index([filingPeriod])
  @@index([returnType, filingPeriod])
  @@index([uploadedAt])
}

model GstReconEntry {
  id              String      @id @default(cuid())
  runId           String
  run             GstReconRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  source          String // "PORTAL" | "BOOKS"
  supplierGstin   String
  supplierName    String?
  invoiceNumber   String
  invoiceDate     DateTime?
  invoiceValue    Float       @default(0)
  taxableValue    Float       @default(0)
  cgst            Float       @default(0)
  sgst            Float       @default(0)
  igst            Float       @default(0)
  cess            Float       @default(0)
  totalGst        Float       @default(0)
  isRCM           Boolean     @default(false)
  itcAvailable    String? // "Y" | "N" from portal
  matchStatus     String      @default("PENDING") // MATCHED | ONLY_IN_PORTAL | ONLY_IN_BOOKS | MISMATCH
  matchMethod     String? // "AUTO" | "MANUAL"
  vendorInvoiceId String?
  taxDiffCgst     Float?
  taxDiffSgst     Float?
  taxDiffIgst     Float?
  taxDiffTotal    Float?
  notes           String?

  @@index([runId])
  @@index([runId, matchStatus])
  @@index([supplierGstin, invoiceNumber])
  @@index([vendorInvoiceId])
}

// ═══════════════════════════════════════════════
// ACTIVITY LOG — generic high-value audit trail
// Captures every CREATE/UPDATE/DELETE on a whitelist of high-value models
// (invoices, payments, POs, GRNs, vendors, customers, items, weighbridge,
// contracts, journal entries, master data, business rules). Driven by Prisma
// $use middleware in services/activityLogger.ts. Visible at /admin/activity-log.
//
// Volume estimate: ~100-500 high-value writes/day → ~36k-180k rows/year.
// Trivial for Postgres. `changes` JSON only contains fields that actually
// changed (UPDATE) or the full record (CREATE/DELETE).
//
// Excluded models (in SELF_WRITE_BLACKLIST or absent from MODEL_CATEGORY):
//   - ActivityLog itself (would loop forever)
//   - WeighmentAuditEvent / WeighmentAuditQueue (own page at /admin/weighbridge-audit)
//   - StockLevel, SyncQueue, Heartbeat, OpcTag, WashTotalizer (high-volume noise)
// ═══════════════════════════════════════════════
model ActivityLog {
  id        String   @id @default(uuid())
  category  String // FINANCIAL | MASTER_DATA | INVENTORY | WEIGHBRIDGE | COMPLIANCE | AUTH | CONTRACT | CONFIG
  model     String // e.g. "Invoice", "PurchaseOrder", "Vendor"
  recordId  String? // primary key of the affected row
  action    String // CREATE | UPDATE | DELETE
  userId    String? // null for system-initiated writes (background workers)
  userName  String? // "system" when no user context
  userRole  String?
  routePath String? // e.g. "POST /api/invoices"
  ipAddress String?
  summary   String? // short human-readable headline (computed by logger)
  changes   Json? // {field: {from, to}} for UPDATE, full row for CREATE/DELETE
  createdAt DateTime @default(now())

  @@index([category, createdAt])
  @@index([model, recordId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// WEIGHMENT AUDIT EVENT
// Cross-system audit log for safety-rule overrides + soft-confirms at the
// weighbridge. Factory server records locally first (WeighmentAuditQueue),
// then syncWorker pushes to this cloud table. Visible at /admin/weighbridge-audit.
// Event types: SCALE_NOT_ZERO_OVERRIDE, DELTA_CONFIRMED, INTERVAL_OVERRIDE,
// DUPLICATE_OVERRIDE. Add new types as new rules ship — column is free-form.
// ═══════════════════════════════════════════════
model WeighmentAuditEvent {
  id               String   @id @default(uuid())
  factoryEventId   String   @unique // factory-side UUID, idempotency key
  eventType        String // SCALE_NOT_ZERO_OVERRIDE | DELTA_CONFIRMED | INTERVAL_OVERRIDE | DUPLICATE_OVERRIDE
  ruleKey          String? // BusinessRule.key that triggered the event (null if not rule-based)
  weighmentLocalId String // factory Weighment.localId — links to GrainTruck/DispatchTruck via remarks
  ticketNo         Int? // snapshot for readability
  vehicleNo        String? // snapshot
  pcId             String? // which scale was used
  action           String? // GROSS | TARE | GATE_ENTRY
  newWeight        Float? // weight that was being captured
  prevWeight       Float? // weight it was compared against
  liveScaleWeight  Float? // live scale reading at capture time (R1 only)
  thresholdKg      Float? // rule threshold at the time
  message          String? // operator-facing message that was shown
  confirmedBy      String // factory user.name who clicked confirm/override
  confirmReason    String? // optional free-text reason
  occurredAt       DateTime // when the event happened on factory
  receivedAt       DateTime @default(now()) // when cloud received it
  rawPayload       Json? // full payload for forensics

  @@index([eventType])
  @@index([weighmentLocalId])
  @@index([occurredAt])
  @@index([ticketNo])
}

// ─────────────────────────────────────────────────────────────────────────
// PROJECT PURCHASES — capex / asset / hardware projects
// Multi-quotation workflow: upload N vendor quotes → AI parse + compare →
// award winner → auto-generate PO. Keeps regular PO flow simple.
// ─────────────────────────────────────────────────────────────────────────
model ProjectPurchase {
  id                      String            @id @default(uuid())
  projectNo               Int               @default(autoincrement())
  name                    String // e.g. "Coal Crusher 20 TPH"
  description             String?
  category                String? // MECHANICAL | CIVIL | ELECTRICAL | INSTRUMENTATION | IT | OTHER
  scopeOfWork             String? // free-text scope / RFQ text
  budgetAmount            Float             @default(0)
  currency                String            @default("INR")
  targetDate              DateTime? // desired completion / delivery date
  status                  String            @default("DRAFT") // DRAFT | COLLECTING_QUOTES | UNDER_EVALUATION | AWARDED | PO_RAISED | COMPLETED | CANCELLED
  awardedQuotationId      String?           @unique
  awardedQuotation        ProjectQuotation? @relation("AwardedQuote", fields: [awardedQuotationId], references: [id])
  awardedAt               DateTime?
  awardedBy               String? // user.id
  awardReason             String? // why this quote was picked
  // Post-award negotiation (oral discussions before PO is raised)
  negotiatedTotal         Float? // final negotiated amount user agreed with vendor
  negotiationNotes        String? // what was negotiated (discount, extras, etc.)
  // What does the negotiated amount include? (drives PO breakdown)
  negotiationInclGst      Boolean           @default(true)
  negotiationInclFreight  Boolean           @default(true)
  negotiationInclErection Boolean           @default(true)
  aiAnalysis              Json? // cached AI comparison summary (criteria, ranking, pros/cons)
  aiAnalysisAt            DateTime?
  remarks                 String?
  division                String?           @default("ETHANOL")
  companyId               String?
  company                 Company?          @relation(fields: [companyId], references: [id])
  userId                  String
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  quotations ProjectQuotation[] @relation("ProjectQuotes")
  po         PurchaseOrder?

  @@index([status])
  @@index([companyId])
  @@index([division])
}

model ProjectQuotation {
  id             String          @id @default(uuid())
  projectId      String
  project        ProjectPurchase @relation("ProjectQuotes", fields: [projectId], references: [id], onDelete: Cascade)
  vendorId       String? // may not match existing vendor yet
  vendor         Vendor?         @relation(fields: [vendorId], references: [id])
  vendorNameRaw  String? // name as extracted from quote
  vendorContact  String? // extracted contact (email / phone) from quote
  quotationNo    String?
  quotationDate  DateTime?
  validityDays   Int? // how many days the quote is valid
  deliveryPeriod String? // free text "15 days", "4 weeks"
  warranty       String? // e.g. "12 months on-site"
  paymentTerms   String? // e.g. "50% advance, 50% on delivery"
  // Totals
  subtotal       Float           @default(0)
  gstAmount      Float           @default(0)
  freight        Float           @default(0)
  otherCharges   Float           @default(0)
  totalAmount    Float           @default(0)
  currency       String          @default("INR")
  // File
  fileUrl        String // path to uploaded PDF/image
  fileName       String?
  mimeType       String?
  fileSize       Int?
  // AI parse state
  extractedJson  Json? // full Gemini extraction
  parsedAt       DateTime?
  parseStatus    String          @default("PENDING") // PENDING | PARSING | PARSED | FAILED | MANUAL
  parseError     String?
  // Evaluation
  aiScore        Float? // 0-100 AI-derived comparison score
  aiNotes        String? // why this quote stands out
  manualNotes    String?
  isAwarded      Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  lineItems  ProjectQuotationLine[]
  awardedFor ProjectPurchase?       @relation("AwardedQuote")

  @@index([projectId])
  @@index([vendorId])
  @@index([parseStatus])
}

model ProjectQuotationLine {
  id            String           @id @default(uuid())
  quotationId   String
  quotation     ProjectQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  lineNo        Int              @default(1)
  description   String
  specification String?
  make          String? // brand / make from quote
  model         String?
  quantity      Float            @default(1)
  unit          String           @default("NOS")
  rate          Float            @default(0)
  amount        Float            @default(0)
  hsnSac        String?
  gstPercent    Float            @default(0)
  remarks       String?

  @@index([quotationId])
}

// ── AI call audit trail — every call to an AI provider (Gemini today, future
// OpenAI/Anthropic) writes one row. Powers the Settings → AI Usage page so
// we can see which features burn the most tokens, which are failing, and
// what the running cost is. Append-only.
model AiCallLog {
  id               String   @id @default(cuid())
  feature          String // "rfq-extraction" | "telegram-image" | "ai-chat" | etc
  provider         String   @default("gemini") // gemini | openai | anthropic
  model            String // e.g. "gemini-3-flash-preview"
  userId           String? // Who triggered (if user-facing); null for background pollers
  contextRef       String? // Free-form key for the entity this call relates to (vrId, indentId, chatId, etc)
  inputTokens      Int      @default(0)
  outputTokens     Int      @default(0)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  estimatedCostInr Float    @default(0)
  durationMs       Int      @default(0)
  success          Boolean
  errorMessage     String?
  metadata         Json     @default("{}") // feature-specific extras (filename, confidence, etc)
  createdAt        DateTime @default(now())

  @@index([feature, createdAt])
  @@index([model])
  @@index([userId])
  @@index([success])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// ATTENDANCE & LEAVE — added 2026-05-06
// Plant attendance via biometric device (eSSL X990) push or manual
// entry. AttendancePunch = raw events. AttendanceDay = derived per-day
// status, overrideable. Leave plugs into the generic Approval framework
// (type=LEAVE_APPLICATION) for the bell-badge / approve UI.
// ══════════════════════════════════════════════════════════════

model Shift {
  id              String   @id @default(cuid())
  code            String   @unique // A, B, C, GEN
  name            String // "Shift A (Morning)"
  startTime       String // "06:00" 24h HH:MM
  endTime         String // "14:00"
  graceMinutes    Int      @default(15) // late = first IN > start + grace
  earlyOutMinutes Int      @default(15) // early = last OUT < end - earlyOutMinutes
  hours           Float    @default(8) // nominal shift length, used for halfday compare
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  employeesDefault Employee[]
  attendanceDays   AttendanceDay[]

  @@index([active])
  @@index([companyId])
}

model AttendancePunch {
  id            String       @id @default(cuid())
  // Polymorphic subject — exactly one of employeeId or laborWorkerId is set.
  // Enforced at write-time in the route handler (pull-punches / device-push).
  employeeId    String?
  employee      Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  laborWorkerId String?
  laborWorker   LaborWorker? @relation(fields: [laborWorkerId], references: [id], onDelete: Cascade)
  punchAt       DateTime // UTC instant of the punch (device emits IST string, server parses to UTC)
  direction     String       @default("AUTO") // IN | OUT | AUTO (eSSL devices often don't distinguish — first of day = IN, last = OUT)
  source        String       @default("DEVICE") // DEVICE | MANUAL | IMPORT
  deviceId      String? // eSSL serial / location identifier
  rawEmpCode    String? // empCode/workerCode at time of punch (audit trail)
  notes         String?
  createdBy     String? // userId for manual entries
  createdAt     DateTime     @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([employeeId, punchAt])
  @@index([laborWorkerId, punchAt])
  @@index([punchAt])
  @@index([deviceId, punchAt])
  @@index([source])
  @@index([companyId])
}

model AttendanceDay {
  id                 String            @id @default(cuid())
  employeeId         String
  employee           Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date               DateTime          @db.Date
  shiftId            String?
  shift              Shift?            @relation(fields: [shiftId], references: [id])
  status             String // PRESENT | ABSENT | HALF_DAY | LATE | EARLY_OUT | LEAVE | WEEKLY_OFF | HOLIDAY
  firstPunchAt       DateTime?
  lastPunchAt        DateTime?
  hoursWorked        Float?
  lateMinutes        Int?
  earlyOutMinutes    Int?
  // If status = LEAVE, link to the approved application (paid/unpaid resolved via leaveType)
  leaveApplicationId String?
  leaveApplication   LeaveApplication? @relation(fields: [leaveApplicationId], references: [id])
  // Manual override metadata
  manualOverride     Boolean           @default(false)
  overrideReason     String?
  overrideBy         String?
  overrideAt         DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@index([shiftId])
  @@index([leaveApplicationId])
  @@index([companyId])
}

model LeaveType {
  id                       String   @id @default(cuid())
  code                     String   @unique // CL, SL, EL, ML, COMP_OFF, LWP
  name                     String
  paid                     Boolean  @default(true) // false = LWP (loss of pay)
  defaultAnnualEntitlement Float    @default(0) // days/year (informational; balance ledger comes later)
  active                   Boolean  @default(true)
  sortOrder                Int      @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  applications LeaveApplication[]

  @@index([active])
}

model LeaveApplication {
  id            String    @id @default(cuid())
  appNo         Int       @unique @default(autoincrement())
  employeeId    String
  employee      Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId   String
  leaveType     LeaveType @relation(fields: [leaveTypeId], references: [id])
  fromDate      DateTime  @db.Date
  toDate        DateTime  @db.Date
  days          Float // half-day support (0.5)
  isHalfDay     Boolean   @default(false)
  reason        String
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  attachmentUrl String?

  // Approval audit (set when generic Approval is reviewed)
  appliedAt  DateTime  @default(now())
  appliedBy  String // userId of applicant (usually employee's user account)
  reviewedBy String?
  reviewedAt DateTime?
  reviewNote String?

  // Back-link: AttendanceDay rows generated when approved
  attendanceDays AttendanceDay[]

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([employeeId, status])
  @@index([fromDate, toDate])
  @@index([status])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// BIOMETRIC DEVICES — added 2026-05-06 (Phase A)
// One row per physical device on plant LAN (eSSL X990, ZKTeco, etc.).
// Cloud backend never talks to devices directly; it talks to a
// biometric-bridge HTTP service running on factory-server (or this Mac
// during dev), which uses pyzk to reach devices on TCP port 4370.
// ══════════════════════════════════════════════════════════════

model BiometricDevice {
  id              String    @id @default(cuid())
  code            String    @unique // GATE_MAIN, DISTILLERY_GATE, etc.
  name            String
  location        String?
  ip              String
  port            Int       @default(4370)
  password        Int       @default(0) // device comm password if set on device
  // Auto-captured on first connect
  serialNumber    String?
  firmware        String?
  platform        String?
  // Sync state
  active          Boolean   @default(true)
  lastSyncAt      DateTime? // last successful user-list sync
  lastSyncStatus  String? // OK | ERROR | NEVER
  lastSyncError   String?
  lastPunchSyncAt DateTime? // last successful punch-pull
  // Auto-sync intervals (0 = disabled)
  autoPullMinutes Int       @default(0) // pull-punches interval; 0 = manual only
  autoPushMinutes Int       @default(0) // sync-employees interval; 0 = manual only
  lastAutoPullAt  DateTime? // last automatic pull-punches run
  lastAutoPushAt  DateTime? // last automatic sync-employees run
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([active])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// LABOR WORKERS — added 2026-05-06 (Phase 2)
//
// Distinct from Employee (different lifecycle: turnover, paid via
// contractor, no salary structure, no payroll line). Belongs to a
// Contractor (labor supplier) and optionally to a manpower-supply
// WorkOrder. Same biometric mapping pattern as Employee — deviceUserId
// on this row routes punches to AttendancePunch.laborWorkerId.
// ══════════════════════════════════════════════════════════════

model LaborWorker {
  id         String @id @default(cuid())
  workerCode String @unique // e.g., LW-001
  workerNo   Int    @unique @default(autoincrement())

  firstName  String
  lastName   String?
  fatherName String?
  phone      String?
  aadhaar    String?

  // Belongs to a contractor (labor supplier) — required
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id])

  // Optionally tied to a specific manpower-supply Work Order
  workOrderId String?
  workOrder   WorkOrder? @relation(fields: [workOrderId], references: [id])

  skillCategory String? // UNSKILLED | SEMI_SKILLED | SKILLED — matches WO rate-card
  dailyRate     Float? // ₹ per day, snapshot from WO rate-card

  // Biometric mapping — same field as Employee.deviceUserId, same value space
  // across all configured devices.
  deviceUserId String?
  cardNumber   String?

  isActive Boolean  @default(true)
  joinedAt DateTime @default(now())
  remarks  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  attendancePunches AttendancePunch[]

  @@index([contractorId])
  @@index([workOrderId])
  @@index([deviceUserId])
  @@index([isActive])
  @@index([companyId])
  @@index([skillCategory])
}
