// ═══════════════════════════════════════════════
// ETHANOL PRODUCT & DISPATCH
// ═══════════════════════════════════════════════
model EthanolProductEntry {
  id              String          @id @default(uuid())
  date            DateTime
  yearStart       Int
  // 9 tanks: current DIP, LT%, Strength%, Volume (BL)
  recADip         Float?
  recALt          Float?
  recAStrength    Float?
  recAVolume      Float?
  recBDip         Float?
  recBLt          Float?
  recBStrength    Float?
  recBVolume      Float?
  recCDip         Float?
  recCLt          Float?
  recCStrength    Float?
  recCVolume      Float?
  issADip         Float?
  issALt          Float?
  issAStrength    Float?
  issAVolume      Float?
  issBDip         Float?
  issBLt          Float?
  issBStrength    Float?
  issBVolume      Float?
  issCDip         Float?
  issCLt          Float?
  issCStrength    Float?
  issCVolume      Float?
  bulkADip        Float?
  bulkALt         Float?
  bulkAStrength   Float?
  bulkAVolume     Float?
  bulkBDip        Float?
  bulkBLt         Float?
  bulkBStrength   Float?
  bulkBVolume     Float?
  bulkCDip        Float?
  bulkCLt         Float?
  bulkCStrength   Float?
  bulkCVolume     Float?
  // Dispatch Tank
  dispDip         Float?
  dispLt          Float?
  dispStrength    Float?
  dispVolume      Float?
  // RS / HFO / LFO tanks (15 M3 each) — current levels as %
  rsLevel         Float?
  hfoLevel        Float?
  lfoLevel        Float?
  // Computed / summary fields
  totalStock      Float           @default(0) // sum of all 9 tank volumes
  avgStrength     Float           @default(0) // weighted average strength
  totalDispatch   Float           @default(0) // sum of all truck dispatch BL
  productionBL    Float           @default(0) // currentStock - prevStock + dispatch
  productionAL    Float           @default(0) // productionBL × avgStrength / 100
  klpd            Float           @default(0) // kilolitres per day flow rate
  // Grain consumption — snapshotted from OPC at dip time
  washTotalizer   Float? // DCS cumulative totalizer (MG_140101 CURRENT) at dip time
  washKL          Float? // wash flow delta between prev dip and this dip
  grainConsumedMT Float? // washKL × grainPct
  yieldALperMT    Float? // productionAL / grainConsumedMT
  grainPctUsed    Float? // grain% setting at time of calculation
  remarks         String?
  userId          String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  trucks          DispatchTruck[]

  @@index([date])
  @@index([yearStart, date])
}

model DispatchTruck {
  id                String               @id @default(uuid())
  entryId           String?
  entry             EthanolProductEntry? @relation(fields: [entryId], references: [id], onDelete: Cascade)
  date              DateTime             @default(now())
  vehicleNo         String               @default("")
  partyName         String               @default("")
  destination       String               @default("")
  batchNo           String               @default("")
  quantityBL        Float                @default(0)
  strength          Float?
  photoUrl          String?
  remarks           String?
  userId            String?
  // Link to contract + lifting (auto-created on dispatch)
  contractId        String?
  contract          EthanolContract?     @relation(fields: [contractId], references: [id])
  liftingId         String?              @unique
  lifting           EthanolLifting?      @relation(fields: [liftingId], references: [id])
  // Driver/transport info for e-way bill
  driverName        String?
  driverPhone       String?
  driverLicense     String? // DL No
  transporterName   String?
  distanceKm        Int?
  rstNo             String? // RST / Receipt number
  sealNo            String? // Tank seal number
  pesoDate          String? // Peso calibration date
  // Gate pass + weighbridge fields
  status            String               @default("GATE_IN") // GATE_IN, TARE_WEIGHED, LOADING, GROSS_WEIGHED, RELEASED
  weightGross       Float? // KG
  weightTare        Float? // KG
  weightNet         Float? // KG (gross - tare, for density verification)
  gateInTime        DateTime?
  tareTime          DateTime?
  grossTime         DateTime?
  releaseTime       DateTime?
  gatePassNo        String?
  challanNo         String? // Delivery challan number
  sourceWbId        String?              @unique // link to weighbridge record for dedup (CRITICAL for idempotency)
  productRatePerLtr Float? // Product value rate (e.g. 71.86/Ltr)
  productValue      Float? // Total product value (qty × productRate)
  // Ship-To (differs from Bill-To for job work; snapshot at gate entry)
  shipToCustomerId  String?
  shipToCustomer    Customer?            @relation("DispatchTruckShipTo", fields: [shipToCustomerId], references: [id])
  shipToName        String?
  shipToGstin       String?
  shipToAddress     String?
  shipToState       String?
  shipToPincode     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @default(now()) @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([entryId])
  @@index([contractId])
  @@index([status])
  @@index([shipToCustomerId])
  @@index([division])
}

// Per-truck grain unloading (real-time)
model GrainTruck {
  id               String         @id @default(uuid())
  date             DateTime       @default(now())
  uidRst           String         @default("") // UID/RST tracking number for lab analysis
  vehicleNo        String         @default("")
  supplier         String         @default("")
  weightGross      Float          @default(0)
  weightTare       Float          @default(0)
  weightNet        Float          @default(0) // gross - tare
  quarantineWeight Float          @default(0) // partial reject weight (T) — in quarantine, not silo
  moisture         Float?
  starchPercent    Float?
  damagedPercent   Float?
  foreignMatter    Float?
  quarantine       Boolean        @default(false) // true = has quarantine portion
  quarantineReason String?
  bags             Float? // number of bags in truck
  remarks          String?
  photoUrl         String?
  userId           String?
  // Traceability FKs (set by weighbridge push)
  poId             String? // FK → PurchaseOrder (which deal)
  purchaseOrder    PurchaseOrder? @relation(fields: [poId], references: [id])
  grnId            String? // FK → GoodsReceipt (auto-created GRN)
  goodsReceipt     GoodsReceipt?  @relation(fields: [grnId], references: [id])
  labSampleId      String? // FK → LabSample (lab result)
  labSample        LabSample?     @relation(fields: [labSampleId], references: [id])
  materialId       String? // FK → InventoryItem (what was delivered)
  // Fields from weighbridge push (previously dropped)
  vehicleType      String? // TRUCK_12, TRACTOR, etc.
  driverName       String?
  driverMobile     String?
  transporterName  String?
  materialType     String? // BROKEN_RICE, RICE_HUSK, MAIZE etc.
  ticketNo         Int? // weighbridge ticket number
  factoryLocalId   String?        @unique // factory-server Weighment.localId (dedup key — UNIQUE to prevent duplicate rows on concurrent push)
  cancelled        Boolean        @default(false) // soft-cancel flag set by admin correction
  cancelledReason  String?
  cancelledAt      DateTime?
  cancelledBy      String?
  createdAt        DateTime       @default(now())
  // Timestamp trail from factory Weighment (mirrored for reporting/analytics)
  gateEntryAt      DateTime? // when the truck entered the gate (Weighment.gateEntryAt)
  firstWeightAt    DateTime? // first weighbridge reading (Weighment.firstWeightAt)
  secondWeightAt   DateTime? // second weighbridge reading (Weighment.secondWeightAt)
  releaseAt        DateTime? // when the truck was released (future — factory doesn't track yet)

  division    String?               @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId   String? // FK → Company (null = MSPIL default)
  company     Company?              @relation(fields: [companyId], references: [id])
  corrections WeighmentCorrection[]

  @@index([date])
  @@index([poId])
  @@index([grnId])
  @@index([ticketNo])
  @@index([division])
  @@index([gateEntryAt])
  @@index([companyId])
  @@index([firstWeightAt])
  @@index([materialId])
}

// ═══════════════════════════════════════════════
// WEIGHMENT CORRECTIONS — Admin audit trail
// See .claude/skills/weighment-corrections.md for full spec.
// ═══════════════════════════════════════════════
model WeighmentCorrection {
  id              String      @id @default(uuid())
  weighmentKind   String // "GrainTruck" | "DispatchTruck"
  weighmentId     String // FK-like to GrainTruck.id or DispatchTruck.id
  grainTruck      GrainTruck? @relation(fields: [weighmentId], references: [id], map: "WeighmentCorrection_grainTruck_fkey")
  ticketNo        Int? // snapshot for readability
  vehicleNo       String? // snapshot
  fieldName       String // "materialType" | "supplier" | "poId" | "cancel" | ...
  oldValue        String? // JSON stringified
  newValue        String? // JSON stringified
  reason          String // mandatory, min 10 chars enforced at API
  correctedBy     String // user.name
  correctedByRole String // user.role
  adminPinUsed    Boolean     @default(false)
  factorySynced   Boolean     @default(false)
  factorySyncedAt DateTime?
  factoryError    String?
  createdAt       DateTime    @default(now())

  @@index([weighmentId])
  @@index([createdAt])
  @@index([ticketNo])
  @@index([factorySynced])
}

// ═══════════════════════════════════════════════
// LAB SAMPLES — linked to trucks via RST number
// ═══════════════════════════════════════════════
model LabSample {
  id             String       @id @default(uuid())
  rstNumber      String       @unique // links to GrainTruck.uidRst
  date           DateTime     @default(now())
  moisture       Float?
  starchPercent  Float?
  damagedPercent Float?
  foreignMatter  Float?
  fungus         Float?
  immature       Float?
  waterDamaged   Float?
  tfm            Float? // total foreign matter
  remarks        String?
  result         String       @default("PENDING") // PENDING, ACCEPTED, REJECTED
  userId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  grainTrucks    GrainTruck[]

  @@index([date])
  @@index([result])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  changes   String
  userId    String
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([userId])
  @@index([action])
}

// ═══════════════════════════════════════════════
// INVENTORY & STORE
// ═══════════════════════════════════════════════
model InventoryItem {
  id                      String                    @id @default(uuid())
  name                    String
  code                    String                    @unique // SKU / part code
  category                String                    @default("RAW_MATERIAL") // RAW_MATERIAL, SPARE_PART, CONSUMABLE, CHEMICAL, FINISHED_GOOD, OTHER
  unit                    String                    @default("kg") // kg, ltr, nos, mtr, set
  currentStock            Float                     @default(0)
  minStock                Float                     @default(0) // reorder point
  maxStock                Float? // max storage
  costPerUnit             Float                     @default(0)
  location                String? // bin/rack location
  supplier                String?
  leadTimeDays            Int?
  isActive                Boolean                   @default(true)
  remarks                 String?
  // SAP-style fields
  hsnCode                 String? // legacy — kept for backfill fallback; new code reads hsnCodeRef
  gstPercent              Float                     @default(18) // legacy cache — authoritative rate lives on GstRate via hsnCodeRef
  // Phase-A tax unification (2026-04-14): link to HsnCode + GstRate master
  hsnCodeId               String?
  hsnCodeRef              HsnCode?                  @relation(fields: [hsnCodeId], references: [id])
  gstOverridePercent      Float? // rare: per-item statutory override (e.g. Notification 2/2017 unbranded)
  gstOverrideReason       String? // required when gstOverridePercent is set
  valuationMethod         String                    @default("WEIGHTED_AVG") // WEIGHTED_AVG, FIFO, STANDARD
  avgCost                 Float                     @default(0) // weighted average cost
  totalValue              Float                     @default(0) // currentStock × avgCost
  batchTracked            Boolean                   @default(false)
  // Procurement fields (merged from Material)
  subCategory             String? // e.g., ENZYME, YEAST, ACID
  defaultRate             Float                     @default(0) // last/standard purchase rate
  // Fuel-specific fields (only used when category = 'FUEL')
  steamRate               Float? // tons of steam per ton of fuel (e.g., 3.0 for rice husk)
  calorificValue          Float? // kcal/kg (optional reference)
  // Multi-division routing (Stage 2): drives factory gate-entry dropdown + cloud detectHandler
  aliases                 String[]                  @default([]) // alternate names operators may type ("DI", "ductile iron", "ms", "iron scrap")
  handlerKey              String? // optional override for cloud detectHandler — null = route by category/division
  isContractBased         Boolean                   @default(false) // if true, gate entry must pick a contract
  needsLabTest            Boolean                   @default(false) // if true, factory blocks gross weighment until lab passes
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  transactions            InventoryTransaction[]
  batches                 Batch[]
  stockLevels             StockLevel[]
  stockMovements          StockMovement[]
  reorderRule             ReorderRule?
  poLines                 POLine[]
  grnLines                GRNLine[]
  vendorItems             VendorItem[]
  fuelConsumptions        FuelConsumption[]
  rawMaterialConsumptions RawMaterialConsumption[]
  indentLines             PurchaseRequisitionLine[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([category])
  @@index([division])
  @@index([companyId])
  @@index([hsnCodeId])
}

model InventoryTransaction {
  id         String        @id @default(uuid())
  itemId     String
  item       InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type       String // IN, OUT, ADJUST
  quantity   Float
  reference  String? // PO number, issue ID, batch number, etc.
  remarks    String?
  warehouse  String? // which warehouse (for Stock IN)
  department String? // which department (for Stock OUT)
  issuedTo   String? // person name who received the item
  userId     String
  createdAt  DateTime      @default(now())

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
}

// ── Fuel Consumption (daily entry per fuel type) ──
model FuelConsumption {
  id             String        @id @default(uuid())
  date           DateTime
  fuelItemId     String
  fuelItem       InventoryItem @relation(fields: [fuelItemId], references: [id])
  openingStock   Float         @default(0) // MT at start of day
  received       Float         @default(0) // received from weighbridge/GRN
  consumed       Float         @default(0) // used in boiler
  closingStock   Float         @default(0) // opening + received - consumed
  steamGenerated Float         @default(0) // consumed × steamRate
  remarks        String?
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([date, fuelItemId])
  @@index([date])
  @@index([fuelItemId])
}

// ── Raw Material Consumption (daily entry per RM item) ──
model RawMaterialConsumption {
  id             String        @id @default(uuid())
  date           DateTime
  materialItemId String
  materialItem   InventoryItem @relation(fields: [materialItemId], references: [id])
  openingStock   Float         @default(0)
  received       Float         @default(0)
  consumed       Float         @default(0)
  closingStock   Float         @default(0)
  remarks        String?
  userId         String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([date, materialItemId])
  @@index([date])
  @@index([materialItemId])
}

// ── Business Division Master (Ethanol / Sugar / Power / Co-Gen / Bio-CNG) ──
// A single Company (MSPIL) runs multiple business divisions. Each department
// belongs to one division. Helps scope indents, reports, and P&L per division.
model BusinessDivision {
  id          String       @id @default(cuid())
  name        String // "Ethanol", "Sugar", "Power", "Co-Gen", "Bio-CNG"
  code        String? // Short code: ETH, SUG, PWR, COG, CBG
  description String?
  isActive    Boolean      @default(true)
  companyId   String? // FK → Company (null = MSPIL default)
  company     Company?     @relation(fields: [companyId], references: [id])
  departments Department[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([name, companyId])
  @@index([companyId])
}

// ── Department Master ──
model Department {
  id                 String            @id @default(cuid())
  name               String            @unique
  code               String?
  isActive           Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  employees          Employee[]
  companyId          String? // FK → Company (null = MSPIL default)
  company            Company?          @relation(fields: [companyId], references: [id])
  businessDivisionId String? // FK → BusinessDivision (null = cross-division / legacy rows)
  businessDivision   BusinessDivision? @relation(fields: [businessDivisionId], references: [id])

  @@index([companyId])
  @@index([businessDivisionId])
}

// ── Warehouse / Storage Location ──
model Warehouse {
  id          String          @id @default(cuid())
  code        String          @unique // MAIN, CHEM, SPARE, YARD, GRAIN
  name        String
  address     String?
  isActive    Boolean         @default(true)
  bins        StorageBin[]
  stockLevels StockLevel[]
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  companyId   String? // FK → Company (null = MSPIL default)
  company     Company?        @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ── Bin / Rack Location within Warehouse ──
model StorageBin {
  id          String       @id @default(cuid())
  warehouseId String
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id])
  code        String // A-01-01 (Aisle-Rack-Shelf)
  name        String?
  capacity    Float? // max capacity in base UOM
  isActive    Boolean      @default(true)
  stockLevels StockLevel[]
  createdAt   DateTime     @default(now())

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

// ── Batch / Lot Tracking ──
model Batch {
  id          String          @id @default(cuid())
  itemId      String
  item        InventoryItem   @relation(fields: [itemId], references: [id])
  batchNo     String
  mfgDate     DateTime?
  expiryDate  DateTime?
  supplier    String?
  grnId       String? // link to GoodsReceipt
  costRate    Float           @default(0)
  status      String          @default("AVAILABLE") // AVAILABLE, QUARANTINE, EXPIRED, CONSUMED
  remarks     String?
  createdAt   DateTime        @default(now())
  stockLevels StockLevel[]
  movements   StockMovement[]

  @@unique([itemId, batchNo])
  @@index([itemId])
  @@index([expiryDate])
  @@index([status])
}

// ── Stock Level (item × warehouse × bin × batch) ──
model StockLevel {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  warehouseId String
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  binId       String?
  bin         StorageBin?   @relation(fields: [binId], references: [id])
  batchId     String?
  batch       Batch?        @relation(fields: [batchId], references: [id])
  quantity    Float         @default(0)
  reservedQty Float         @default(0)
  updatedAt   DateTime      @updatedAt
  companyId   String? // FK → Company (null = MSPIL default)
  company     Company?      @relation(fields: [companyId], references: [id])

  @@unique([itemId, warehouseId, binId, batchId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([batchId])
  @@index([companyId])
}

// ── Stock Movement (every IN/OUT/TRANSFER/ADJUST) ──
model StockMovement {
  id            String        @id @default(cuid())
  movementNo    Int           @unique @default(autoincrement())
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id])
  movementType  String // GRN_RECEIPT, PRODUCTION_ISSUE, PRODUCTION_RECEIPT, SALES_ISSUE, TRANSFER, ADJUSTMENT, RETURN, SCRAP
  direction     String // IN, OUT
  quantity      Float
  unit          String
  costRate      Float         @default(0)
  totalValue    Float         @default(0)
  warehouseId   String
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id])
  binId         String?
  batchId       String?
  batch         Batch?        @relation(fields: [batchId], references: [id])
  toWarehouseId String?
  toBinId       String?
  refType       String? // GRN, PO, SALES_ORDER, PRODUCTION_ORDER, MANUAL
  refId         String?
  refNo         String?
  narration     String?
  userId        String
  date          DateTime      @default(now())
  createdAt     DateTime      @default(now())

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([itemId, date])
  @@index([warehouseId])
  @@index([movementType])
  @@index([refType, refId])
  @@index([date])
  @@index([division])
  @@index([companyId])
}

// ── Stock Count / Physical Inventory ──
model StockCount {
  id          String           @id @default(cuid())
  countNo     Int              @unique @default(autoincrement())
  warehouseId String
  countDate   DateTime
  status      String           @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, APPROVED
  countType   String           @default("FULL") // FULL, CYCLE, SPOT
  remarks     String?
  lines       StockCountLine[]
  userId      String
  approvedBy  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([warehouseId])
  @@index([status])
}

model StockCountLine {
  id             String     @id @default(cuid())
  countId        String
  count          StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  itemId         String
  batchId        String?
  binId          String?
  systemQty      Float
  physicalQty    Float?
  variance       Float?
  variancePct    Float?
  adjustmentDone Boolean    @default(false)
  remarks        String?

  @@index([countId])
  @@index([itemId])
}

// ── Reorder Rule ──
model ReorderRule {
  id            String        @id @default(cuid())
  itemId        String        @unique
  item          InventoryItem @relation(fields: [itemId], references: [id])
  reorderPoint  Float
  reorderQty    Float
  maxStock      Float?
  safetyStock   Float         @default(0)
  leadTimeDays  Int           @default(7)
  autoCreate    Boolean       @default(false)
  isActive      Boolean       @default(true)
  lastTriggered DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([itemId])
}

// ═══════════════════════════════════════════════
// PLANT ISSUES (Maintenance / Breakdown)
// ═══════════════════════════════════════════════
model PlantIssue {
  id            String         @id @default(uuid())
  issueNo       Int            @default(autoincrement())
  title         String
  description   String
  issueType     String         @default("MECHANICAL") // MECHANICAL, ELECTRICAL, INSTRUMENTATION, CIVIL, SAFETY, OTHER
  severity      String         @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW
  equipment     String? // which equipment/area
  location      String? // plant area
  status        String         @default("OPEN") // OPEN, ASSIGNED, IN_PROGRESS, RESOLVED, CLOSED
  assignedTo    String? // user name or ID
  resolvedAt    DateTime?
  resolution    String?
  partsUsed     String? // JSON or comma-separated
  downtimeHours Float?
  photoUrl      String?
  reportedBy    String
  userId        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  comments      IssueComment[]

  division String? @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON

  @@index([status])
  @@index([division])
  @@index([issueType])
  @@index([severity])
  @@index([createdAt])
}

model IssueComment {
  id        String     @id @default(uuid())
  issueId   String
  issue     PlantIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  message   String
  userId    String
  userName  String
  createdAt DateTime   @default(now())
}

// ═══════════════════════════════════════════════
// PURCHASE REQUISITION
// ═══════════════════════════════════════════════
model PurchaseRequisition {
  id                String    @id @default(uuid())
  reqNo             Int       @default(autoincrement())
  title             String
  itemName          String
  quantity          Float     @default(1)
  unit              String    @default("nos")
  estimatedCost     Float     @default(0)
  urgency           String    @default("ROUTINE") // ROUTINE, SOON, URGENT, EMERGENCY
  category          String    @default("GENERAL") // SPARE_PART, RAW_MATERIAL, CONSUMABLE, TOOL, SAFETY, CHEMICAL, MECHANICAL, ELECTRICAL, GENERAL
  justification     String?
  linkedIssueId     String? // optional link to PlantIssue
  supplier          String? // preferred supplier
  status            String    @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, PO_PENDING, ORDERED, RECEIVED, COMPLETED
  approvedBy        String?
  approvedAt        DateTime?
  rejectionReason   String?
  remarks           String?
  requestedBy       String
  userId            String
  // Warehouse split fields
  inventoryItemId   String? // FK to InventoryItem (if linked)
  department        String? // requesting department
  requestedByPerson String? // person name who needs the item
  issuedQty         Float     @default(0) // qty issued from warehouse stock
  purchaseQty       Float     @default(0) // qty that needs external purchase
  issuedBy          String? // warehouse person who issued
  issuedAt          DateTime? // when warehouse issued stock
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // ── Quote / Vendor Tracking (one vendor per indent) ──
  vendorId            String? // FK → Vendor for the quote / PO
  vendor              Vendor?   @relation("VendorIndents", fields: [vendorId], references: [id])
  quoteRequestedAt    DateTime? // when we emailed / asked vendor for quote
  quoteRequestedBy    String? // user name who triggered the quote request
  quoteEmailSubject   String? // subject line used in the quote request email
  quoteEmailThreadId  String? // Gmail thread id — used to match replies
  quoteEmailMessageId String? // Gmail message id of the sent request
  vendorRate          Float? // rate quoted by the vendor (manual or AI-extracted)
  vendorQuotedAt      DateTime? // when rate was entered / extracted
  quoteSource         String? // MANUAL | EMAIL_AUTO | PHONE | WHATSAPP
  quoteRemarks        String? // free-text notes on the quote

  purchaseOrders PurchaseOrder[] // auto-generated POs from this indent
  quotes         PurchaseRequisitionVendor[] // one row per vendor we're asking for a quote from
  lines          PurchaseRequisitionLine[] // multi-item indents — 1+ items in the same request
  companyId      String? // FK → Company (null = MSPIL default)
  company        Company?                    @relation(fields: [companyId], references: [id])

  @@index([status])
  @@index([urgency])
  @@index([userId])
  @@index([inventoryItemId])
  @@index([companyId])
  @@index([vendorId])
  @@index([createdAt])
}

// ── Per-vendor quote row inside an indent ──
// Each indent can have many of these — one per vendor we're asking for a quote.
// When one is awarded, PurchaseRequisition.vendorId points at the winner.
model PurchaseRequisitionVendor {
  id                   String                          @id @default(cuid())
  requisitionId        String
  requisition          PurchaseRequisition             @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  vendorId             String
  vendor               Vendor                          @relation("VendorIndentQuotes", fields: [vendorId], references: [id])
  quoteRequestedAt     DateTime?
  quoteRequestedBy     String?
  quoteEmailSubject    String?
  quoteEmailThreadId   String? // gmail thread id (match replies)
  quoteEmailMessageId  String?
  vendorRate           Float? // header-level rate (sum of line totals / total qty) — kept for back-compat
  quotedAt             DateTime?
  quoteSource          String? // MANUAL | EMAIL_AUTO | EMAIL_PARTIAL | PHONE | WHATSAPP
  quoteRemarks         String?
  // ── Quote Cost Template — structured cost components extracted from the
  // vendor quote (or edited by the buyer before award). These flow to the PO
  // header on award (freight → freightCharge, rest → otherCharges). Per-line
  // discount lives on PurchaseRequisitionVendorLine.discountPercent.
  packingPercent       Float                           @default(0)
  packingAmount        Float                           @default(0)
  freightPercent       Float                           @default(0)
  freightAmount        Float                           @default(0)
  insurancePercent     Float                           @default(0)
  insuranceAmount      Float                           @default(0)
  loadingPercent       Float                           @default(0)
  loadingAmount        Float                           @default(0)
  isRateInclusiveOfGst Boolean                         @default(false)
  tcsPercent           Float                           @default(0)
  deliveryBasis        String? // EX_WORKS | FOR_DESTINATION | CIF | FOB | OTHER
  additionalCharges    Json                            @default("[]") // [{name, percent?, amount?, basis?}]
  isAwarded            Boolean                         @default(false)
  lineQuotes           PurchaseRequisitionVendorLine[]
  createdAt            DateTime                        @default(now())
  updatedAt            DateTime                        @updatedAt

  @@unique([requisitionId, vendorId])
  @@index([requisitionId])
  @@index([vendorId])
}

// ── Per-line rate from a vendor ──
// One row per (vendor × indent line). Created lazily — only when a rate is
// entered (manually or by AI). PurchaseRequisitionVendor.vendorRate is kept in
// sync as the weighted average so existing reports/awarding logic still work.
model PurchaseRequisitionVendorLine {
  id                String                    @id @default(cuid())
  vendorQuoteId     String
  vendorQuote       PurchaseRequisitionVendor @relation(fields: [vendorQuoteId], references: [id], onDelete: Cascade)
  requisitionLineId String
  requisitionLine   PurchaseRequisitionLine   @relation(fields: [requisitionLineId], references: [id], onDelete: Cascade)
  unitRate          Float?
  gstPercent        Float?
  hsnCode           String?
  // Footer/per-line discount captured from vendor quote (e.g. Gajanan's
  // "Discount - 31%"). Footer-level discounts are flattened to every line at
  // extract time so the award→PO handoff carries one value per line.
  discountPercent   Float                     @default(0)
  remarks           String?
  source            String? // MANUAL | EMAIL_AUTO
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@unique([vendorQuoteId, requisitionLineId])
  @@index([vendorQuoteId])
  @@index([requisitionLineId])
}

// ═══════════════════════════════════════════════
// EMAIL SYSTEM — polymorphic, reusable across modules
// ═══════════════════════════════════════════════

// A single email we sent FROM the ERP. One thread = one outbound message.
// Replies from the recipient are stored in EmailReply linked back.
//
// entityType + entityId is polymorphic:
//   INDENT_QUOTE  → PurchaseRequisitionVendor.id
//   PURCHASE_ORDER → PurchaseOrder.id
//   VENDOR_INVOICE → VendorInvoice.id
//   SALES_INVOICE → Invoice.id
//   PAYMENT_CONFIRMATION → VendorPayment.id
//   etc.
model EmailThread {
  id             String       @id @default(cuid())
  entityType     String // see comment above
  entityId       String
  // vendorId allows a vendor-centric view — "show every email I ever sent to
  // Vendor X across all POs/indents/invoices". Nullable because some emails
  // aren't vendor-related (internal notifications, customer emails, etc.)
  vendorId       String?
  vendor         Vendor?      @relation("VendorEmailThreads", fields: [vendorId], references: [id])
  customerId     String? // symmetric — customer-centric view for sales emails
  customer       Customer?    @relation("CustomerEmailThreads", fields: [customerId], references: [id])
  subject        String
  fromEmail      String
  fromName       String?
  toEmail        String // comma-separated allowed
  ccEmail        String?
  bccEmail       String?
  bodyText       String
  bodyHtml       String?
  messageId      String? // RFC 5322 Message-ID of the SENT message, used to match replies
  threadId       String? // provider thread id (Gmail X-GM-THRID if we can get it)
  sentAt         DateTime     @default(now())
  sentBy         String // user name / email who triggered send
  status         String       @default("SENT") // SENT | FAILED | BOUNCED | QUEUED
  errorMessage   String?
  attachments    Json? // [{filename, size, contentType, storagePath?}]
  lastCheckedAt  DateTime? // last time we pulled replies via IMAP
  replyCount     Int          @default(0)
  hasUnreadReply Boolean      @default(false)
  companyId      String?
  company        Company?     @relation(fields: [companyId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  replies        EmailReply[]

  @@index([entityType, entityId])
  @@index([vendorId])
  @@index([customerId])
  @@index([companyId])
  @@index([messageId])
  @@index([sentAt])
}

// A reply to one of our EmailThreads, fetched from IMAP and persisted.
// Persisting means the user can see the full history without re-polling.
model EmailReply {
  id                String      @id @default(cuid())
  threadId          String
  thread            EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  providerMessageId String // RFC 5322 Message-ID of the reply
  fromEmail         String
  fromName          String?
  toEmail           String?
  subject           String?
  bodyText          String
  bodyHtml          String?
  inReplyTo         String?
  refsHeaders       String? // References header, space-separated
  receivedAt        DateTime
  attachments       Json? // [{filename, size, contentType, contentBase64}]
  aiExtractedJson   Json? // structured AI extraction result if run
  aiExtractedAt     DateTime?
  aiConfidence      String? // HIGH | MEDIUM | LOW
  seenAt            DateTime? // when user first opened it in the drawer
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([threadId, providerMessageId])
  @@index([threadId])
  @@index([receivedAt])
}

// ── Indent Line — one item in a multi-item indent ──
// An indent can have many lines. The parent PurchaseRequisition keeps
// itemName/quantity/unit populated with the first line's values for
// backward-compat (existing code + reports).
model PurchaseRequisitionLine {
  id              String                          @id @default(cuid())
  requisitionId   String
  requisition     PurchaseRequisition             @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  lineNo          Int                             @default(1)
  itemName        String
  inventoryItemId String?
  inventoryItem   InventoryItem?                  @relation(fields: [inventoryItemId], references: [id])
  quantity        Float                           @default(1)
  unit            String                          @default("nos")
  estimatedCost   Float                           @default(0) // per unit
  remarks         String?
  vendorQuotes    PurchaseRequisitionVendorLine[]
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt

  @@index([requisitionId])
  @@index([inventoryItemId])
}

// ═══════════════════════════════════════════════
// SALES & DISTRIBUTION MODULE
// ═══════════════════════════════════════════════

// Master: Customer (buyer parties)
model Customer {
  id                       String               @id @default(uuid())
  name                     String
  shortName                String? // display name for lists
  address                  String?
  city                     String?
  state                    String?
  pincode                  String?
  gstNo                    String? // GSTIN
  panNo                    String?
  // ── Compliance & Tax (Phase 1) ──
  stateCode                String? // 2-digit GST state code
  placeOfSupply            String? // state code for GST PoS
  isSEZ                    Boolean              @default(false)
  isExport                 Boolean              @default(false)
  isRCMApplicable          Boolean              @default(false)
  customerType             String               @default("B2B") // B2B | B2C | SEZ | EXPORT | DEEMED_EXPORT
  contactPerson            String?
  phone                    String?
  email                    String?
  creditLimit              Float                @default(0) // max outstanding allowed (Rs)
  cautionDeposit           Float                @default(0) // caution / security deposit (Rs)
  defaultTerms             String               @default("ADVANCE") // ADVANCE, COD, NET7, NET10, NET15, NET30
  isActive                 Boolean              @default(true)
  remarks                  String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  salesOrders              SalesOrder[]
  invoices                 Invoice[]
  payments                 Payment[]
  ethanolContracts         EthanolContract[]
  ddgsContracts            DDGSContract[]
  ddgsDispatchTrucks       DDGSDispatchTruck[]  @relation("DDGSDispatchBillTo")
  ddgsDispatchTrucksShipTo DDGSDispatchTruck[]  @relation("DDGSDispatchShipTo")
  dispatchTrucksShipTo     DispatchTruck[]      @relation("DispatchTruckShipTo")
  shipmentsShipTo          Shipment[]           @relation("ShipmentShipTo")
  sugarContracts           SugarContract[]
  sugarDispatchTrucks      SugarDispatchTruck[]
  directSales              DirectSale[]
  emailThreads             EmailThread[]        @relation("CustomerEmailThreads")
  companyId                String? // FK → Company (null = MSPIL default)
  company                  Company?             @relation(fields: [companyId], references: [id])

  divisions String[] @default([]) // empty = available to all divisions

  @@index([companyId])
}

// Master: Product catalogue
model Product {
  id          String   @id @default(uuid())
  name        String   @unique // DDGS, ETHANOL, LFO, HFO, RS
  unit        String   @default("TON") // TON, KL, LTR
  hsnCode     String? // GST HSN code
  defaultRate Float    @default(0) // Rs per unit
  gstPercent  Float    @default(18) // GST %
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  companyId   String? // FK → Company (null = MSPIL default)
  company     Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// Master: Transporter
model Transporter {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String?
  email         String?
  gstin         String?
  pan           String?
  vehicleCount  Int?
  address       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  divisions String[] @default([]) // empty = available to all divisions
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ── Sales Order (HQ creates) ──
model SalesOrder {
  id               String            @id @default(uuid())
  orderNo          Int               @default(autoincrement())
  customerId       String
  customer         Customer          @relation(fields: [customerId], references: [id])
  orderDate        DateTime          @default(now())
  deliveryDate     DateTime?
  poNumber         String? // customer PO reference
  paymentTerms     String            @default("ADVANCE") // ADVANCE, COD, NET7, NET10, NET15, NET30
  logisticsBy      String            @default("BUYER") // BUYER or SELLER
  deliveryAddress  String? // delivery location / full address
  transporterId    String? // if SELLER arranges
  freightRate      Float? // Rs per ton/KL if seller pays
  status           String            @default("DRAFT") // DRAFT, CONFIRMED, IN_PROGRESS, COMPLETED, CANCELLED
  remarks          String?
  // Totals (computed from lines)
  totalAmount      Float             @default(0)
  totalGst         Float             @default(0)
  grandTotal       Float             @default(0)
  userId           String // created by
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  lines            SalesOrderLine[]
  dispatchRequests DispatchRequest[]
  invoices         Invoice[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([division])
  @@index([companyId])
  @@index([orderDate])
}

// ── Sales Order Line Items ──
model SalesOrderLine {
  id               String            @id @default(uuid())
  orderId          String
  order            SalesOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productName      String // DDGS, ETHANOL, LFO, HFO, RS
  quantity         Float // ordered qty
  unit             String            @default("TON")
  rate             Float // Rs per unit
  gstPercent       Float             @default(18)
  amount           Float             @default(0) // qty × rate
  gstAmount        Float             @default(0)
  totalAmount      Float             @default(0) // amount + gst
  dispatchedQty    Float             @default(0) // how much already dispatched
  pendingQty       Float             @default(0) // quantity - dispatchedQty
  createdAt        DateTime          @default(now())
  dispatchRequests DispatchRequest[]
}

// ── Dispatch Request (HQ → Factory) ──
model DispatchRequest {
  id              String          @id @default(uuid())
  drNo            Int             @default(autoincrement())
  orderId         String
  order           SalesOrder      @relation(fields: [orderId], references: [id])
  orderLineId     String?
  orderLine       SalesOrderLine? @relation(fields: [orderLineId], references: [id])
  productName     String // DDGS, ETHANOL etc
  quantity        Float // qty to dispatch
  unit            String          @default("TON")
  customerName    String          @default("") // denormalized for factory display
  destination     String?
  deliveryDate    DateTime?
  // Logistics
  logisticsBy     String          @default("BUYER")
  transporterName String?
  transporterId   String? // selected transporter from master
  vehicleCount    Int? // expected trucks
  freightRate     Float? // Rs per MT (negotiated)
  distanceKm      Float? // factory to destination distance
  // Status flow
  status          String          @default("SCHEDULED")
  // SCHEDULED → LOADING → DISPATCHED → COMPLETED | CANCELLED
  acceptedAt      DateTime?
  acceptedBy      String?
  remarks         String?
  userId          String // created by (HQ user)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  shipments       Shipment[]
  freightInquiry  FreightInquiry?
  companyId       String? // FK → Company (null = MSPIL default)
  company         Company?        @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([orderId])
  @@index([status])
  @@index([deliveryDate])
}

// ── Shipment (Factory: one truck = one shipment) ──
model Shipment {
  id                  String               @id @default(uuid())
  shipmentNo          Int                  @default(autoincrement())
  dispatchRequestId   String?
  dispatchRequest     DispatchRequest?     @relation(fields: [dispatchRequestId], references: [id])
  productName         String // DDGS, ETHANOL, LFO, HFO, RS
  customerName        String               @default("")
  destination         String?
  // Vehicle
  vehicleNo           String               @default("")
  vehicleType         String? // TRUCK, TANKER, TRAILER
  capacityTon         Float?
  driverName          String?
  driverMobile        String?
  transporterName     String?
  // Weighbridge
  weightTare          Float? // kg
  weightGross         Float? // kg
  weightNet           Float? // kg (gross - tare)
  // For liquids (Ethanol, LFO, HFO, RS)
  quantityKL          Float? // kilolitres
  quantityBL          Float? // bulk litres
  strength            Float? // % alcohol (ethanol)
  // Bags (DDGS)
  bags                Int?
  weightPerBag        Float? // kg
  // Documents
  challanNo           String?
  challanDate         String?
  // E-Invoice (IRN)
  irn                 String? // Invoice Reference Number from e-Invoice system
  irnDate             DateTime? // IRN generation date
  irnStatus           String? // GENERATED, CANCELLED
  ackNo               String? // IRN acknowledgement number
  signedQRCode        String? // Signed QR code from IRP
  // E-Way Bill
  ewayBill            String? // e-way bill number
  ewayBillDate        DateTime? // e-way bill generation date
  ewayBillValid       DateTime? // e-way bill validity date
  ewayBillStatus      String? // GENERATED, CANCELLED, EXPIRED
  gatePassNo          String?
  invoiceRef          String? // linked invoice
  // GR / Bilty (from transporter)
  grBiltyNo           String? // GR/Bilty number from transporter
  grBiltyDate         DateTime?
  grReceivedBack      Boolean              @default(false) // signed GR received back from buyer
  grReceivedDate      DateTime?
  // Delivery confirmation
  deliveryStatus      String? // IN_TRANSIT, DELIVERED, CONFIRMED
  deliveredAt         DateTime?
  receivedByName      String? // person at buyer who received
  receivedByPhone     String?
  podRemarks          String? // proof of delivery remarks
  // Insurance
  insuranceBy         String? // BUYER, SELLER, NONE
  insuranceNo         String?
  insuranceProvider   String?
  // ── Payment gate (for ADVANCE / COD orders) ──
  paymentTerms        String? // inherited from SalesOrder: ADVANCE, COD, NET7, NET10, NET15, NET30
  paymentStatus       String               @default("PENDING") // PENDING, CONFIRMED, NOT_REQUIRED
  paymentMode         String? // CASH, UPI, NEFT, RTGS, CHEQUE, BANK_TRANSFER
  paymentRef          String? // UTR / cheque no / transaction ID
  paymentAmount       Float? // amount received for this truck
  paymentConfirmedAt  DateTime?
  paymentConfirmedBy  String? // userId who confirmed
  // Status flow
  status              String               @default("GATE_IN")
  // GATE_IN → TARE_WEIGHED → LOADING → GROSS_WEIGHED → RELEASED → EXITED → DELIVERED → GR_RECEIVED
  gateInTime          String? // HH:MM
  tareTime            String?
  loadStartTime       String?
  grossTime           String?
  releaseTime         String?
  exitTime            String?
  date                DateTime             @default(now())
  remarks             String?
  // ── Gate Pass (for job work / returnable material) ──
  gatePassType        String? // SALE, RETURNABLE, NON_RETURNABLE, JOB_WORK
  purpose             String? // e.g. "Deshelling & Reshelling"
  partyName           String? // vendor/party for non-sale gate passes
  partyAddress        String?
  partyGstin          String?
  gatePassItems       String? // JSON array of items [{desc, hsnCode, qty, unit, value}]
  totalValue          Float? // declared value of goods
  coveringNote        String? // authority letter text
  sourceWbId          String?              @unique // Factory weighment ID for dedup/traceability (CRITICAL for idempotency)
  // Scrap sales order link
  directSaleId        String?
  directSale          DirectSale?          @relation(fields: [directSaleId], references: [id])
  // Ship-To (may differ from Bill-To customer for job work)
  shipToCustomerId    String?
  shipToCustomer      Customer?            @relation("ShipmentShipTo", fields: [shipToCustomerId], references: [id])
  shipToName          String?
  shipToGstin         String?
  shipToAddress       String?
  shipToState         String?
  shipToPincode       String?
  userId              String? // factory user
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  documents           ShipmentDocument[]
  transporterPayments TransporterPayment[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([status])
  @@index([paymentStatus])
  @@index([dispatchRequestId])
  @@index([division])
  @@index([directSaleId])
  @@index([companyId])
}

// ── Shipment Documents (uploaded files: GR, Bilty, POD, Insurance, etc.) ──
model ShipmentDocument {
  id         String   @id @default(uuid())
  shipmentId String
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  docType    String // GR_BILTY, POD, INSURANCE, CHALLAN, EWAY_BILL, INVOICE, INQUIRY, QUOTATION, OTHER
  fileName   String
  filePath   String // relative path to uploads/
  fileSize   Int? // bytes
  mimeType   String?
  uploadedBy String?
  remarks    String?
  createdAt  DateTime @default(now())
}

// ── Transporter Inquiry (MSPIL asks transporters for quotes) ──
model FreightInquiry {
  id                String             @id @default(uuid())
  inquiryNo         Int                @default(autoincrement())
  dispatchRequestId String?            @unique
  dispatchRequest   DispatchRequest?   @relation(fields: [dispatchRequestId], references: [id])
  orderId           String?
  // Route
  origin            String             @default("MSPIL, Village Bachai, Narsinghpur, MP - 487001")
  destination       String
  distanceKm        Float?
  // Cargo
  productName       String
  quantity          Float
  unit              String             @default("TON")
  vehicleType       String? // TRUCK, TRAILER, TANKER
  vehicleCount      Int                @default(1)
  // Dates
  loadingDate       DateTime?
  inquiryDate       DateTime           @default(now())
  validTill         DateTime?
  // Status
  status            String             @default("OPEN") // OPEN, QUOTES_RECEIVED, AWARDED, CANCELLED
  remarks           String?
  userId            String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  quotations        FreightQuotation[]
  companyId         String? // FK → Company (null = MSPIL default)
  company           Company?           @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
}

// ── Freight Quotation (Transporter responds to inquiry) ──
model FreightQuotation {
  id              String         @id @default(uuid())
  inquiryId       String
  inquiry         FreightInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  transporterId   String?
  transporterName String
  // Rate
  ratePerMT       Float? // Rs per metric ton
  ratePerTrip     Float? // or flat rate per trip
  ratePerKm       Float? // or per km
  totalAmount     Float?
  // Vehicle offered
  vehicleType     String?
  vehicleCount    Int            @default(1)
  estimatedDays   Int? // transit time
  // Status
  status          String         @default("RECEIVED") // RECEIVED, ACCEPTED, REJECTED
  remarks         String?
  quotedAt        DateTime       @default(now())
  createdAt       DateTime       @default(now())
  companyId       String? // FK → Company (null = MSPIL default)
  company         Company?       @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ── Transporter Payment (50% advance + balance after GR) ──
model TransporterPayment {
  id              String    @id @default(uuid())
  paymentNo       Int       @default(autoincrement())
  shipmentId      String
  shipment        Shipment  @relation(fields: [shipmentId], references: [id])
  transporterId   String?
  transporterName String
  // Amount
  paymentType     String // ADVANCE, BALANCE, FULL, DEDUCTION
  amount          Float
  // Payment details
  paymentDate     DateTime  @default(now())
  mode            String    @default("BANK_TRANSFER") // CASH, CHEQUE, BANK_TRANSFER, UPI, NEFT, RTGS
  reference       String? // UTR / cheque no
  // Freight reference
  freightRate     Float? // Rs per MT
  freightTotal    Float? // total freight for this shipment
  // Status
  status          String    @default("PENDING") // PENDING, PAID, CANCELLED
  paidAt          DateTime?
  approvedBy      String?
  remarks         String?
  userId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([shipmentId])
  @@index([status])
}

// ── Invoice (auto-generated from shipment) ──
model Invoice {
  id                      String                  @id @default(uuid())
  invoiceNo               Int                     @default(autoincrement())
  customerId              String
  customer                Customer                @relation(fields: [customerId], references: [id])
  orderId                 String?
  order                   SalesOrder?             @relation(fields: [orderId], references: [id])
  invoiceDate             DateTime                @default(now())
  dueDate                 DateTime?
  // Line items
  productName             String
  quantity                Float
  unit                    String                  @default("TON")
  rate                    Float
  amount                  Float                   @default(0) // qty × rate
  gstPercent              Float                   @default(18)
  gstAmount               Float                   @default(0)
  // GST component split
  supplyType              String                  @default("INTRA_STATE") // INTRA_STATE or INTER_STATE
  placeOfSupply           String? // State code e.g. "23-MP"
  cgstPercent             Float                   @default(0)
  cgstAmount              Float                   @default(0)
  sgstPercent             Float                   @default(0)
  sgstAmount              Float                   @default(0)
  igstPercent             Float                   @default(0)
  igstAmount              Float                   @default(0)
  freightCharge           Float                   @default(0)
  // TCS (Tax Collected at Source) — Section 206C(1) for scrap sales
  tcsPercent              Float                   @default(0) // 2% from 01-Apr-2026
  tcsAmount               Float                   @default(0) // tcsPercent × amount
  tcsSection              String? // "206C(1)" for scrap, "206C(1H)" for high-value
  totalAmount             Float                   @default(0) // amount + gst + freight + tcs
  // Payment tracking
  paidAmount              Float                   @default(0)
  balanceAmount           Float                   @default(0) // total - paid
  status                  String                  @default("UNPAID") // UNPAID, PARTIAL, PAID, CANCELLED
  // E-Invoice (IRN) — authoritative source for IRN data
  irn                     String? // Invoice Reference Number from NIC/IRP
  irnDate                 DateTime? // IRN generation date
  irnStatus               String? // GENERATED, CANCELLED
  ackNo                   String? // IRN acknowledgement number
  signedQRCode            String? // Signed QR code from IRP
  // E-Way Bill
  ewbNo                   String? // E-Way Bill number (from IRN-based generation)
  ewbDate                 DateTime? // EWB generation date
  ewbValidTill            DateTime? // EWB validity
  ewbStatus               String? // GENERATED, CANCELLED, EXPIRED
  ewbPdfData              Bytes? // Uploaded EWB PDF (for manual entries)
  // Document refs
  shipmentId              String? // which shipment
  challanNo               String?
  ewayBill                String? // legacy field (manual entry)
  // Ship-To snapshot (Bill-To = customerId; Ship-To may differ for job work)
  shipToName              String?
  shipToGstin             String?
  shipToAddress           String?
  shipToState             String?
  shipToPincode           String?
  remarks                 String?
  userId                  String
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  payments                Payment[]
  ethanolLiftings         EthanolLifting[]
  ddgsContractDispatches  DDGSContractDispatch[]
  sugarContractDispatches SugarContractDispatch[]

  // Snapshot — frozen at IRN-generation time. See .claude/skills/invoice-snapshot-immutability.md
  // Phase 1 (shadow-write): populated alongside existing flow; read path still goes through live DB.
  snapshotJsonPath String? // e.g. snapshots/2026/04/INV-248.json (relative to SNAPSHOT_DIR)
  snapshotPdfPath  String? // e.g. snapshots/2026/04/INV-248.pdf
  snapshotJsonSha  String? // SHA256 hex of JSON bytes
  snapshotPdfSha   String? // SHA256 hex of PDF bytes
  snapshotAt       DateTime? // when frozen

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([shipmentId])
  @@index([division])
  @@index([companyId])
  @@index([snapshotAt])
  @@index([orderId])
  @@index([invoiceDate])
}

// ── Payment (against invoices) ──
model Payment {
  id          String    @id @default(uuid())
  paymentNo   Int       @default(autoincrement())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  invoiceId   String?
  invoice     Invoice?  @relation(fields: [invoiceId], references: [id])
  paymentDate DateTime  @default(now())
  amount      Float
  mode        String    @default("BANK_TRANSFER") // CASH, CHEQUE, BANK_TRANSFER, UPI, NEFT, RTGS
  reference   String? // UTR / cheque no / UPI ref
  confirmedBy String? // who confirmed receipt
  confirmedAt DateTime?
  remarks     String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([division])
  @@index([companyId])
  @@index([customerId])
  @@index([paymentDate])
}

// ═══════════════════════════════════════════════════════════════
// PROCUREMENT MODULE (P2P — SAP MM inspired with Indian GST)
// ═══════════════════════════════════════════════════════════════

// ── Vendor Master (supplier registration) ──
model Vendor {
  id                      String      @id @default(uuid())
  vendorCode              String?     @unique // auto or manual code
  name                    String
  tradeName               String? // business trade name
  category                String      @default("GENERAL") // RAW_MATERIAL, CHEMICAL, FUEL, PACKING, SERVICE, TRADER, GENERAL
  gstin                   String? // 15-char GSTIN
  pan                     String? // 10-char PAN
  gstState                String? // 2-digit state code (e.g., "09" for UP)
  gstStateCode            String? // state name
  isRCM                   Boolean     @default(false) // Reverse Charge Mechanism applicable
  isMSME                  Boolean     @default(false) // MSME vendor (priority payment)
  msmeRegNo               String?
  msmeCategory            String? // MICRO, SMALL, MEDIUM
  // Address
  address                 String?
  city                    String?
  state                   String?
  pincode                 String?
  // Contact
  contactPerson           String?
  phone                   String?
  email                   String?
  // Bank Details
  bankName                String?
  bankBranch              String?
  bankAccount             String?
  bankIfsc                String?
  // Payment
  paymentTerms            String? // ADVANCE, COD, NET7, NET15, NET30, NET45, NET60
  creditLimit             Float       @default(0)
  creditDays              Int         @default(30)
  // TDS
  tdsApplicable           Boolean     @default(false)
  tdsSection              String? // 194C, 194Q, etc. (legacy string, kept for compat)
  tdsPercent              Float       @default(0)
  // ── Compliance & Tax (Phase 1) ──
  tdsSectionId            String? // FK to TdsSection master
  tdsSectionRef           TdsSection? @relation(fields: [tdsSectionId], references: [id])
  udyamNo                 String? // MSME Udyam registration no
  msmePaymentTermDays     Int         @default(45) // 45 days unless written agreement
  lowerDeductionCertNo    String? // Form 13 certificate
  lowerDeductionRate      Float?
  lowerDeductionValidFrom DateTime?
  lowerDeductionValidTill DateTime?
  is206ABNonFiler         Boolean     @default(false)
  isUnregisteredForRCM    Boolean     @default(false) // unregistered under GST → RCM on all supplies
  // Procurement agent/trader
  isAgent                 Boolean     @default(false) // true = informal procurement agent/trader
  aadhaarNo               String? // Aadhaar number for individual traders
  productTypes            String? // Comma-separated: "FUEL,RAW_MATERIAL,CHEMICAL" — what this trader buys
  // Raw Material sub-type
  rawMaterialType         String? // CORN, RICE, WHEAT, etc. — only when category = RAW_MATERIAL_SUPPLIER
  maanNumber              String? // Maan/Mandi license number — required for corn suppliers
  //
  isActive                Boolean     @default(true)
  remarks                 String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  purchaseOrders    PurchaseOrder[]
  indents           PurchaseRequisition[]       @relation("VendorIndents")
  indentQuotes      PurchaseRequisitionVendor[] @relation("VendorIndentQuotes")
  emailThreads      EmailThread[]               @relation("VendorEmailThreads")
  grns              GoodsReceipt[]
  vendorInvoices    VendorInvoice[]
  vendorPayments    VendorPayment[]
  vendorItems       VendorItem[]
  contractor        Contractor?
  projectQuotations ProjectQuotation[]

  divisions String[] @default([]) // empty = available to all divisions

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([isAgent])
  @@index([companyId])
}

// ── Vendor-Item Pricing (what items a vendor supplies + negotiated rates) ──
model VendorItem {
  id              String        @id @default(cuid())
  vendorId        String
  vendor          Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  inventoryItemId String
  item            InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  rate            Float         @default(0) // last negotiated rate
  minOrderQty     Float? // minimum order quantity
  leadTimeDays    Int? // vendor-specific lead time
  remarks         String?
  isPreferred     Boolean       @default(false) // preferred supplier for this item
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([vendorId, inventoryItemId])
  @@index([vendorId])
  @@index([inventoryItemId])
}

// ── Material Master (items you buy) ──
model Material {
  id              String   @id @default(uuid())
  code            String?  @unique // item code
  name            String
  category        String   @default("RAW_MATERIAL") // RAW_MATERIAL, CHEMICAL, FUEL, PACKING, CONSUMABLE, SPARE, SERVICE
  subCategory     String? // e.g., ENZYME, YEAST, ACID
  hsnCode         String? // HSN/SAC code (legacy string — new code uses hsnId FK)
  hsnId           String? // FK to HsnCode master (Phase 1 compliance)
  hsn             HsnCode? @relation(fields: [hsnId], references: [id])
  defaultUqc      String? // Unit Quantity Code per GSTN (e.g., "KLR", "KGS", "NOS")
  isRcmApplicable Boolean  @default(false) // RCM applies to procurement of this material
  unit            String   @default("KG") // KG, MT, LTR, KL, NOS, BAG, DRUM
  gstPercent      Float    @default(18) // default GST rate (legacy — new code reads from GstRate)
  defaultRate     Float    @default(0) // last/standard rate
  minStock        Float    @default(0) // reorder level
  currentStock    Float    @default(0) // current qty in store
  storageLocation String? // STORE, YARD, TANK, etc.
  isActive        Boolean  @default(true)
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  poLines  POLine[]
  grnLines GRNLine[]

  divisions String[] @default([]) // empty = available to all divisions
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ── Purchase Order (HQ creates, sent to vendor) ──
model PurchaseOrder {
  id                   String               @id @default(uuid())
  poNo                 Int                  @default(autoincrement())
  vendorId             String
  vendor               Vendor               @relation(fields: [vendorId], references: [id])
  poDate               DateTime             @default(now())
  deliveryDate         DateTime?
  // GST supply type
  supplyType           String               @default("INTRA_STATE") // INTRA_STATE (CGST+SGST), INTER_STATE (IGST)
  placeOfSupply        String? // state code
  // Totals (auto-calculated)
  subtotal             Float                @default(0) // sum of line amounts
  totalCgst            Float                @default(0)
  totalSgst            Float                @default(0)
  totalIgst            Float                @default(0)
  totalGst             Float                @default(0)
  freightCharge        Float                @default(0)
  otherCharges         Float                @default(0)
  roundOff             Float                @default(0)
  grandTotal           Float                @default(0)
  // TDS
  tdsApplicable        Boolean              @default(false)
  tdsSection           String?
  tdsPercent           Float                @default(0)
  tdsAmount            Float                @default(0)
  // Phase-B TDS unification: snapshot from calculator at booking time
  tdsReasonSnapshot    Json? // { panMissing, nonFiler, thresholdMet, ldcApplied, ytdPaid }
  tdsComputedAt        DateTime? // when calculator last ran — payment recomputes if stale
  // Per-PO TDS section override (e.g., "Payment 0.1% TDS" clause on RM contract → 194Q).
  // When set, calculator ignores vendor.tdsSectionId and uses this instead.
  overrideTdsSectionId String?
  overrideTdsSection   TdsSection?          @relation("PoOverrideTds", fields: [overrideTdsSectionId], references: [id])
  // RM contract terms ticked on this PO — keys from backend/src/data/poTerms.ts
  termsAccepted        String[]             @default([])
  // Payment terms
  paymentTerms         String?
  creditDays           Int                  @default(30)
  // Logistics
  deliveryAddress      String? // factory address
  transportMode        String? // ROAD, RAIL
  transportBy          String? // BY_US, BY_SUPPLIER
  // Deal type
  dealType             String               @default("STANDARD") // STANDARD (fixed qty PO), OPEN (running account, no qty limit)
  // What kind of procurement is this PO for?
  // GOODS      — physical inventory items (default, full HSN + GRN flow)
  // SERVICE    — service engagement (SAC code, no GRN / service completion note)
  // CONTRACTOR — contractor work (labour, civil, electrical) — may link to Contractor master
  // TRANSPORT  — freight / vehicle hire / logistics
  // RENT       — premises / equipment / vehicle rent (recurring)
  // UTILITY    — electricity, water, internet, phone, subscription
  // PROJECT    — capex / asset purchase (coal crusher, plant hardware, turnkey project, civil project)
  // OTHER      — anything else that needs a PO umbrella
  poType               String               @default("GOODS") // GOODS | SERVICE | CONTRACTOR | TRANSPORT | RENT | UTILITY | PROJECT | OTHER
  // Quotation reference (vendor quote this PO is based on — primarily used for PROJECT / capex POs)
  quotationNo          String?
  quotationDate        DateTime?
  projectName          String? // e.g. "Coal Crusher 20 TPH", "Silo #3 Erection"
  // Status
  status               String               @default("DRAFT") // DRAFT, APPROVED, SENT, PARTIAL_RECEIVED, RECEIVED, CLOSED, CANCELLED
  approvedBy           String?
  approvedAt           DateTime?
  // Refs
  remarks              String?
  truckCap             Int? // Max trucks for FIXED TRUCKS fuel deals (NF-4)
  requisitionId        String? // FK to PurchaseRequisition (auto-PO from indent)
  requisition          PurchaseRequisition? @relation(fields: [requisitionId], references: [id], onDelete: SetNull)
  userId               String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  // Contractor link (when poType = CONTRACTOR)
  contractorId String?
  contractor   Contractor? @relation(fields: [contractorId], references: [id])

  lines           POLine[]
  grns            GoodsReceipt[]
  vendorInvoices  VendorInvoice[]
  grainTrucks     GrainTruck[]
  contractorBills ContractorBill[]

  // Link back to project purchase (when auto-generated from a ProjectPurchase awarded quote)
  projectPurchaseId String?          @unique
  projectPurchase   ProjectPurchase? @relation(fields: [projectPurchaseId], references: [id])

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([vendorId])
  @@index([status])
  @@index([vendorId, dealType, status])
  @@index([contractorId])
  @@index([requisitionId])
  @@index([division])
  @@index([companyId])
}

// ── PO Line Item ──
model POLine {
  id              String         @id @default(uuid())
  poId            String
  po              PurchaseOrder  @relation(fields: [poId], references: [id], onDelete: Cascade)
  lineNo          Int            @default(1)
  materialId      String? // DEPRECATED — use inventoryItemId
  material        Material?      @relation(fields: [materialId], references: [id])
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  description     String // item description
  hsnCode         String? // legacy string snapshot; new code reads hsnCodeRef
  // Phase-A tax unification: snapshot HSN at PO time for audit integrity
  hsnCodeId       String?
  hsnCodeRef      HsnCode?       @relation(fields: [hsnCodeId], references: [id])
  quantity        Float
  unit            String         @default("KG")
  rate            Float
  isRateInclusive Boolean        @default(false) // if true: rate is GST-inclusive; base = rate / (1 + gst%)
  amount          Float          @default(0) // qty × rate
  discountPercent Float          @default(0)
  discountAmount  Float          @default(0)
  taxableAmount   Float          @default(0) // amount - discount (or back-solved when inclusive)
  // GST split
  gstPercent      Float          @default(18)
  rateSnapshotGst Float? // audit: GST rate fetched from master at PO create/update time
  cgstPercent     Float          @default(0)
  cgstAmount      Float          @default(0)
  sgstPercent     Float          @default(0)
  sgstAmount      Float          @default(0)
  igstPercent     Float          @default(0)
  igstAmount      Float          @default(0)
  totalGst        Float          @default(0)
  lineTotal       Float          @default(0) // taxable + gst
  // Receipt tracking
  receivedQty     Float          @default(0)
  pendingQty      Float          @default(0) // = quantity - receivedQty
  // RCM
  isRCM           Boolean        @default(false)
  createdAt       DateTime       @default(now())

  grnLines GRNLine[]

  @@index([inventoryItemId])
  @@index([poId])
  @@index([hsnCodeId])
}

// ── Goods Receipt Note (factory receives goods against PO) ──
model GoodsReceipt {
  id               String        @id @default(uuid())
  grnNo            Int           @default(autoincrement())
  poId             String
  po               PurchaseOrder @relation(fields: [poId], references: [id])
  vendorId         String
  vendor           Vendor        @relation(fields: [vendorId], references: [id])
  grnDate          DateTime      @default(now())
  // Vehicle / delivery info
  vehicleNo        String?
  challanNo        String? // kept for backward compat
  challanDate      DateTime?
  invoiceNo        String? // vendor invoice number
  invoiceDate      DateTime? // vendor invoice date
  ewayBill         String?
  // Uploaded document files (AI-extracted)
  invoiceFilePath  String? // path to uploaded invoice photo/PDF
  ewayBillFilePath String? // path to uploaded e-way bill photo/PDF
  // Quality
  qualityStatus    String        @default("PENDING") // PENDING, ACCEPTED, REJECTED, PARTIAL_ACCEPTED
  qualityRemarks   String?
  inspectedBy      String?
  // Status (Saif 2026-04-30: added AT_GATE between AWAITING and CONFIRMED)
  // Lifecycle: DRAFT (=AWAITING_ITEM for EXPECTED grnType) → AT_GATE → CONFIRMED
  status           String        @default("DRAFT") // DRAFT, AT_GATE, PARTIAL, CONFIRMED, CANCELLED
  atGateAt         DateTime? // set when truck for this PO checks in at gate
  grnType          String        @default("ACTUAL") // EXPECTED (pre-created from approved PO), ACTUAL (real receipt)
  expectedDate     DateTime? // when EXPECTED type: planned arrival
  archived         Boolean       @default(false) // hide from active list
  // Payment linkage (denormalized for "paid & awaiting" filter)
  paymentLinkedAt  DateTime?
  fullyPaid        Boolean       @default(false)
  // Totals (from lines)
  totalQty         Float         @default(0)
  totalAmount      Float         @default(0)
  // Weighbridge data (populated when GRN is created from a weighbridge ticket)
  grossWeight      Float? // MT — total truck gross
  tareWeight       Float? // MT — empty truck tare
  netWeight        Float? // MT — net delivered
  firstWeightAt    DateTime? // entry / first weighment timestamp
  secondWeightAt   DateTime? // exit / second weighment timestamp
  ticketNo         Int? // weighbridge ticket number
  driverName       String?
  driverMobile     String?
  transporterName  String?
  //
  remarks          String?
  userId           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  lines              GRNLine[]
  vendorInvoices     VendorInvoice[]
  vendorInvoiceLines VendorInvoiceLine[]
  grainTrucks        GrainTruck[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([poId])
  @@index([vendorId])
  @@index([ticketNo])
  @@index([division])
  @@index([companyId])
  @@index([status])
  @@index([status, archived])
}

// ── GRN Line Item ──
model GRNLine {
  id                 String         @id @default(uuid())
  grnId              String
  grn                GoodsReceipt   @relation(fields: [grnId], references: [id], onDelete: Cascade)
  poLineId           String?
  poLine             POLine?        @relation(fields: [poLineId], references: [id])
  materialId         String? // DEPRECATED — use inventoryItemId
  material           Material?      @relation(fields: [materialId], references: [id])
  inventoryItemId    String?
  inventoryItem      InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  description        String
  receivedQty        Float
  acceptedQty        Float          @default(0) // after quality check
  rejectedQty        Float          @default(0)
  unit               String         @default("KG")
  rate               Float          @default(0) // from PO
  amount             Float          @default(0) // acceptedQty × rate
  storageLocation    String? // legacy
  warehouseCode      String? // warehouse code (e.g. CHEM, MAIN, SPARE)
  batchNo            String?
  expiryDate         DateTime?
  remarks            String?
  // Routing decision at GRN approval (Saif 2026-04-30): split accepted qty
  // between store warehouse and direct-to-factory. Sum should equal acceptedQty
  // (validated at approve time). routedAt is set when the user clicks Approve.
  routedToStoreQty   Float?         @default(0)
  routedToFactoryQty Float?         @default(0)
  routedAt           DateTime?
  createdAt          DateTime       @default(now())

  @@index([inventoryItemId])
  @@index([grnId])
}

// ── Vendor Invoice (3-way match: PO + GRN + Invoice) ──
model VendorInvoice {
  id                String         @id @default(uuid())
  invoiceNo         Int            @default(autoincrement())
  vendorId          String
  vendor            Vendor         @relation(fields: [vendorId], references: [id])
  poId              String?
  po                PurchaseOrder? @relation(fields: [poId], references: [id])
  grnId             String?
  grn               GoodsReceipt?  @relation(fields: [grnId], references: [id])
  // Vendor's invoice details
  vendorInvNo       String? // vendor's own invoice number
  vendorInvDate     DateTime? // vendor's invoice date
  invoiceDate       DateTime       @default(now()) // our booking date
  dueDate           DateTime?
  // Line summary
  productName       String?
  quantity          Float          @default(0)
  unit              String         @default("KG")
  rate              Float          @default(0)
  subtotal          Float          @default(0) // qty × rate
  // GST breakup
  supplyType        String         @default("INTRA_STATE")
  gstPercent        Float          @default(18)
  cgstAmount        Float          @default(0)
  sgstAmount        Float          @default(0)
  igstAmount        Float          @default(0)
  totalGst          Float          @default(0)
  // RCM
  isRCM             Boolean        @default(false)
  rcmCgst           Float          @default(0)
  rcmSgst           Float          @default(0)
  rcmIgst           Float          @default(0)
  rcmTotal          Float          @default(0)
  // ITC eligibility
  itcEligible       Boolean        @default(true)
  itcClaimed        Boolean        @default(false)
  itcClaimedDate    DateTime?
  itcReversed       Boolean        @default(false)
  itcReversalReason String?
  // Other charges
  freightCharge     Float          @default(0)
  loadingCharge     Float          @default(0)
  otherCharges      Float          @default(0)
  roundOff          Float          @default(0)
  totalAmount       Float          @default(0)
  // TDS
  tdsSection        String?
  tdsPercent        Float          @default(0)
  tdsAmount         Float          @default(0)
  // Phase-B TDS unification: snapshot from calculator at invoice booking
  tdsReasonSnapshot Json? // { panMissing, nonFiler, thresholdMet, ldcApplied, ytdPaid }
  tdsComputedAt     DateTime? // when calculator last ran
  netPayable        Float          @default(0) // total - tds
  // Payment tracking
  paidAmount        Float          @default(0)
  balanceAmount     Float          @default(0)
  status            String         @default("PENDING") // PENDING, VERIFIED, APPROVED, PARTIAL_PAID, PAID, DISPUTED, CANCELLED
  // 3-way match
  matchStatus       String         @default("UNMATCHED") // UNMATCHED, MATCHED, MISMATCH
  matchRemarks      String?
  // Document refs
  filePath          String? // uploaded invoice file (relative to uploads/)
  fileHash          String? // SHA-256 of the uploaded bill — used to skip AI extraction on re-uploads
  originalFileName  String? // the user's original filename (e.g. "may-bills-3.pdf") — for human-readable dedup messages
  remarks           String?
  userId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  payments VendorPayment[]
  lines    VendorInvoiceLine[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([vendorId])
  @@index([poId])
  @@index([status])
  @@index([invoiceDate])
  @@index([division])
  @@index([companyId])
  @@index([fileHash])
  @@index([grnId])
}

// ── Vendor Invoice Line ──
// One row per line item on a vendor's bill.
// A bill can cover multiple GRNs / multiple HSN codes / mix of goods + freight + service charges.
// `grnId` is optional — non-GRN charges (freight, loading) leave it null.
// Header-level VendorInvoice.grnId still mirrors the FIRST line's grnId for back-compat
// with 3-way match + ITC code that reads single grn today.
model VendorInvoiceLine {
  id            String        @id @default(uuid())
  invoiceId     String
  invoice       VendorInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  grnId         String?
  grn           GoodsReceipt? @relation(fields: [grnId], references: [id])
  lineNo        Int           @default(1)
  productName   String
  hsnCode       String?
  quantity      Float         @default(0)
  unit          String        @default("KG")
  rate          Float         @default(0)
  taxableAmount Float         @default(0) // qty × rate, before GST
  gstPercent    Float         @default(0)
  cgstAmount    Float         @default(0)
  sgstAmount    Float         @default(0)
  igstAmount    Float         @default(0)
  totalAmount   Float         @default(0) // taxable + GST
  remarks       String?
  createdAt     DateTime      @default(now())

  @@index([invoiceId])
  @@index([grnId])
}

// ── Vendor Payment ──
model VendorPayment {
  id                   String         @id @default(uuid())
  paymentNo            Int            @default(autoincrement())
  vendorId             String
  vendor               Vendor         @relation(fields: [vendorId], references: [id])
  invoiceId            String?
  invoice              VendorInvoice? @relation(fields: [invoiceId], references: [id])
  paymentDate          DateTime       @default(now())
  amount               Float
  mode                 String         @default("BANK_TRANSFER") // CASH, CHEQUE, BANK_TRANSFER, NEFT, RTGS, UPI
  reference            String? // UTR / cheque no
  // TDS deducted in this payment
  tdsDeducted          Float          @default(0)
  tdsSection           String?
  // Advance payment (no invoice)
  isAdvance            Boolean        @default(false)
  advanceAdjusted      Float          @default(0) // how much of advance is adjusted
  // Payment status (bank two-step flow)
  paymentStatus        String         @default("CONFIRMED") // INITIATED (pending UTR), CONFIRMED, CANCELLED
  confirmedAt          DateTime? // when UTR was entered and payment confirmed
  // Payment Advice delivery (emailed to vendor after confirmation)
  adviceSentAt         DateTime? // when Payment Advice email was delivered
  adviceSentTo         String? // email address the advice was sent to
  // GST inclusion — captured at Pay time (compulsory user choice)
  hasGst               Boolean? // true = payment inclusive of GST, false = advance/GST excluded, null = legacy (not captured)
  // Bank receipt — PDF/JPG uploaded by team, Gemini-extracted structured data, timestamp
  bankReceiptPath      String? // uploads/bank-receipts/<filename> — original bank confirmation
  bankReceiptExtracted Json? //   raw Gemini extraction (audit trail: UTR, beneficiary, amount, etc.)
  bankReceiptScannedAt DateTime? // when the receipt was uploaded + scanned
  // Bank file tracking (UBI APPA integration)
  bankFileBatch        String? // batch ID when included in bank file
  bankFileSentAt       DateTime? // when bank file was generated
  //
  remarks              String?
  userId               String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([vendorId])
  @@index([invoiceId])
  @@index([paymentDate])
  @@index([paymentStatus])
  @@index([bankFileBatch])
  @@index([division])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// CONTRACTORS — Service providers (civil, electrical, manpower, etc.)
// ══════════════════════════════════════════════════════════════

model Contractor {
  id             String   @id @default(uuid())
  contractorCode String   @unique // CON-001, CON-002...
  name           String // Name of individual / firm
  tradeName      String? // Firm/trade name (if company)
  pan            String // PAN (10 chars, required)
  panType        String   @default("INDIVIDUAL") // INDIVIDUAL | COMPANY (derived from PAN 4th char)
  gstin          String? // 15-char GSTIN (null = unregistered)
  gstState       String? // GST state code
  aadhaarNo      String? // For individuals
  contractorType String   @default("OTHER") // CIVIL, ELECTRICAL, MANPOWER, TRANSPORT, DAILY_WORK, OTHER
  phone          String?
  email          String?
  address        String?
  bankName       String?
  bankBranch     String?
  bankAccount    String?
  bankIfsc       String?
  tdsSection     String   @default("194C")
  tdsPercent     Float    @default(1) // 1% individual, 2% company
  isActive       Boolean  @default(true)
  remarks        String?
  // Shadow vendor for PO integration (auto-created on first contractor PO)
  vendorId       String?  @unique
  vendor         Vendor?  @relation(fields: [vendorId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  bills          ContractorBill[]
  payments       ContractorPayment[]
  storeIssues    ContractorStoreIssue[]
  workOrders     WorkOrder[]
  employees      Employee[]
  purchaseOrders PurchaseOrder[]
  laborWorkers   LaborWorker[]

  divisions String[] @default([]) // empty = available to all divisions
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([pan])
  @@index([isActive])
  @@index([contractorType])
  @@index([companyId])
}

model ContractorBill {
  id                String         @id @default(uuid())
  billNo            Int            @default(autoincrement())
  contractorId      String
  contractor        Contractor     @relation(fields: [contractorId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  workOrderId       String?
  workOrder         WorkOrder?     @relation(fields: [workOrderId], references: [id])
  billDate          DateTime       @default(now())
  billPath          String         @default("CREATED") // CREATED | UPLOADED
  description       String // Summary of work done
  // Amounts
  subtotal          Float          @default(0) // Sum of line items (base before GST)
  cgstPercent       Float          @default(0)
  sgstPercent       Float          @default(0)
  igstPercent       Float          @default(0)
  cgstAmount        Float          @default(0)
  sgstAmount        Float          @default(0)
  igstAmount        Float          @default(0)
  totalAmount       Float          @default(0) // subtotal + GST
  tdsPercent        Float          @default(0) // From contractor master
  tdsAmount         Float          @default(0) // tdsPercent × subtotal
  netPayable        Float          @default(0) // totalAmount - tdsAmount
  paidAmount        Float          @default(0)
  balanceAmount     Float          @default(0) // netPayable - paidAmount
  // Status
  status            String         @default("DRAFT") // DRAFT | CONFIRMED | PARTIAL_PAID | PAID | CANCELLED
  vendorBillNo      String? // Contractor's own bill number (UPLOADED path)
  documentUrl       String? // Uploaded bill file path (UPLOADED path)
  // ITC tracking (Input Tax Credit)
  itcEligible       Boolean        @default(true)
  itcClaimed        Boolean        @default(false)
  itcClaimedDate    DateTime?
  itcReversed       Boolean        @default(false)
  itcReversalReason String?
  confirmedAt       DateTime?
  confirmedBy       String?
  userId            String
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  lines    ContractorBillLine[]
  payments ContractorPayment[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([contractorId])
  @@index([purchaseOrderId])
  @@index([workOrderId])
  @@index([status])
  @@index([billDate])
  @@index([division])
  @@index([companyId])
}

model ContractorBillLine {
  id          String         @id @default(uuid())
  billId      String
  bill        ContractorBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  description String // Work description
  quantity    Float          @default(1)
  unit        String         @default("NOS") // NOS, DAYS, SQ.FT, CU.M, KG, MT, LUMP
  rate        Float          @default(0)
  amount      Float          @default(0) // qty × rate

  @@index([billId])
}

model ContractorPayment {
  id            String          @id @default(uuid())
  contractorId  String
  contractor    Contractor      @relation(fields: [contractorId], references: [id])
  billId        String?
  bill          ContractorBill? @relation(fields: [billId], references: [id])
  amount        Float
  tdsDeducted   Float           @default(0)
  paymentMode   String          @default("NEFT") // CASH, NEFT, RTGS, UPI, CHEQUE, BANK_TRANSFER
  paymentRef    String? // UTR / cheque no
  paymentDate   DateTime        @default(now())
  paymentStatus String          @default("CONFIRMED") // INITIATED | CONFIRMED | CANCELLED
  isAdvance     Boolean         @default(false)
  remarks       String?
  userId        String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([contractorId])
  @@index([billId])
  @@index([paymentDate])
  @@index([paymentStatus])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// CONTRACTOR STORE ISSUE — Items issued from store to contractors
// with usage charge (debit note). Track per contractor.
// ══════════════════════════════════════════════════════════════

model ContractorStoreIssue {
  id            String     @id @default(uuid())
  issueNo       Int        @default(autoincrement())
  issueDate     DateTime   @default(now())
  contractorId  String
  contractor    Contractor @relation(fields: [contractorId], references: [id])
  // Totals (denormalized for list view)
  subtotal      Float      @default(0) // Sum of (qty × rate) across lines
  chargePercent Float      @default(5) // Usage/handling charge %
  chargeAmount  Float      @default(0) // chargePercent × subtotal / 100
  totalAmount   Float      @default(0) // subtotal + chargeAmount
  status        String     @default("DRAFT") // DRAFT | CONFIRMED | RETURNED | CANCELLED
  purpose       String? // What work the items are for
  remarks       String?
  returnedAt    DateTime?
  returnRemarks String?
  userId        String // Created by
  confirmedBy   String?
  confirmedAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  lines ContractorStoreIssueLine[]

  division  String?  @default("ETHANOL")
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([contractorId])
  @@index([status])
  @@index([issueDate])
  @@index([division])
  @@index([companyId])
}

model ContractorStoreIssueLine {
  id              String               @id @default(uuid())
  issueId         String
  issue           ContractorStoreIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  description     String // Item name
  inventoryItemId String? // Link to InventoryItem if from store stock
  quantity        Float                @default(1)
  unit            String               @default("NOS")
  rate            Float                @default(0) // Cost price from store
  amount          Float                @default(0) // qty × rate
  returnedQty     Float                @default(0) // How much was returned
  remarks         String?

  @@index([issueId])
}

// ══════════════════════════════════════════════════════════════
// CONTRACTOR WORK ORDER — Authorisation to perform a job at agreed
// scope, rate, GST, TDS. Bills (ContractorBill) link via workOrderId
// so payment + journal flow rides on the existing rails.
// ══════════════════════════════════════════════════════════════

model WorkOrder {
  id               String     @id @default(uuid())
  woNo             Int        @default(autoincrement())
  contractorId     String
  contractor       Contractor @relation(fields: [contractorId], references: [id])
  // Scope
  title            String // short title — "Boiler shed roofing"
  description      String? // detailed scope of work
  startDate        DateTime?
  endDate          DateTime? // expected completion
  siteLocation     String? // "Distillery Plant — bay 4"
  // GST supply type (mirrors PurchaseOrder)
  supplyType       String     @default("INTRA_STATE") // INTRA_STATE (CGST+SGST) | INTER_STATE (IGST)
  placeOfSupply    String? // state code
  // Contract type — drives form layout / list tab
  contractType     String     @default("GENERAL") // GENERAL | MANPOWER_SUPPLY
  // Manpower supply contract — header-level rate card snapshot (JSON array of skill categories with 8h / 12h rates).
  // Only populated when contractType = 'MANPOWER_SUPPLY'. Used to render the rate card on print / re-edit.
  manpowerRateCard Json?
  // Header totals (denormalised from lines)
  subtotal         Float      @default(0) // sum of (qty × rate)
  discountAmount   Float      @default(0)
  taxableAmount    Float      @default(0) // subtotal - discount
  totalCgst        Float      @default(0)
  totalSgst        Float      @default(0)
  totalIgst        Float      @default(0)
  totalGst         Float      @default(0)
  grandTotal       Float      @default(0) // taxable + GST
  // Retention (held back from each bill until close-out)
  retentionPercent Float      @default(0)
  retentionAmount  Float      @default(0)
  // TDS
  tdsSection       String     @default("194C") // snapshot from contractor master
  tdsPercent       Float      @default(0)
  tdsAmount        Float      @default(0) // tdsPercent × taxableAmount (estimated)
  // Settlement (rolled up from confirmed ContractorBills)
  billedAmount     Float      @default(0) // sum of confirmed bill subtotals against this WO
  paidAmount       Float      @default(0) // sum of payments through linked bills
  balanceAmount    Float      @default(0) // grandTotal - billed (positive = unbilled scope left)
  progressPercent  Float      @default(0) // last reported % completion
  // Lifecycle
  status           String     @default("DRAFT") // DRAFT | APPROVED | IN_PROGRESS | COMPLETED | CLOSED | CANCELLED
  approvedBy       String?
  approvedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  closedAt         DateTime?
  cancelledAt      DateTime?
  cancelReason     String?
  // Payment terms
  paymentTerms     String? // free text — "30% advance, 60% on completion, 10% retention release after 90 days"
  creditDays       Int        @default(30)
  // Refs
  remarks          String?
  userId           String // created by
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  lines        WorkOrderLine[]
  progress     WorkOrderProgress[]
  bills        ContractorBill[]
  laborWorkers LaborWorker[]

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([contractorId])
  @@index([status])
  @@index([startDate])
  @@index([division])
  @@index([companyId])
  @@index([contractType])
}

model WorkOrderLine {
  id              String    @id @default(uuid())
  woId            String
  workOrder       WorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade)
  lineNo          Int       @default(1)
  description     String // scope line — "RCC roofing 12m × 8m"
  hsnSac          String? // HSN/SAC code (services use SAC)
  quantity        Float     @default(1)
  unit            String    @default("NOS") // NOS, DAYS, SQ.FT, CU.M, MT, KG, LUMP, LM
  rate            Float     @default(0)
  amount          Float     @default(0) // qty × rate
  discountPercent Float     @default(0)
  discountAmount  Float     @default(0)
  taxableAmount   Float     @default(0) // amount - discount
  // GST split
  gstPercent      Float     @default(18)
  cgstPercent     Float     @default(0)
  cgstAmount      Float     @default(0)
  sgstPercent     Float     @default(0)
  sgstAmount      Float     @default(0)
  igstPercent     Float     @default(0)
  igstAmount      Float     @default(0)
  totalGst        Float     @default(0)
  lineTotal       Float     @default(0) // taxable + gst
  // Progress against this line
  completedQty    Float     @default(0)
  remarks         String?
  // Manpower supply lines — populated when lineKind = 'MANPOWER'
  lineKind        String    @default("GENERAL") // GENERAL | MANPOWER
  skillCategory   String? // SKILLED | SEMI_SKILLED | UNSKILLED | SUPERVISOR | (free-text override)
  shiftHours      Int? // 8 or 12
  personCount     Int? // people supplied per day
  shiftCount      Int? // number of shifts (days) in the contract period
  createdAt       DateTime  @default(now())

  @@index([woId])
}

model WorkOrderProgress {
  id         String    @id @default(uuid())
  woId       String
  workOrder  WorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade)
  reportedAt DateTime  @default(now())
  percent    Float     @default(0) // running % completion (0-100)
  workDone   String // narrative — "RCC slab cured day 7"
  photoUrl   String?
  reportedBy String // userId
  remarks    String?

  @@index([woId])
  @@index([reportedAt])
}

// ══════════════════════════════════════════════════════════════
// DIRECT TRADE — Cash purchases from farmers / cash sales without paperwork
// ══════════════════════════════════════════════════════════════

model DirectPurchase {
  id              String   @id @default(uuid())
  entryNo         Int      @default(autoincrement())
  date            DateTime @default(now())
  // Seller (farmer) — not a registered vendor
  sellerName      String
  sellerPhone     String?
  sellerVillage   String?
  sellerAadhaar   String? // optional ID proof
  // What was bought
  materialName    String // Maize, Broken Rice, etc.
  quantity        Float
  unit            String   @default("KG") // KG, MT, QTL, LTR
  rate            Float
  amount          Float // qty × rate
  // Weighbridge / vehicle
  vehicleNo       String?
  weightSlipNo    String?
  grossWeight     Float?
  tareWeight      Float?
  netWeight       Float?
  // Payment
  paymentMode     String   @default("CASH") // CASH, UPI, BANK_TRANSFER
  paymentRef      String? // UPI ref / cheque no
  isPaid          Boolean  @default(true)
  // Deductions (moisture, foreign matter, etc.)
  deductions      Float    @default(0)
  deductionReason String?
  netPayable      Float    @default(0) // amount - deductions
  //
  remarks         String?
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  // Farmer master link — added 2026-05-02. Nullable so legacy rows don't break.
  // Backfilled by /farmers/backfill admin endpoint that groups by sellerPhone.
  farmerId String?
  farmer   Farmer? @relation(fields: [farmerId], references: [id])

  @@index([date])
  @@index([isPaid])
  @@index([division])
  @@index([companyId])
  @@index([farmerId])
}

// ══════════════════════════════════════════════════════════════
// FARMER MASTER — separate from Vendor master.
// Vendors = GSTIN-registered industrial parties (TDS/MSME/credit terms).
// Farmers = unregistered individuals selling raw material at gate (mandi-license driven,
// scale to thousands per season, RCM applicable). Keeping them apart prevents the
// vendor master from getting clogged and lets us run farmer-only reports cleanly.
// ══════════════════════════════════════════════════════════════

model Farmer {
  id               String  @id @default(uuid())
  code             String? @unique // auto-generated F-0001 etc.
  name             String
  // Identifiers — phone is primary match key, aadhaar fallback
  phone            String? // 10-digit, no country code
  aadhaar          String? // 12-digit
  // Mandatory for grain procurement under MP/UP mandi rules
  maanNumber       String?
  // Address
  village          String?
  tehsil           String?
  district         String?
  state            String?
  pincode          String?
  // Bank details for UPI/NEFT payouts
  bankName         String?
  bankAccount      String?
  bankIfsc         String?
  upiId            String?
  // What this farmer typically supplies — comma-separated for multi-material support
  // e.g. "CORN,BROKEN_RICE". Used for filtering at gate but not enforced.
  rawMaterialTypes String?
  // KYC
  kycStatus        String  @default("PENDING") // PENDING, VERIFIED, REJECTED
  kycNotes         String?
  // RCM — most farmers are unregistered for GST → reverse charge applies
  isRCM            Boolean @default(true)
  isActive         Boolean @default(true)
  remarks          String?

  division  String?  @default("ETHANOL")
  companyId String? // null = MSPIL default
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases DirectPurchase[]
  payments  FarmerPayment[]

  @@index([phone])
  @@index([aadhaar])
  @@index([maanNumber])
  @@index([companyId])
  @@index([isActive])
}

// ══════════════════════════════════════════════════════════════
// FARMER PAYMENTS — payouts to farmers (cash voucher / UPI / bank).
// Separate from VendorPayment so farmer ledger doesn't mix with Trade Creditors.
// Posted to dedicated GL account 2003 (Farmers Payable) via autoJournal.
// ══════════════════════════════════════════════════════════════

model FarmerPayment {
  id          String   @id @default(uuid())
  paymentNo   Int      @default(autoincrement())
  farmerId    String
  farmer      Farmer   @relation(fields: [farmerId], references: [id])
  paymentDate DateTime @default(now())
  amount      Float
  mode        String   @default("CASH") // CASH, UPI, NEFT, RTGS, BANK_TRANSFER
  reference   String? // UPI ref / cheque no / UTR
  remarks     String?
  // Optional link to a specific DirectPurchase if paying for a single trip
  purchaseId  String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([farmerId])
  @@index([paymentDate])
  @@index([companyId])
}

// Scrap / Misc Sales Orders — open rate contracts with validity period
model DirectSale {
  id               String    @id @default(uuid())
  entryNo          Int       @default(autoincrement())
  date             DateTime  @default(now())
  // Buyer — linked to Customer master
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id])
  buyerName        String
  buyerPhone       String?
  buyerAddress     String?
  // Product & Rate
  productName      String // Scrap Iron, Scrap SS, etc.
  rate             Float     @default(0)
  unit             String    @default("KG")
  // Validity
  validFrom        DateTime  @default(now())
  validTo          DateTime?
  status           String    @default("ACTIVE") // ACTIVE, EXPIRED, CLOSED
  // Supplied (running total from weighbridge dispatches)
  quantity         Float     @default(0) // estimated/target qty (0 = open/unlimited)
  totalSuppliedQty Float     @default(0)
  totalSuppliedAmt Float     @default(0)
  amount           Float     @default(0) // legacy: qty × rate (for backward compat)
  // Vehicle (legacy — future dispatches tracked separately)
  vehicleNo        String?
  weightSlipNo     String?
  grossWeight      Float?
  tareWeight       Float?
  netWeight        Float?
  // Payment (legacy)
  paymentMode      String    @default("CASH")
  paymentRef       String?
  isPaid           Boolean   @default(true)
  //
  remarks          String?
  userId           String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  division  String?    @default("ETHANOL")
  companyId String? // FK → Company (null = MSPIL default)
  company   Company?   @relation(fields: [companyId], references: [id])
  shipments Shipment[]

  @@index([date])
  @@index([status])
  @@index([division])
  @@index([customerId])
  @@index([validFrom])
  @@index([validTo])
  @@index([companyId])
}

// ── ETHANOL SUPPLY / CONTRACTS ──

model EthanolContract {
  id           String @id @default(uuid())
  contractNo   String @unique
  contractType String // JOB_WORK, FIXED_PRICE, OMC
  status       String @default("ACTIVE") // DRAFT, ACTIVE, EXPIRED, TERMINATED

  // Buyer / Party
  buyerName    String
  buyerAddress String?
  buyerGst     String?
  buyerPan     String?
  buyerContact String?
  buyerPhone   String?
  buyerEmail   String?

  // OMC-specific
  omcName         String? // IOCL, BPCL, HPCL, JioBP, Nayara
  omcDepot        String? // delivery depot/location
  allocationQtyKL Float? // allocated qty in KL

  // Job Work-specific (principal provides grain, MSPIL converts)
  principalName    String? // e.g. "Mash Bio Fuels Pvt Ltd"
  conversionRate   Float? // ₹/BL for ethanol conversion charges
  ddgsRate         Float? // ₹/kg for DDGS
  ethanolBenchmark Float? // BL per 1000kg grain (e.g. 374)
  ddgsBenchmark    Float? // kg per BL ethanol (e.g. 0.76)
  prcPenalty       Float? // ₹/BL short supply penalty

  // Fixed Price-specific
  ethanolRate Float? // ₹/Litre base rate (e.g. 60)

  // Common terms
  startDate        DateTime
  endDate          DateTime
  contractQtyKL    Float? // total contract quantity KL
  dailyTargetKL    Float? // daily supply target KL
  minLiftingPerDay Int? // min tankers per day
  tankerCapacityKL String? // "20/30/35/40" etc
  paymentTermsDays Int? // payment within X days
  paymentMode      String? // RTGS, NEFT, BANK_TRANSFER
  gstPercent       Float?
  supplyType       String? // INTRA_STATE, INTER_STATE
  logisticsBy      String? // BUYER, SELLER, PRINCIPAL

  // Buyer → Customer link (for invoice / e-invoice)
  buyerCustomerId      String?
  buyerCustomer        Customer? @relation(fields: [buyerCustomerId], references: [id])
  autoGenerateEInvoice Boolean   @default(false)

  // Tracking (updated on dispatch)
  totalSuppliedKL  Float @default(0)
  totalInvoicedAmt Float @default(0)
  totalReceivedAmt Float @default(0)

  remarks         String?
  contractPdf     String? // base64-encoded PDF
  contractPdfName String? // original filename
  userId          String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  liftings   EthanolLifting[]
  dispatches DispatchTruck[]
  companyId  String? // FK → Company (null = MSPIL default)
  company    Company?         @relation(fields: [companyId], references: [id])

  @@index([buyerCustomerId])
  @@index([companyId])
  @@index([status])
  @@index([contractType])
}

model EthanolLifting {
  id                String          @id @default(uuid())
  contractId        String
  contract          EthanolContract @relation(fields: [contractId], references: [id])
  liftingDate       DateTime
  vehicleNo         String
  driverName        String?
  driverPhone       String?
  transporterName   String?
  destination       String?
  quantityBL        Float           @default(0)
  quantityKL        Float           @default(0)
  strength          Float?
  temperature       Float?
  // Billing
  rate              Float? // ₹/BL or ₹/L
  amount            Float?
  invoiceNo         String?
  invoiceDate       DateTime?
  invoiceId         String?
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id])
  distanceKm        Int? // for e-way bill generation
  // Consignee (Ship To) — if different from buyer
  consigneeName     String?
  consigneeGstin    String?
  consigneeAddress  String?
  consigneeState    String?
  consigneePincode  String?
  // Status
  status            String          @default("LOADED") // LOADED, IN_TRANSIT, DELIVERED, SHORTAGE
  deliveredQtyKL    Float?
  shortageKL        Float?
  omcReceiptNo      String?
  deliveredAt       DateTime?
  // Dispatch/transport details (from Tally)
  rstNo             String? // RST / Delivery Note number (e.g. "1053")
  challanNo         String? // Challan / dispatch doc number
  dispatchMode      String?         @default("TANKER") // TANKER, TRUCK, PIPELINE
  productRatePerLtr Float? // Actual product rate ₹/Ltr (e.g. 71.86) — for EWB value
  productValue      Float? // Product basic value (qty × productRate) — for EWB/insurance
  remarks           String?
  userId            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  dispatchTruck DispatchTruck?

  @@index([contractId])
  @@index([invoiceId])
  @@index([liftingDate])
  @@index([status])
}

model TelegramMessage {
  id        String   @id @default(cuid())
  direction String // "incoming" or "outgoing"
  chatId    String // Telegram chat ID
  name      String? // sender name if available
  message   String   @db.Text
  module    String? // which ERP module sent it
  timestamp DateTime @default(now())

  @@index([chatId, timestamp])
  @@index([module, timestamp])
  @@index([timestamp])
}

model WhatsAppMessage {
  id        String   @id @default(cuid())
  direction String // "outgoing" (for now)
  recipient String // phone or group JID
  message   String   @db.Text
  module    String?
  status    String   @default("sent") // sent, failed
  timestamp DateTime @default(now())

  @@index([recipient, timestamp])
  @@index([module, timestamp])
  @@index([timestamp])
}

// ═══════════════════════════════════════════════════
// ACCOUNTS MODULE — Double-Entry Bookkeeping
// ═══════════════════════════════════════════════════

model Account {
  id               String            @id @default(cuid())
  code             String            @unique // e.g. "1001", "2001"
  name             String // e.g. "Cash in Hand", "SBI Current A/c"
  type             String // ASSET, LIABILITY, INCOME, EXPENSE, EQUITY
  subType          String? // CURRENT_ASSET, FIXED_ASSET, DIRECT_INCOME, etc.
  parentId         String?
  parent           Account?          @relation("AccountTree", fields: [parentId], references: [id])
  children         Account[]         @relation("AccountTree")
  isSystem         Boolean           @default(false) // system accounts can't be deleted
  isActive         Boolean           @default(true)
  openingBalance   Float             @default(0)
  journalLines     JournalLine[]
  bankTransactions BankTransaction[]
  companyId        String? // FK → Company (null = MSPIL default)
  company          Company?          @relation(fields: [companyId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([type])
  @@index([parentId])
  @@index([companyId])
}

model JournalEntry {
  id              String        @id @default(cuid())
  entryNo         Int           @unique @default(autoincrement())
  date            DateTime
  narration       String
  refType         String? // SALE, PURCHASE, PAYMENT, RECEIPT, CONTRA, JOURNAL
  refId           String? // FK to Invoice/VendorInvoice/Payment etc.
  isAutoGenerated Boolean       @default(false)
  isReversed      Boolean       @default(false)
  reversalOf      String? // original entry ID if this is a reversal
  lines           JournalLine[]
  userId          String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([refType, refId])
  @@index([userId])
  @@index([division])
  @@index([companyId])
}

model JournalLine {
  id         String       @id @default(cuid())
  journalId  String
  journal    JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  accountId  String
  account    Account      @relation(fields: [accountId], references: [id])
  debit      Float        @default(0)
  credit     Float        @default(0)
  narration  String?
  costCenter String? // DISTILLERY, BOILER, DDGS, ADMIN, TRANSPORT, MAINTENANCE
  division   String? // SUGAR | POWER | ETHANOL | COMMON

  @@index([journalId])
  @@index([accountId])
  @@index([division])
}

model BankTransaction {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id])
  date           DateTime
  description    String
  refNo          String? // cheque/UTR number
  debit          Float    @default(0)
  credit         Float    @default(0)
  balance        Float    @default(0)
  isReconciled   Boolean  @default(false)
  reconciledWith String? // JournalEntry ID matched to
  importBatch    String? // batch ID for CSV imports
  createdAt      DateTime @default(now())

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([accountId, date])
  @@index([isReconciled])
  @@index([division])
  @@index([companyId])
}

// ── Gate Entry (Vehicle In/Out Register) ──
model GateEntry {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  vehicleNo       String
  capacityTon     Float    @default(0)
  vendor          String   @default("")
  transporterName String   @default("")
  material        String   @default("OTHER") // DDGS, ETHANOL, MAIZE, OTHER
  direction       String   @default("INBOUND") // INBOUND, OUTBOUND
  status          String   @default("INSIDE") // INSIDE, LOADING, LOADED, DISPATCHED, EMPTY_OUT
  entryTime       String   @default("")
  exitTime        String?
  driverMobile    String   @default("")
  rstNo           String   @default("")
  remarks         String?
  grossWeight     Float?
  netWeight       Float?
  // Links to other modules
  grnId           String? // Link to GRN (for inbound purchases)
  shipmentId      String? // Link to Shipment (for outbound sales)
  userId          String? // Who created this entry
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  division String? @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON

  @@index([date])
  @@index([status])
  @@index([vehicleNo])
  @@index([division])
}

// ══════════════════════════════════════════════════════════════
// CASH VOUCHER — Petty cash, advances, informal payments
// "Pay 4000 to Khan uncle, paperwork later"
// ══════════════════════════════════════════════════════════════

model CashVoucher {
  id              String    @id @default(uuid())
  voucherNo       Int       @default(autoincrement())
  date            DateTime  @default(now())
  type            String    @default("PAYMENT") // PAYMENT, RECEIPT, ADVANCE, REFUND
  payeeName       String
  payeePhone      String?
  purpose         String
  category        String    @default("MISC") // LABOUR, TRANSPORT, REPAIR, MATERIAL, OFFICE, MISC
  amount          Float
  paymentMode     String    @default("CASH") // CASH, UPI, BANK_TRANSFER
  paymentRef      String?
  authorizedBy    String // "Dad", "Manager", free text
  status          String    @default("ACTIVE") // ACTIVE, SETTLED, CANCELLED
  settlementDate  DateTime?
  settlementNote  String?
  linkedInvoiceId String? // when paperwork arrives, link to vendor invoice
  journalEntryId  String? // FK to auto-generated journal entry
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([status])
  @@index([type])
  @@index([userId])
  @@index([division])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// BANK LOANS — Term loans, working capital, CC limits
// ══════════════════════════════════════════════════════════════

model BankLoan {
  id                 String          @id @default(uuid())
  loanNo             String          @unique
  bankName           String
  bankAccountCode    String? // Account code from Chart of Accounts (e.g., 2400)
  loanType           String          @default("TERM_LOAN") // TERM_LOAN, WORKING_CAPITAL, CC_LIMIT, EQUIPMENT
  sanctionAmount     Float
  disbursedAmount    Float           @default(0)
  outstandingAmount  Float           @default(0)
  interestRate       Float // Annual rate (e.g., 9.5)
  tenure             Int // Months
  emiAmount          Float           @default(0)
  sanctionDate       DateTime
  disbursementDate   DateTime?
  maturityDate       DateTime?
  status             String          @default("ACTIVE") // ACTIVE, CLOSED, RESTRUCTURED
  repaymentFrequency String          @default("MONTHLY") // MONTHLY, QUARTERLY, HALF_YEARLY, BULLET, NONE
  securityDetails    String?
  remarks            String?
  repayments         LoanRepayment[]
  userId             String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  companyId          String? // FK → Company (null = MSPIL default)
  company            Company?        @relation(fields: [companyId], references: [id])

  @@index([status])
  @@index([bankName])
  @@index([companyId])
}

model LoanRepayment {
  id               String    @id @default(uuid())
  loanId           String
  loan             BankLoan  @relation(fields: [loanId], references: [id])
  installmentNo    Int
  dueDate          DateTime
  principalAmount  Float
  interestAmount   Float
  totalAmount      Float
  outstandingAfter Float
  status           String    @default("SCHEDULED") // SCHEDULED, PAID, OVERDUE, SKIPPED
  paidDate         DateTime?
  paymentMode      String?
  paymentRef       String?
  journalEntryId   String?
  remarks          String?
  userId           String?
  createdAt        DateTime  @default(now())

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([loanId])
  @@index([dueDate])
  @@index([status])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// AUTO-COLLECT SCHEDULE — Telegram bot schedules per module
// ══════════════════════════════════════════════════════════════

model AutoCollectSchedule {
  id              String   @id @default(uuid())
  module          String   @unique // 'ddgs', 'decanter', etc.
  phone           String   @default("")
  intervalMinutes Int      @default(60)
  enabled         Boolean  @default(false)
  autoShare       Boolean  @default(true)
  language        String   @default("hi")
  bagWeight       Int      @default(35) // kg per bag (DDGS module)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([module])
}

// ══════════════════════════════════════════════════════════════
// POST-DATED CHEQUES (PDC) — Track outgoing/incoming post-dated cheques
// ══════════════════════════════════════════════════════════════

model PostDatedCheque {
  id              String    @id @default(uuid())
  chequeNo        Int       @default(autoincrement())
  direction       String    @default("OUTGOING") // OUTGOING (we give) | INCOMING (we receive)
  chequeNumber    String // printed cheque number
  chequeDate      DateTime // date written on cheque
  maturityDate    DateTime // when to present/deposit
  amount          Float
  bankName        String // issuing bank
  branchName      String?
  accountNo       String? // bank account number
  // Party
  partyType       String    @default("VENDOR") // VENDOR | CUSTOMER
  partyId         String // vendor or customer ID
  partyName       String // denormalized for display
  // Purpose & linking
  purpose         String? // e.g. "Against INV-123"
  linkedInvoiceId String? // vendor or customer invoice ID
  linkedPoId      String? // for vendor PDCs
  // Status lifecycle: ISSUED → DEPOSITED → CLEARED | DISHONOURED | CANCELLED
  status          String    @default("ISSUED")
  depositDate     DateTime? // when deposited in bank
  clearDate       DateTime? // when cleared
  dishonourDate   DateTime?
  dishonourReason String?
  // Journal
  journalEntryId  String? // auto-journal on issue
  remarks         String?
  userId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  companyId       String? // FK → Company (null = MSPIL default)
  company         Company?  @relation(fields: [companyId], references: [id])

  @@index([maturityDate])
  @@index([status])
  @@index([partyId])
  @@index([direction])
  @@index([companyId])
  @@index([chequeDate])
}

// ══════════════════════════════════════════════════════════════
// BANK PAYMENTS — UBI H2H-STP Direct Payment Integration
// Security: Maker-Checker-Releaser workflow, PIN auth, full audit trail
// ══════════════════════════════════════════════════════════════

model BankPaymentBatch {
  id             String             @id @default(uuid())
  batchNo        Int                @default(autoincrement())
  status         String             @default("DRAFT")
  // DRAFT → APPROVED → RELEASED → SENT_TO_BANK → COMPLETED → FAILED / PARTIAL
  paymentType    String             @default("NEFT") // NEFT, RTGS
  debitAccount   String             @default("") // MSPIL account number
  payerIfsc      String             @default("") // MSPIL IFSC
  totalAmount    Float              @default(0)
  recordCount    Int                @default(0)
  // Maker (creator)
  createdBy      String // userId of maker
  // Checker (approver)
  checkedBy      String? // userId of checker
  checkedAt      DateTime?
  checkerRemarks String?
  // Releaser (final auth)
  releasedBy     String? // userId of releaser
  releasedAt     DateTime?
  // Bank file
  fileName       String? // file name sent to SFTP
  sentAt         DateTime? // when uploaded to SFTP
  // ACK/NACK response from bank
  ackFileName    String?
  ackReceivedAt  DateTime?
  ackStatus      String? // ACK, NACK, PARTIAL
  ackRemarks     String?
  // Timestamps
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  // Relations
  items          BankPaymentItem[]
  audit          BankPaymentAudit[]
  companyId      String? // FK → Company (null = MSPIL default)
  company        Company?           @relation(fields: [companyId], references: [id])

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@index([batchNo])
  @@index([companyId])
  @@index([paymentType])
}

model BankPaymentItem {
  id                 String           @id @default(uuid())
  batchId            String
  batch              BankPaymentBatch @relation(fields: [batchId], references: [id])
  // Vendor / Payee
  vendorId           String?
  vendorInvoiceId    String?
  beneficiaryName    String
  beneficiaryAccount String
  beneficiaryIfsc    String
  beneficiaryBank    String?
  beneficiaryEmail   String?
  beneficiaryPhone   String?
  // Amount
  amount             Float
  remarks            String?
  // Status per item
  status             String           @default("PENDING")
  // PENDING → APPROVED → REJECTED → SENT → SUCCESS → FAILED
  rejectionReason    String? // if checker rejects this item
  utrNumber          String? // UTR from ACK response
  failureReason      String? // reason from NACK response
  // Link to VendorPayment (created after ACK confirms success)
  vendorPaymentId    String?
  //
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([batchId])
  @@index([vendorId])
  @@index([status])
  @@index([vendorInvoiceId])
}

model BankPaymentAudit {
  id        String            @id @default(uuid())
  batchId   String?
  batch     BankPaymentBatch? @relation(fields: [batchId], references: [id])
  itemId    String?
  action    String // BATCH_CREATED, ITEM_ADDED, ITEM_REMOVED, APPROVED, REJECTED, RELEASED, SENT, ACK_RECEIVED, NACK_RECEIVED, PIN_FAILED
  userId    String
  userName  String            @default("")
  ipAddress String?
  userAgent String?
  details   String? // JSON with additional context
  createdAt DateTime          @default(now())

  @@index([batchId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model PaymentPin {
  id             String    @id @default(uuid())
  userId         String    @unique
  pinHash        String // bcrypt hashed 6-digit PIN
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

// ══════════════════════════════════════════════════════════════
// MOBILE APP — Offline-first field data submissions
// ══════════════════════════════════════════════════════════════

model MobileSubmission {
  id          String    @id @default(uuid())
  localId     String    @unique // client-generated ID for idempotency
  module      String // ddgs, decanter, etc.
  data        String // JSON stringified field values
  operatorId  String
  capturedAt  DateTime // when operator entered the data
  processedAt DateTime? // when backend processed into actual tables
  createdAt   DateTime  @default(now())

  @@index([module])
  @@index([operatorId])
  @@index([capturedAt])
}

// ══════════════════════════════════════════════════════════════
// WEBHOOK EVENTS — Cloud → Factory Server push delivery
// ══════════════════════════════════════════════════════════════

model WebhookEvent {
  id          String    @id @default(uuid())
  event       String // PO_CHANGED, LAB_RESULT, VENDOR_CHANGED, MATERIAL_CHANGED, CUSTOMER_CHANGED
  payload     Json
  targetUrl   String
  status      String    @default("PENDING") // PENDING, DELIVERED, FAILED, DEAD
  attempts    Int       @default(0)
  lastError   String?
  nextRetry   DateTime  @default(now())
  deliveredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, nextRetry])
  @@index([createdAt])
}

// ══════════════════════════════════════════════════════════════
// APPROVALS — Generic admin approval queue
// Used for: PO overages, rate changes, credit limits, etc.
// ══════════════════════════════════════════════════════════════

model Approval {
  id          String    @id @default(uuid())
  type        String // PO_OVERAGE, RATE_CHANGE, CREDIT_LIMIT, etc.
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  entityType  String // PurchaseOrder, GoodsReceipt, etc.
  entityId    String // ID of the entity needing approval
  title       String // Short title for the approval
  description String // Detailed description
  requestedBy String // userId or 'system-weighbridge'
  reviewedBy  String? // admin userId who reviewed
  reviewedAt  DateTime?
  reviewNote  String?
  metadata    Json? // Extra data (e.g., { overagePercent: 7.2, excessQty: 1.5 })
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([status])
  @@index([type])
  @@index([entityId])
  @@index([companyId])
}

// ══════════════════════════════════════════════════════════════
// NOTIFICATIONS — Unified inbox (approvals, alerts, system events)
// Replaces the old "poll approvals/count" pattern with a proper
// per-user, per-role inbox with read state, severity, categories.
// ══════════════════════════════════════════════════════════════

model Notification {
  id         String    @id @default(uuid())
  category   String // APPROVAL, STOCK_LOW, PAYMENT_DUE, SYNC_ERROR, FACTORY, SYSTEM, INFO
  severity   String    @default("INFO") // INFO, WARNING, CRITICAL
  title      String
  message    String
  link       String? // deep-link path e.g. /admin/approvals/123
  // Targeting: either a specific user, or broadcast to a role
  userId     String? // if set, only this user sees it
  role       String? // ADMIN, SUPER_ADMIN, MANAGER, OPERATOR — broadcast to role
  // Source entity for dedupe + auto-resolve
  entityType String? // Approval, GoodsReceipt, PurchaseOrder, etc.
  entityId   String?
  dedupeKey  String? // prevents spamming same alert (e.g. "low-stock:ITEM-123")
  // State
  read       Boolean   @default(false)
  readAt     DateTime?
  resolved   Boolean   @default(false) // auto-set when underlying issue is gone
  resolvedAt DateTime?
  // Metadata for rendering
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, read, createdAt])
  @@index([role, read, createdAt])
  @@index([category, resolved])
  @@index([dedupeKey])
  @@index([entityType, entityId])
}

// ══════════════════════════════════════════════════════════════
// COMPANY DOCUMENTS — Document vault for compliance, certificates, contracts
// RAG-indexed via LightRAG microservice for semantic search
// ══════════════════════════════════════════════════════════════

model CompanyDocument {
  id          String    @id @default(cuid())
  category    String // COMPLIANCE, LICENSE, CERTIFICATE, CONTRACT, INSURANCE, HR, LEGAL, BANK, OTHER
  subcategory String? // EC, POLLUTION_CERT, FACTORY_LICENSE, BOILER_CERT, PESO, FIRE_NOC, etc.
  title       String
  description String?
  filePath    String
  fileName    String
  fileSize    Int?
  mimeType    String?
  issuedBy    String? // Issuing authority
  issuedDate  DateTime?
  expiryDate  DateTime?
  referenceNo String? // Certificate/license number
  department  String? // Which department owns this
  tags        String? // Comma-separated tags for filtering
  status      String    @default("ACTIVE") // ACTIVE, EXPIRED, SUPERSEDED, ARCHIVED
  uploadedBy  String?
  ragTrackId  String? // LightRAG indexing track ID
  ragIndexed  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  complianceLinks ComplianceDocument[]

  @@index([category])
  @@index([subcategory])
  @@index([expiryDate])
  @@index([status])
  @@index([ragIndexed])
}

// ── Vault Notes (auto-generated summaries for Obsidian knowledge base) ──
model VaultNote {
  id          String   @id @default(cuid())
  sourceType  String // CompanyDocument, VendorInvoice, GoodsReceipt, ContractorBill, EthanolContract, Manual
  sourceId    String? // FK to source record
  vaultPath   String   @unique // relative path in vault (e.g., documents/compliance/mppcb-clearance.md)
  title       String
  category    String // compliance, contracts, vendor, hr, legal, bank, production, other
  summary     String   @db.Text
  entities    String?  @db.Text // JSON: extracted names, dates, amounts for linking
  contentHash String // MD5 of source content — skip regeneration if unchanged
  ragIndexed  Boolean  @default(false)
  synced      Boolean  @default(false) // true once pulled to local Obsidian vault
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sourceType, sourceId])
  @@index([category])
  @@index([synced])
}

// ══════════════════════════════════════════════════════════════
// COMPLIANCE MANAGEMENT — Regulatory obligation tracker
// Built on top of Document Vault + RAG pipeline
// ══════════════════════════════════════════════════════════════

model ComplianceObligation {
  id String @id @default(cuid())

  // Classification
  category    String // FACTORY_LABOR, ENVIRONMENTAL, EXCISE_DISTILLERY, POWER_ENERGY, SUGAR_MILL, TAX_STATUTORY, SEBI_LISTING, HR_PEOPLE, LEGAL_CORPORATE
  subcategory String?
  title       String
  description String? @db.Text

  // Legal basis
  actOrRegulation String? // e.g., "Factories Act, 1948 Section 6"
  authority       String? // e.g., "Chief Inspector of Factories, MP"

  // Responsibility
  department String? // HR, Environment, Accounts, Legal, Production, Admin
  ownerName  String? // Person responsible (plain text, not FK)

  // Frequency & Dates
  frequency         String    @default("ANNUAL") // ONE_TIME, MONTHLY, QUARTERLY, HALF_YEARLY, ANNUAL, BIENNIAL, EVENT_BASED
  dueDate           DateTime?
  lastCompletedDate DateTime?
  leadTimeDays      Int       @default(30)

  // Status & Risk
  status    String @default("PENDING") // COMPLIANT, NON_COMPLIANT, EXPIRING, PENDING, NOT_APPLICABLE
  riskLevel String @default("MEDIUM") // CRITICAL, HIGH, MEDIUM, LOW

  // Penalty
  penaltyInfo String? @db.Text

  // Notes
  notes String? @db.Text

  // Relations
  documents ComplianceDocument[]
  actions   ComplianceAction[]

  // Audit
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([title, category])
  @@index([category])
  @@index([status])
  @@index([dueDate])
  @@index([riskLevel])
  @@index([department])
  @@index([frequency])
  @@index([createdAt])
}

// Join table: which CompanyDocuments fulfill which obligations
model ComplianceDocument {
  id           String               @id @default(cuid())
  obligationId String
  obligation   ComplianceObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  documentId   String
  document     CompanyDocument      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  isFulfilling Boolean              @default(true) // true = this doc proves compliance
  notes        String?
  createdAt    DateTime             @default(now())

  @@unique([obligationId, documentId])
  @@index([obligationId])
  @@index([documentId])
}

// Audit log of every compliance activity
model ComplianceAction {
  id              String               @id @default(cuid())
  obligationId    String
  obligation      ComplianceObligation @relation(fields: [obligationId], references: [id], onDelete: Cascade)
  actionType      String // RENEWED, FILED, SUBMITTED, INSPECTED, PAID, UPLOADED, NOTE, STATUS_CHANGE
  description     String
  performedBy     String?
  performedDate   DateTime             @default(now())
  documentId      String? // Optional: linked CompanyDocument
  isAutoGenerated Boolean              @default(false)
  metadata        Json?
  createdAt       DateTime             @default(now())

  @@index([obligationId])
  @@index([actionType])
  @@index([performedDate])
}

// ═══════════════════════════════════════════════
// DDGS CONTRACTS (supply agreements with buyers)
// ═══════════════════════════════════════════════
model DDGSContract {
  id                    String   @id @default(uuid())
  contractNo            String   @unique
  status                String   @default("ACTIVE") // DRAFT, ACTIVE, EXPIRED, TERMINATED
  dealType              String   @default("FIXED_RATE") // FIXED_RATE, JOB_WORK, SPOT
  processingChargePerMT Float? // job work only
  principalName         String? // job work only
  customerId            String
  customer              Customer @relation(fields: [customerId], references: [id])
  buyerName             String
  buyerAddress          String?
  buyerGstin            String?
  buyerState            String?
  buyerContact          String?
  buyerPhone            String?
  buyerEmail            String?
  supplyType            String? // INTRA_STATE, INTER_STATE
  startDate             DateTime
  endDate               DateTime
  quantityType          String   @default("FIXED") // FIXED, OPEN
  contractQtyMT         Float    @default(0) // 0 when quantityType=OPEN
  rate                  Float    @default(0) // ₹/MT
  gstPercent            Float    @default(5)
  paymentTermsDays      Int?
  paymentMode           String?
  logisticsBy           String   @default("BUYER")
  remarks               String?
  contractPdf           String? // base64
  contractPdfName       String?
  autoGenerateEInvoice  Boolean  @default(false)

  totalSuppliedMT  Float @default(0)
  totalInvoicedAmt Float @default(0)
  totalReceivedAmt Float @default(0)

  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches     DDGSContractDispatch[]
  dispatchTrucks DDGSDispatchTruck[]
  companyId      String? // FK → Company (null = MSPIL default)
  company        Company?               @relation(fields: [companyId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([companyId])
  @@index([startDate])
  @@index([endDate])
}

model DDGSContractDispatch {
  id              String       @id @default(uuid())
  contractId      String
  contract        DDGSContract @relation(fields: [contractId], references: [id])
  dispatchDate    DateTime
  vehicleNo       String
  driverName      String?
  driverPhone     String?
  transporterName String?
  destination     String?
  bags            Int          @default(0)
  weightPerBag    Float        @default(50)
  weightGrossMT   Float        @default(0)
  weightTareMT    Float        @default(0)
  weightNetMT     Float        @default(0)
  rate            Float        @default(0)
  amount          Float        @default(0)
  distanceKm      Float?
  challanNo       String?
  gatePassNo      String?

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  ddgsDispatchTruckId String?            @unique
  ddgsDispatchTruck   DDGSDispatchTruck? @relation(fields: [ddgsDispatchTruckId], references: [id])

  status    String   @default("DISPATCHED")
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contractId])
  @@index([dispatchDate])
}

// ═══════════════════════════════════════════════
// SUGAR (received from sister sugar mill, sold via ERP)
// ═══════════════════════════════════════════════

model SugarStockEntry {
  id                   String   @id @default(uuid())
  date                 DateTime
  yearStart            Int
  openingStock         Float    @default(0) // MT
  receiptFromMillToday Float    @default(0) // MT received from sister mill
  dispatchToday        Float    @default(0) // MT dispatched out
  closingStock         Float    @default(0) // opening + receipt - dispatch
  bags                 Int      @default(0)
  weightPerBag         Float    @default(50) // kg per bag
  remarks              String?
  userId               String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([date, yearStart])
  @@index([date])
}

model SugarDispatchTruck {
  id                    String                 @id @default(uuid())
  date                  DateTime               @default(now())
  status                String                 @default("GATE_IN") // GATE_IN → TARE_WEIGHED → LOADING → GROSS_WEIGHED → BILLED → RELEASED
  rstNo                 Int?
  vehicleNo             String                 @default("")
  partyName             String                 @default("")
  partyAddress          String?
  partyGstin            String?
  destination           String                 @default("")
  driverName            String?
  driverMobile          String?
  transporterName       String?
  bags                  Int                    @default(0)
  weightPerBag          Float                  @default(50)
  weightGross           Float                  @default(0)
  weightTare            Float                  @default(0)
  weightNet             Float                  @default(0)
  rate                  Float? // ₹ per MT
  invoiceNo             String?
  invoiceAmount         Float?
  gatePassNo            String?
  ewayBillNo            String?
  hsnCode               String                 @default("1701") // Sugar HSN
  gateInTime            DateTime?
  tareTime              DateTime?
  grossTime             DateTime?
  releaseTime           DateTime?
  remarks               String?
  sourceWbId            String?                @unique // Factory weighment ID for dedup (CRITICAL for idempotency)
  customerId            String?
  customer              Customer?              @relation(fields: [customerId], references: [id])
  contractId            String?
  contract              SugarContract?         @relation(fields: [contractId], references: [id])
  userId                String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @default(now()) @updatedAt
  sugarContractDispatch SugarContractDispatch?

  division  String?  @default("ETHANOL") // SUGAR | POWER | ETHANOL | COMMON
  companyId String? // FK → Company (null = MSPIL default)
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([date])
  @@index([customerId])
  @@index([contractId])
  @@index([status])
  @@index([division])
  @@index([companyId])
}

model SugarContract {
  id                   String   @id @default(uuid())
  contractNo           String   @unique
  status               String   @default("ACTIVE") // DRAFT, ACTIVE, EXPIRED, TERMINATED
  dealType             String   @default("FIXED_RATE") // FIXED_RATE, SPOT
  customerId           String
  customer             Customer @relation(fields: [customerId], references: [id])
  buyerName            String
  buyerAddress         String?
  buyerGstin           String?
  buyerState           String?
  buyerContact         String?
  buyerPhone           String?
  buyerEmail           String?
  supplyType           String? // INTRA_STATE, INTER_STATE
  startDate            DateTime
  endDate              DateTime
  contractQtyMT        Float    @default(0)
  rate                 Float    @default(0) // ₹/MT
  gstPercent           Float    @default(5)
  paymentTermsDays     Int?
  paymentMode          String?
  logisticsBy          String   @default("BUYER")
  remarks              String?
  contractPdf          String? // base64
  contractPdfName      String?
  autoGenerateEInvoice Boolean  @default(false)

  totalSuppliedMT  Float @default(0)
  totalInvoicedAmt Float @default(0)
  totalReceivedAmt Float @default(0)

  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches     SugarContractDispatch[]
