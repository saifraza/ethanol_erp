generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/@prisma/opc-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_OPC")
}

// Tags being monitored — synced from Windows SQLite
model OpcMonitoredTag {
  id          String   @id @default(cuid())
  tag         String   @unique
  area        String
  folder      String
  tagType     String   @default("analog")
  label       String   @default("")
  description String   @default("")
  hhAlarm     Float?   // High-High alarm limit
  llAlarm     Float?   // Low-Low alarm limit
  pushToCloud Boolean  @default(true)  // true=push readings to cloud, false=local alarm only
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([area])
  @@index([active])
}

// Raw readings pushed every scan (keep 24h, auto-purge older)
model OpcReading {
  id         String   @id @default(cuid())
  tag        String
  property   String   // PV, SP, OP, IO_VALUE
  value      Float
  scannedAt  DateTime
  receivedAt DateTime @default(now())

  @@index([tag, scannedAt])
  @@index([scannedAt])
  @@index([tag, property, scannedAt])
}

// Hourly averages — permanent storage
model OpcHourlyReading {
  id        String   @id @default(cuid())
  tag       String
  property  String
  hour      DateTime
  avg       Float
  min       Float
  max       Float
  count     Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([tag, property, hour])
  @@index([tag, hour])
  @@index([hour])
}

// Sync tracking — last successful push from Windows
model OpcSyncLog {
  id        String   @id @default(cuid())
  syncType  String   // "readings" | "hourly" | "tags"
  batchId   String?
  tagCount  Int      @default(0)
  readingCount Int   @default(0)
  syncedAt  DateTime @default(now())

  @@index([syncType, syncedAt])
}

// Alarm log — permanent record of all alarms fired (local or cloud)
model OpcAlarmLog {
  id           String   @id @default(uuid())
  tag          String
  label        String   @default("")
  value        Float
  limit        Float
  alarmType    String   // 'HH' or 'LL'
  acknowledged Boolean  @default(false)
  sentAt       DateTime @default(now())

  @@index([tag, sentAt])
  @@index([sentAt])
}
